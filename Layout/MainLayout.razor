@inherits LayoutComponentBase

<MudThemeProvider Theme="@mahjongTheme" @bind-IsDarkMode="_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    @* 上部のバー *@
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">麻雀集計ツール</MudText>
        <MudSpacer />
        @* --- ダークモード切り替えスイッチ --- *@
        <MudToggleIconButton @bind-Toggled="_isDarkMode"
                             Icon="@Icons.Material.Filled.DarkMode" Color="Color.Inherit" Title="ダークモードへ"
                             ToggledIcon="@Icons.Material.Filled.LightMode" ToggledColor="Color.Inherit" ToggledTitle="ライトモードへ" />
    </MudAppBar>

    @* 左側のメニュー *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Width="160px">
        <NavMenu />
    </MudDrawer>

    @* メメイン画面 *@
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = false;
    bool _isDarkMode = true; // デフォルトをダークモードに設定

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private MudTheme mahjongTheme = new MudTheme()
    {
        // --- ライトモード設定（以前の設定を維持） ---
        PaletteLight = new PaletteLight()
        {
            Primary = "#1b5e20",     // 深緑
            Secondary = "#b71c1c",   // 赤
            Background = "#2e7d32",  // 鮮やかな緑（雀卓）
            Surface = "#ffffff",     // 白
            TextPrimary = "#000000",
            AppbarBackground = "#1b5e20",
        },

        // --- ダークモード設定（シックな黒緑スタイル） ---
        PaletteDark = new PaletteDark()
        {
            Primary = "#81c784",      // 明るめの緑（ボタン等）
            Secondary = "#ef5350",    // 明るめの赤（削除ボタン等）
            Background = "#0d140d",   // 背景：黒に近い深い緑
            Surface = "#1a261a",      // カード：少しだけ明るい黒緑（雀卓の質感をイメージ）
            AppbarBackground = "#081008", // バー：さらに暗い緑
            TextPrimary = "#e0e0e0",  // 文字：少しグレーがかった白（まぶしさを抑制）
            TextSecondary = "#b0b0b0",
            ActionDefault = "#81c784",
            DrawerBackground = "#121d12", // ドロワー：背景に近い深い緑
            Divider = "#2e3b2e",      // 区切り線
            TableStriped = "rgba(255,255,255,0.02)"
        }
    };
}