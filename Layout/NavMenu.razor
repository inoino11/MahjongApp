@using System.Reflection
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@implements IDisposable

<div style="display: flex; flex-direction: column; height: 100%;">
    <MudNavMenu>
        <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Functions">素点集計</MudNavLink>
        <MudNavLink Href="sessions" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">対局履歴</MudNavLink>
        <MudNavLink Href="dashboard" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QueryStats">通算成績</MudNavLink>
        <MudNavLink Href="players" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ManageAccounts">名簿管理</MudNavLink>
        <MudNavLink Href="settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">データ管理</MudNavLink>
    </MudNavMenu>
    <div style="margin-top: auto;">
        @* Android / PC 用インストールボタン *@
        @if (canInstall)
        {
            <div class="px-4 mb-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.InstallMobile" FullWidth="true" OnClick="InstallPwaAsync" Style="font-size: 0.8rem; padding: 4px 8px; border-radius: 8px;">
                    アプリとして追加
                </MudButton>
            </div>
        }
        @* iOS Webブラウザ用 警告＆案内メッセージ *@
        @if (isIosWebBrowser)
        {
            <div class="px-3 mb-2">
                <MudAlert Severity="Severity.Warning" Class="pa-2" Style="font-size: 0.75rem; line-height: 1.4;">
                    <div style="font-weight: bold; margin-bottom: 4px;">📱 iPhone/iPadの方へ</div>
                    共有メニューから「ホーム画面に追加」でアプリ化できますが、<span style="color: #d32f2f; font-weight: bold;">Safariのデータは引き継がれません。</span><br />
                    事前に「データ管理」からバックアップをお願いします。
                </MudAlert>
            </div>
        }
        @* バージョン表示 *@
        <MudButton Variant="Variant.Text" OnClick="CheckForUpdateAsync" Style="color: var(--mud-palette-text-disabled); font-family: monospace; text-transform: none; padding: 4px 8px; min-width: 0; font-size: 0.8rem;" Disabled="@isChecking">
            @if (isChecking)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span style="white-space: nowrap;">確認中...</span>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" Class="mr-1" />
                <span style="white-space: nowrap;">@AppVersion</span>
            }
        </MudButton>
    </div>
</div>

@code {
    private string AppVersion { get; set; } = "v--.--.--";
    private bool isChecking = false;
    private bool canInstall = false;
    private DotNetObjectReference<NavMenu>? objRef;
    private bool isIosWebBrowser = false;
    protected override void OnInitialized()
    {
        var assembly = Assembly.GetExecutingAssembly();
        var attr = assembly.GetCustomAttribute<AssemblyInformationalVersionAttribute>();
        if (attr != null) AppVersion = attr.InformationalVersion;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("pwaInstall.init", objRef);
            isIosWebBrowser = await JSRuntime.InvokeAsync<bool>("pwaHelper.isIosWeb");
            StateHasChanged();
        }
    }

    // JSから呼び出されるメソッド（インストール可能時）
    [JSInvokable]
    public void OnInstallAvailable()
    {
        canInstall = true;
        StateHasChanged();
    }

    // JSから呼び出されるメソッド（インストール完了時）
    [JSInvokable]
    public void OnInstalled()
    {
        canInstall = false;
        StateHasChanged();
        Snackbar.Add("アプリがインストールされました", Severity.Success);
    }

    // インストールボタンが押された時の処理
    private async Task InstallPwaAsync()
    {
        try
        {
            // JS側のプロンプト表示関数を呼び出す
            var accepted = await JSRuntime.InvokeAsync<bool>("pwaInstall.prompt");
            if (accepted)
            {
                // 承認されたらボタンを消す
                canInstall = false;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("インストール中にエラーが発生しました", Severity.Error);
        }
    }

    // メモリリーク防止のための破棄処理
    public void Dispose()
    {
        objRef?.Dispose();
    }

    private async Task CheckForUpdateAsync()
    {
        isChecking = true;
        StateHasChanged();

        try
        {
            // 少しだけ待機して、ボタンが押された感（UX）を出す
            await Task.Delay(500);
            var result = await JSRuntime.InvokeAsync<string>("checkForUpdate");
            if (result == "CHECKED")
            {
                Snackbar.Add("アップデートをチェックしました", Severity.Info);
            }
            else if (result == "NOT_REGISTERED")
            {
                Snackbar.Add("Service Workerが未登録です\n初回ロードまたはPWA非対応ブラウザ", Severity.Warning);
            }
            else
            {
                Snackbar.Add("アップデートの確認に失敗しました", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"エラーが発生しました:\n{ex.Message}", Severity.Error);
        }
        finally
        {
            isChecking = false;
            StateHasChanged();
        }
    }
}