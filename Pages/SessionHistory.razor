@page "/sessions"
@using MahjongApp.Models
@inject MahjongApp.Services.DatabaseService DatabaseService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<style>
    .session-table { 
        width: 100% !important; 
    }
    /* 親テーブルは横スクロールさせず、画面幅に収める */
    .session-table .mud-table-container { 
        overflow-x: hidden !important; 
        width: 100% !important; 
    }
    /* 子テーブル（詳細領域）の横スクロール設定 */
    .child-table-wrapper { 
        overflow-x: auto !important; 
        width: 0;
        min-width: 100% !important; 
        -webkit-overflow-scrolling: touch; 
        padding-bottom: 4px; 
    }
</style>
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-10" @onclick="ClearArmedState">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white;">
        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        対局履歴
    </MudText>

    @if (isLoading)
    {
        <div class="d-flex justify-center py-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (sessionGroups.Count == 0)
    {
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">記録された対局はありません。</MudText>
    }
    else
    {
        <MudTable Items="@sessionGroups" Class="session-table" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None" Style="background-color: rgba(255,255,255,0.02);">
            <RowTemplate Context="group">
                <MudTd Style="padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <div class="d-flex align-center justify-space-between w-100" style="margin-bottom: 6px;">
                        <div class="d-flex align-center" style="gap: 4px;">
                            <MudIconButton Icon="@(group.ShowDetails ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" 
                                           OnClick="@(() => group.ShowDetails = !group.ShowDetails)" 
                                           Size="Size.Small" 
                                           Style="padding: 4px; color: #fff;" />
                            <span style="font-size: 0.95rem; font-weight: bold; color: #fff; letter-spacing: 0.5px;">
                                @group.Session.Date.ToString("yyyy/MM/dd HH:mm")
                            </span>
                        </div>
                        <div class="d-flex align-center" style="gap: 8px;">
                            <span style="font-size: 0.8rem; color: #9e9e9e; background-color: rgba(255,255,255,0.05); padding: 2px 8px; border-radius: 4px; font-weight: bold;">
                                @group.Games.Count 局
                            </span>
                            <span @onclick="() => { }" @onclick:stopPropagation="true">
                                <MudButton Size="Size.Small" 
                                           Variant="Variant.Text"
                                           Color="@(ArmedDeleteTarget == group ? Color.Error : Color.Default)" 
                                           StartIcon="@(ArmedDeleteTarget == group ? DeleteEmpty : Icons.Material.Filled.Delete)" 
                                           Style="@(ArmedDeleteTarget == group ? "font-weight: bold; min-width: 32px; padding: 4px;" : "color: #9e9e9e; min-width: 32px; padding: 4px;")"
                                           OnClick="@(() => HandleDeleteClick(group))">
                                </MudButton>
                            </span>
                        </div>
                    </div>
                    <div style="text-align: left; padding-left: 32px; font-size: 0.85rem; color: #aaaaaa; white-space: normal; word-break: break-all; line-height: 1.4;">
                        @GetPlayerNames(group.Session.ParticipantPlayerIds)
                    </div>
                </MudTd>
            </RowTemplate>
            <ChildRowContent Context="group">
                @if (group.ShowDetails)
                {
                    <MudTr>
                        <MudTd Colspan="1" Class="pa-4" Style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <MudCard Elevation="0" Style="background-color: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1);">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Secondary">◆ 対局一覧</MudText>
                                    @if (group.Games.Count > 0)
                                    {
                                        <div class="child-table-wrapper mb-4">
                                            <ResultTable History="@ConvertToGameResults(group.Games)" Players="@GetSessionPlayerNames(group)" ActiveParticipantCount="@group.Session.ParticipantPlayerIds.Count" IsReadOnly="true" />
                                        </div>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Class="mb-4">ここには対局記録がありません。</MudText>
                                    }
                                    @if (group.Session.SettledChips != null && group.Session.SettledChips.Count > 0 && group.Session.SettledChips.Any(c => c != 0))
                                    {
                                        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-2" Color="Color.Secondary">◆ チップ精算 (レート: @group.Session.ChipRate 円)</MudText>
                                        <div class="d-flex flex-wrap gap-2">
                                            @for (int i = 0; i < group.Session.ParticipantPlayerIds.Count; i++)
                                            {
                                                var pId = group.Session.ParticipantPlayerIds[i];
                                                if (string.IsNullOrEmpty(pId)) continue;
                                                var pName = GetPlayerName(pId);
                                                var chips = group.Session.SettledChips.Count > i ? group.Session.SettledChips[i] : 0;
                                                var chipYen = chips * group.Session.ChipRate;
                                                var color = chips >= 0 ? "#ff6b6b" : "#4dabf7";
                                                var sign = chips > 0 ? "+" : "";
                                                if (chips != 0)
                                                {
                                                    <span style="font-size: 0.85rem; padding: 2px 6px; background-color: rgba(255,255,255,0.05); border-radius: 4px;">
                                                        @pName: <span style="color: @color; font-weight: bold;">@sign@chips 枚 (@sign@chipYen.ToString("N0")円)</span>
                                                    </span>
                                                }
                                            }
                                        </div>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudTd>
                    </MudTr>
                }
            </ChildRowContent>
        </MudTable>
    }
</MudContainer>

@code {
    private bool isLoading = true;
    private List<SessionGroup> sessionGroups = new();
    private List<PlayerProfile> allPlayers = new();
    private Dictionary<string, string> playerMap = new();
    private SessionGroup? ArmedDeleteTarget { get; set; }

    public class SessionGroup
    {
        public SavedSessionRecord Session { get; set; } = new();
        public List<SavedGameRecord> Games { get; set; } = new();
        public bool ShowDetails { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        var dbData = await DatabaseService.GetAllDataAsync();
        if (dbData != null)
        {
            allPlayers = dbData.Players;
            playerMap = dbData.Players.ToDictionary(p => p.Id, p => p.Name);
            
            // 対局を日付の降順（新しい順）で並べ、紐づく対局データをグループ化
            sessionGroups = dbData.Sessions
                .OrderByDescending(s => s.Date)
                .Select(s => new SessionGroup
                {
                    Session = s,
                    Games = dbData.Games.Where(g => g.SessionId == s.SessionId).OrderBy(g => g.Timestamp).ToList(),
                    ShowDetails = false
                })
                .ToList();
        }
        
        isLoading = false;
        StateHasChanged();
    }

    // ごみ箱ボタンのクリックハンドラー
    private async Task HandleDeleteClick(SessionGroup group)
    {
        if (ArmedDeleteTarget != group)
        {
            ArmedDeleteTarget = group;
            return;
        }
        await ConfirmDeleteSession(group);
    }

    // 別の場所をクリックしたときに警告（Armed）状態を解除する
    private void ClearArmedState()
    {
        if (ArmedDeleteTarget != null)
        {
            ArmedDeleteTarget = null;
        }
    }

    private string GetPlayerName(string id) => playerMap.TryGetValue(id, out var name) ? name : "不明";

    private string GetPlayerNames(List<string> ids)
    {
        var names = ids.Where(id => !string.IsNullOrEmpty(id) && id != "deleted").Select(GetPlayerName);
        return string.Join(", ", names);
    }

    private async Task ConfirmDeleteSession(SessionGroup group)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "対局の削除",
            $"この対局（{group.Session.Date.ToString("yyyy/MM/dd HH:mm")}）データを完全に削除します。\nよろしいですか？",
            yesText: "削除する", cancelText: "キャンセル");
            
        if (result == true)
        {
            await DatabaseService.DeleteSessionAsync(group.Session.SessionId);
            Snackbar.Add("対局記録を削除しました", Severity.Success);
            await LoadData();
        }
        else
        {
            ArmedDeleteTarget = null;
        }
    }

    // データベース用の型(SavedGameRecord)を、UI表示用の型(GameResult)に変換する
    private List<GameResult> ConvertToGameResults(List<SavedGameRecord> savedGames)
    {
        return savedGames.Select(g => new GameResult
        {
            Timestamp = g.Timestamp,
            RawScores = g.RawScores != null ? new List<int?>(g.RawScores) : new(),
            Points = g.Points != null ? new List<double>(g.Points) : new(),
            Yen = g.Yen != null ? new List<int>(g.Yen) : new()
        }).ToList();
    }

    // ResultTableのヘッダーに表示するための「名前のリスト」を生成する
    private List<string> GetSessionPlayerNames(SessionGroup group)
    {
        return group.Session.ParticipantPlayerIds
            .Select(id => GetPlayerName(id))
            .ToList();
    }

    private const string DeleteEmpty = "<path d=\"M20.37,8.91L19.37,10.64L7.24,3.64L8.24,1.91L11.28,3.66L12.64,3.29L16.97,5.79L17.34,7.16L20.37,8.91M6,19V7H11.07L18,11V19A2,2 0 0,1 16,21H8A2,2 0 0,1 6,19Z\"/>";
}