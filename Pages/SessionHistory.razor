@page "/sessions"
@using MahjongApp.Models
@inject MahjongApp.Services.DatabaseService DatabaseService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<style>
    .session-table {
        width: 100% !important;
    }

    /* 親テーブルは横スクロールさせず、画面幅に収める */
    .session-table .mud-table-container {
        overflow-x: hidden !important;
        width: 100% !important;
    }

    /* 子テーブル（詳細領域）の横スクロール設定 */
    .child-table-wrapper {
        overflow-x: auto !important;
        width: 0;
        min-width: 100% !important;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 4px;

        /* 独自チップ風デザイン（PresetDialogから流用） */
        .rule-badge {
            display: inline-flex;
            align-items: center;
            padding: 1px 6px;
            background-color: var(--mud-palette-background-grey);
            border-radius: 4px;
            font-size: 0.7rem;
            color: var(--mud-palette-text-secondary);
            white-space: nowrap;
        }
    }

    /* --- ページネーションの配置・間隔調整 --- */

    /* 1. 外枠と内部ツールバーの両方の高さを強制的に上書き */
    .session-table .mud-table-pagination,
    .session-table .mud-table-pagination .mud-toolbar {
        min-height: 36px !important;
        height: 36px !important;
    }

    /* 2. 内部ツールバーを「両端揃え」にし、左右の端からの距離をとる */
    .session-table .mud-table-pagination .mud-toolbar {
        justify-content: space-between !important;
        padding: 0 32px !important; /* ← 端の余白 */
    }

    /* 3. 見えないスペーサーを無効化（テキストを左側に持っていくため） */
    .session-table .mud-table-pagination-spacer {
        display: none !important;
    }

    /* 4. テキストの不要なマージンをリセット */
    .session-table .mud-table-pagination-information {
        margin-right: 0 !important;
    }

    /* 5. ボタン群のラップ要素の余白を消す */
    .session-table .mud-table-pagination-actions {
        margin-left: 0 !important;
    }

    /* 6. ボタン同士の間隔とクリック範囲の調整 */
    .session-table .mud-table-pagination-actions .mud-icon-button {
        padding: 4px !important;  
        margin: 0 8px !important; 
    }
</style>
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-10" @onclick="ClearArmedState">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        対局履歴
    </MudText>
    @if (isLoading)
    {
        <div class="d-flex justify-center py-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (sessionGroups.Count == 0)
    {
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">記録された対局はありません。</MudText>
    }
    else
    {
        <MudTable Items="@sessionGroups" RowsPerPage="100" Class="session-table" Hover="true" Dense="true" Elevation="1" Breakpoint="Breakpoint.None">
            @* ページネーション *@
            <PagerContent>
                <MudTablePager HideRowsPerPage="true" />
            </PagerContent>
            <RowTemplate Context="group">
                <MudTd Style="@($"cursor: pointer; padding: 10px 12px {(group.ShowDetails ? "0px" : "10px")} 12px; border-bottom: {(group.ShowDetails ? "none" : "1px solid var(--mud-palette-divider)")}; transition: padding-bottom 0.2s ease;")"
                       @onclick="@(() => { group.ShowDetails = !group.ShowDetails; group.HasBeenOpened = true; })">
                    <div class="d-flex align-start w-100">
                        @* 1. 左側のアイコン領域（幅を固定してインデントの軸を作る） *@
                        <div style="width: 32px; flex-shrink: 0; display: flex; justify-content: flex-start; margin-top: 1px;">
                            <MudIcon Icon="@(group.ShowDetails ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Style="color: #888;" />
                        </div>
                        @* 2. 右側のテキスト領域（タイトルと対局者名） *@
                        <div class="flex-grow-1 d-flex flex-column" style="min-width: 0;">
                            @* 日付とバッジの行 *@
                            <div class="d-flex align-center justify-space-between w-100" style="margin-bottom: 4px;">
                                <span style="font-size: 0.95rem; font-weight: bold; letter-spacing: 0.5px;">
                                    @group.Session.Date.ToString("yyyy/MM/dd HH:mm")
                                </span>
                                <div class="d-flex align-center" style="gap: 8px;">
                                    <span style="font-size: 0.8rem; color: #9e9e9e; background-color: rgba(255,255,255,0.05); padding: 2px 8px; border-radius: 4px; font-weight: bold;">
                                        @group.Games.Count 局
                                    </span>
                                    <span @onclick="() => { }" @onclick:stopPropagation="true">
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="@(ArmedDeleteTarget == group ? Color.Error : Color.Default)" StartIcon="@(ArmedDeleteTarget == group ? DeleteEmpty : Icons.Material.Filled.Delete)" Style="@(ArmedDeleteTarget == group ? "font-weight: bold; min-width: 32px; padding: 4px;" : "color: #9e9e9e; min-width: 32px; padding: 4px;")" OnClick="@(() => HandleDeleteClick(group))"></MudButton>
                                    </span>
                                </div>
                            </div>
                            @* 対局者名の行（改行を自然に） *@
                            <div style="font-size: 0.85rem; color: #aaaaaa; line-height: 1.5; overflow-wrap: break-word; word-break: normal;">
                                @GetPlayerNames(group.Session.ParticipantPlayerIds)
                            </div>
                        </div>
                    </div>
                </MudTd>
            </RowTemplate>
            <ChildRowContent Context="group">
                <MudTr>
                    <td colspan="1" style="padding: 0; border: none;">
                        <MudCollapse Expanded="group.ShowDetails">
                            @if (group.HasBeenOpened)
                            {
                                <div class="px-4 pb-4 pt-1" style="border-bottom: 1px solid var(--mud-palette-divider);">
                                    <MudCard Elevation="0" Style="background-color: var(--mud-palette-background-grey); border: 1px solid var(--mud-palette-divider);">
                                        <MudCardContent Class="py-4">
                                            @if (group.Games.Count > 0)
                                            {
                                                <div class="child-table-wrapper mb-4">
                                                    <ResultTable History="@group.CachedResults" Players="@group.CachedPlayerNames" ActiveParticipantCount="@group.Session.ParticipantPlayerIds.Count" Rules="@(group.Session.Rules ?? new RuleSet())" SessionChips="@(group.Session.SettledChips ?? new List<int>())" IsReadOnly="true" />
                                                </div>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Class="mb-4">対局記録がありません。</MudText>
                                            }
                                            @if (group.Session.Rules != null)
                                            {
                                                <MudText Typo="Typo.subtitle2" Class="d-flex align-center mt-2 mb-2" Color="Color.Primary">
                                                    <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Small" Class="mr-1" />
                                                    @($"{group.Session.Rules.Name}")
                                                </MudText>
                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                    <span class="rule-badge">@(group.Session.Rules.PlayerCount == 3 ? "三人麻雀" : "四人麻雀")</span>
                                                    <span class="rule-badge">@($"{group.Session.Rules.StartingPoints} / {group.Session.Rules.ReturnPoints}")</span>
                                                    <span class="rule-badge">ウマ @group.Session.Rules.GetUmaDisplayText()</span>
                                                    <span class="rule-badge">レート @(group.Session.Rules.Rate)</span>
                                                    @if (group.Session.Rules.ChipRate > 0)
                                                    {
                                                        <span class="rule-badge">チップ @(group.Session.Rules.ChipRate)</span>
                                                    }
                                                </div>
                                                <ShareButtonGroup Rules="group.Session.Rules" TablePlayers="group.CachedPlayerNames" ActiveHistory="group.CachedResults" ActiveSessionChips="group.CachedChipsDict" />
                                            }
                                            else if (group.Session.SettledChips != null && group.Session.SettledChips.Count > 0 && group.Session.SettledChips.Any(c => c != 0))
                                            {
                                                <MudText Typo="Typo.subtitle2" Class="mt-2 mb-2" Color="Color.Primary">💰 チップ精算 (レート: @group.Session.ChipRate 円)</MudText>
                                                <div class="d-flex flex-wrap gap-2">
                                                    @for (int i = 0; i < group.Session.ParticipantPlayerIds.Count; i++)
                                                    {
                                                        var pId = group.Session.ParticipantPlayerIds[i];
                                                        if (string.IsNullOrEmpty(pId)) continue;
                                                        var pName = GetPlayerName(pId);
                                                        var chips = group.Session.SettledChips.Count > i ? group.Session.SettledChips[i] : 0;
                                                        var chipYen = chips * group.Session.ChipRate;
                                                        var color = chips >= 0 ? "#ff6b6b" : "#4dabf7";
                                                        var sign = chips > 0 ? "+" : "";
                                                        if (chips != 0)
                                                        {
                                                            <span style="font-size: 0.85rem; padding: 2px 6px; background-color: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 4px;">
                                                                @pName: <span style="color: @color; font-weight: bold;">@sign@chips 枚 (@sign@chipYen.ToString("N0")円)</span>
                                                            </span>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </div>
                            }
                        </MudCollapse>
                    </td>
                </MudTr>
            </ChildRowContent>
        </MudTable>
    }
</MudContainer>

@code {
    private bool isLoading = true;
    private List<SessionGroup> sessionGroups = new();
    private List<PlayerProfile> allPlayers = new();
    private Dictionary<string, string> playerMap = new();
    private SessionGroup? ArmedDeleteTarget { get; set; }

    public class SessionGroup
    {
        public SavedSessionRecord Session { get; set; } = new();
        public List<SavedGameRecord> Games { get; set; } = new();
        public bool ShowDetails { get; set; }
        public bool HasBeenOpened { get; set; }
        public List<GameResult> CachedResults { get; set; } = new();
        public List<string> CachedPlayerNames { get; set; } = new();
        public Dictionary<string, int> CachedChipsDict { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        var dbData = await DatabaseService.GetAllDataAsync();
        if (dbData != null)
        {
            var safePlayers = dbData.Players ?? new List<PlayerProfile>();
            var safeSessions = dbData.Sessions ?? new List<SavedSessionRecord>();
            var safeGames = dbData.Games ?? new List<SavedGameRecord>();
            allPlayers = safePlayers.Where(p => p != null).ToList();
            playerMap = allPlayers.ToDictionary(p => p.Id, p => p.Name);

            sessionGroups = safeSessions
                            .Where(s => s != null)
                            .OrderByDescending(s => s.Date)
                            .Select(s =>
                            {
                                var group = new SessionGroup
                                {
                                    Session = AggregateSessionDuplicates(s),
                                    Games = safeGames.Where(g => g != null && g.SessionId == s.SessionId).OrderBy(g => g.Timestamp).ToList(),
                                    ShowDetails = false,
                                    HasBeenOpened = false
                                };
                                group.CachedResults = ConvertToGameResults(group.Games);
                                group.CachedPlayerNames = GetSessionPlayerNames(group);
                                var chipsDict = new Dictionary<string, int>();
                                var safeChips = group.Session.SettledChips ?? new List<int>();
                                for (int i = 0; i < group.Session.ParticipantPlayerIds.Count; i++)
                                {
                                    var pId = group.Session.ParticipantPlayerIds[i];
                                    if (!string.IsNullOrEmpty(pId))
                                    {
                                        var pName = GetPlayerName(pId);
                                        chipsDict[pName] = safeChips.Count > i ? safeChips[i] : 0;
                                    }
                                }
                                group.CachedChipsDict = chipsDict;
                                return group;
                            })
                            .ToList();
        }
        isLoading = false;
        StateHasChanged();
    }

    // セッション内の重複した参加枠を1つにまとめる
    private SavedSessionRecord AggregateSessionDuplicates(SavedSessionRecord session)
    {
        var distinctIds = new List<string>();
        var distinctChips = new List<int>();
        var pIds = session.ParticipantPlayerIds ?? new List<string>();
        var sChips = session.SettledChips ?? new List<int>();
        for (int i = 0; i < pIds.Count; i++)
        {
            var id = pIds[i];
            var chip = sChips.Count > i ? sChips[i] : 0;
            int existingIdx = id == null ? -1 : distinctIds.IndexOf(id);
            if (existingIdx != -1)
            {
                distinctChips[existingIdx] += chip;
            }
            else
            {
                distinctIds.Add(id ?? "");
                distinctChips.Add(chip);
            }
        }
        session.ParticipantPlayerIds = distinctIds;
        session.SettledChips = distinctChips;
        return session;
    }

    // ごみ箱ボタンのクリックハンドラー
    private async Task HandleDeleteClick(SessionGroup group)
    {
        if (ArmedDeleteTarget != group)
        {
            ArmedDeleteTarget = group;
            return;
        }
        await ConfirmDeleteSession(group);
    }

    // 別の場所をクリックしたときに警告（Armed）状態を解除する
    private void ClearArmedState()
    {
        if (ArmedDeleteTarget != null)
        {
            ArmedDeleteTarget = null;
        }
    }

    private string GetPlayerName(string id)
    {
        if (id == "deleted") return "削除済み";
        return playerMap.TryGetValue(id, out var name) ? name : "不明";
    }

    private string GetPlayerNames(List<string> ids)
    {
        var names = ids.Where(id => !string.IsNullOrEmpty(id)).Select(GetPlayerName);
        return string.Join(", ", names);
    }

    private async Task ConfirmDeleteSession(SessionGroup group)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "対局の削除",
            (MarkupString)$"対局（{group.Session.Date.ToString("yyyy/MM/dd HH:mm")}）データを削除します。<br />よろしいですか？",
            yesText: "削除する",
            cancelText: "キャンセル"
        );

        if (result == true)
        {
            await DatabaseService.DeleteSessionAsync(group.Session.SessionId);
            Snackbar.Add("対局記録を削除しました", Severity.Success);
            await LoadData();
        }
        else
        {
            ArmedDeleteTarget = null;
        }
    }

    // データベース用の型(SavedGameRecord)を、UI表示用の型(GameResult)に変換する
    private List<GameResult> ConvertToGameResults(List<SavedGameRecord> savedGames)
    {
        var results = new List<GameResult>();
        foreach (var g in savedGames)
        {
            var pNames = new List<string>();
            var rScores = new List<int?>();
            var pts = new List<double>();
            var yen = new List<int>();
            var sPts = new List<double>();
            var yPts = new List<double>();
            var tPts = new List<double>();
            var cPts = new List<double>();
            var playerIdsSource = g.PlayerIds ?? new List<string?>();
            var rawSource = g.RawScores ?? new List<int?>();
            var ptsSource = g.Points ?? new List<double>();
            var yenSource = g.Yen ?? new List<int>();
            var sPtsSource = g.SinkPoints ?? new List<double>();
            var yPtsSource = g.YakiPoints ?? new List<double>();
            var tPtsSource = g.TobiPoints ?? new List<double>();
            var cPtsSource = g.ColdPoints ?? new List<double>();
            for (int i = 0; i < playerIdsSource.Count; i++)
            {
                string id = playerIdsSource[i] ?? "";
                string name = string.IsNullOrEmpty(id) ? "" : GetPlayerName(id);
                int existingIdx = pNames.IndexOf(name);
                int? currentRaw = rawSource.Count > i ? rawSource[i] : null;
                if (existingIdx != -1 && !string.IsNullOrEmpty(name))
                {
                    // 重複枠の場合: 先に見つけた枠が「抜け番(null)」で、今回が「有効な点数」なら上書きする
                    if (!rScores[existingIdx].HasValue && currentRaw.HasValue)
                    {
                        rScores[existingIdx] = currentRaw;
                        if (ptsSource.Count > i) pts[existingIdx] = ptsSource[i];
                        if (yenSource.Count > i) yen[existingIdx] = yenSource[i];
                        if (sPtsSource.Count > i) sPts[existingIdx] = sPtsSource[i];
                        if (yPtsSource.Count > i) yPts[existingIdx] = yPtsSource[i];
                        if (tPtsSource.Count > i) tPts[existingIdx] = tPtsSource[i];
                        if (cPtsSource.Count > i) cPts[existingIdx] = cPtsSource[i];
                    }
                }
                else
                {
                    // 新規枠として追加する
                    pNames.Add(name ?? "");
                    rScores.Add(currentRaw);
                    pts.Add(ptsSource.Count > i ? ptsSource[i] : 0);
                    yen.Add(yenSource.Count > i ? yenSource[i] : 0);
                    sPts.Add(sPtsSource.Count > i ? sPtsSource[i] : 0);
                    yPts.Add(yPtsSource.Count > i ? yPtsSource[i] : 0);
                    tPts.Add(tPtsSource.Count > i ? tPtsSource[i] : 0);
                    cPts.Add(cPtsSource.Count > i ? cPtsSource[i] : 0);
                }
            }
            results.Add(new GameResult
            {
                Timestamp = g.Timestamp,
                PlayerNames = pNames,
                RawScores = rScores,
                Points = pts,
                Yen = yen,
                SinkPoints = sPts,
                YakiPoints = yPts,
                TobiPoints = tPts,
                ColdPoints = cPts
            });
        }
        return results;
    }

    // ResultTableのヘッダーに表示するための「名前のリスト」を生成する
    private List<string> GetSessionPlayerNames(SessionGroup group)
    {
        return group.Session.ParticipantPlayerIds
            .Select(id => GetPlayerName(id))
            .ToList();
    }

    private const string DeleteEmpty = "<path d=\"M20.37,8.91L19.37,10.64L7.24,3.64L8.24,1.91L11.28,3.66L12.64,3.29L16.97,5.79L17.34,7.16L20.37,8.91M6,19V7H11.07L18,11V19A2,2 0 0,1 16,21H8A2,2 0 0,1 6,19Z\"/>";
}