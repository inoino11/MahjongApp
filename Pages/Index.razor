@page "/"
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

@* 素点入力欄のスタイル *@
<style>
    .score-input input {
        text-align: right !important;
        font-size: 1.3rem !important;
        font-weight: 500 !important;
        padding-right: 2px !important;
    }

    .score-zeros {
        font-size: 1.3rem;
        font-weight: 500;
        color: #808080;
        margin-left: 2px;
        user-select: none;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-10" @onclick="CancelDelete">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        麻雀集計ツール
    </MudText>

    @* --- セクション1: 設定 (折りたたみ可) --- *@
    <MudExpansionPanels Class="mb-6" @onclick:stopPropagation="true">
        <MudExpansionPanel Text="ルール・対局者設定" @bind-Expanded="isSettingsExpanded">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mb-4" StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenPresetDialog">
                保存済みの設定を呼び出し
            </MudButton>
            <MudGrid>
                <MudItem xs="12" md="8" Class="d-flex">
                    <MudCard Outlined="true" Class="flex-grow-1">
                        <MudCardHeader Class="pb-0">
                            <CardHeaderContent>
                                <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:bold; white-space: nowrap;">ルール設定</MudText>
                                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Settings" OnClick="OpenCustomRuleDialog">
                                            カスタム<span class="d-none d-sm-inline">ルール</span>
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="SavePreset">
                                            <span class="d-none d-sm-inline">現在の</span>設定保存
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="pa-3 pt-1 mt-2">
                            <MudGrid Spacing="1">
                                <MudItem xs="6" sm="4" Class="pr-3">
                                    <MudSelect T="int" Label="対局人数" Value="rules.PlayerCount" ValueChanged="OnPlayerCountChanged" Margin="Margin.Dense">
                                        <MudSelectItem Value="@(4)">四人麻雀</MudSelectItem>
                                        <MudSelectItem Value="@(3)">三人麻雀</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="6" sm="8" Class="pr-3">
                                    <MudTextField Label="ルール名" @bind-Value="rules.Name" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="4" Class="pr-3">
                                    <MudNumericField T="int" Label="持ち点" Value="rules.StartingPoints" ValueChanged="OnStartingPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="4" Class="pr-3">
                                    <MudNumericField T="int" Label="返し点" Value="rules.ReturnPoints" ValueChanged="OnReturnPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="4" Class="pr-3">
                                    <MudNumericField Label="レート(円/1k)" @bind-Value="rules.Rate" Step="10" Min="0" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="4" Class="pr-3">
                                    <MudNumericField Label="チップ(円/枚)" @bind-Value="rules.ChipRate" Step="50" Min="0" Margin="Margin.Dense" />
                                </MudItem>
                                @if (rules.IsCustomUma)
                                {
                                    <MudItem xs="12" sm="8">
                                        <MudTextField Label="カスタム順位ウマ" Value="@rules.GetUmaDisplayText(true)" ReadOnly="true" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Close" OnAdornmentClick="DisableCustomUma" Style="font-variant-numeric: tabular-nums;" />
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudNumericField Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←2)" : "順位ウマ(2←3)")" @bind-Value="rules.Uma1" Step="5" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudNumericField Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←3)" : "順位ウマ(1←4)")" @bind-Value="rules.Uma2" Step="5" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex">
                    <MudCard Outlined="true" Class="flex-grow-1">
                        <MudCardHeader Class="pb-0">
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:bold;">対局者名</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="pa-3 pt-1">
                            <MudStack Spacing="0">
                                @for (int i = 0; i < activeParticipantCount; i++)
                                {
                                    var index = i;
                                    <MudTextField Placeholder="@($"対局者 {index + 1}")" Value="currentPlayers[index]" ValueChanged="@((string v) => OnPlayerNameChanged(index, v))" Margin="Margin.Dense" />
                                }
                            </MudStack>
                            @* 抜け番（参加枠）の追加・削除ボタン *@
                            <MudStack Row="true" Justify="Justify.Center" Class="mt-2" Spacing="1">
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddParticipant" Disabled="@(activeParticipantCount >= MaxParticipants)">
                                    枠を追加
                                </MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonRemove" OnClick="RemoveParticipant" Disabled="@(activeParticipantCount <= rules.PlayerCount)">
                                    枠を削除
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* --- セクション2: 素点入力 --- *@
    <MudPaper Class="pa-4 mb-6" Elevation="2" @onclick:stopPropagation="true">
        <MudStack Row="true" AlignItems="AlignItems.Baseline" Class="mb-2">
            <MudText Typo="Typo.h6">素点入力</MudText>
        </MudStack>
        <MudGrid Spacing="1" AlignItems="AlignItems.Center">
            @for (int i = 0; i < activeParticipantCount; i++)
            {
                var index = i;
                bool isSitOut = currentSitOuts[index];
                <MudItem xs="12" sm="6" Class="pa-2">
                    @* 抜け番の時は透明度を下げる *@
                    <MudPaper Outlined="true" Elevation="0" Class="d-flex align-center px-3 py-1" Style="@($"background-color: rgba(255,255,255,0.02); transition: opacity 0.3s; {(isSitOut ? "opacity: 0.4;" : "")}")">
                        <MudText Typo="Typo.body1" Style="font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 40%;">
                            @(string.IsNullOrWhiteSpace(currentPlayers[index]) ? " " : currentPlayers[index])
                        </MudText>
                        <MudSpacer />
                        <div class="d-flex align-center">
                            @* 抜け番 *@
                            @if (activeParticipantCount > rules.PlayerCount)
                            {
                                <MudToggleIconButton Toggled="currentSitOuts[index]" ToggledChanged="@((bool v) => OnSitOutChanged(index, v))" Icon="@Icons.Material.Filled.Person" Color="Color.Default" Title="参加中" ToggledIcon="@Icons.Material.Filled.LocalCafe" ToggledColor="Color.Default" ToggledTitle="☕ 抜け番" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" />
                            }
                            @* 焼き鳥 *@
                            @if (rules.IsYakiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentYaki[index]" Icon="@Icons.Material.Filled.NoMeals" Color="Color.Default" Title="焼き鳥ではありません" ToggledIcon="@YakiIcon" ToggledColor="Color.Warning" ToggledTitle="🍗 焼き鳥です" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                            @* トビ *@
                            @if (rules.IsTobiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentTobiBonus[index]" Icon="@Icons.Material.Filled.Rocket" Color="Color.Default" Title="トビ賞を獲得しません" ToggledIcon="@Icons.Material.Filled.RocketLaunch" ToggledColor="Color.Error" ToggledTitle="🚀 トビ賞を獲得します" Size="Size.Small" ToggledSize="Size.Small" Class="mr-2" Disabled="isSitOut" />
                            }
                            @* 素点 *@
                            <div class="d-flex align-baseline">
                                <MudNumericField T="int?" Value="currentScores[index]" ValueChanged="@(v => HandleScoreInputWithAutoFill(index, v))" HideSpinButtons="true" DisableUnderLine="true" Margin="Margin.Dense" Class="score-input" Style="width: 70px;" Disabled="isSitOut" />
                                <span class="score-zeros">00</span>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Class="mt-4 py-3" Disabled="@(!IsTotalCorrect)" OnClick="CalculateAndRecordGame">結果を記録する</MudButton>
    </MudPaper>

    @* --- セクション3: 集計結果 --- *@
    <MudPaper Class="pa-2 px-sm-4" Elevation="2" @onclick="CancelDelete">
        <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 gap-2">
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudButton Variant="@(displayMode == 0 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => displayMode = 0">素点</MudButton>
                <MudButton Variant="@(displayMode == 1 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => displayMode = 1">+/−</MudButton>
                <MudButton Variant="@(displayMode == 2 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => displayMode = 2">円</MudButton>
            </MudStack>
            @if (rules.IsSinkEnabled || rules.IsYakiEnabled || rules.IsTobiEnabled || rules.IsColdEnabled)
            {
                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    @if (rules.IsSinkEnabled)
                    {
                        <MudButton Variant="@(displayMode == 3 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Warning" Size="Size.Small" OnClick="() => displayMode = 3">沈み</MudButton>
                    }
                    @if (rules.IsYakiEnabled)
                    {
                        <MudButton Variant="@(displayMode == 4 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Warning" Size="Size.Small" OnClick="() => displayMode = 4">焼き鳥</MudButton>
                    }
                    @if (rules.IsTobiEnabled)
                    {
                        <MudButton Variant="@(displayMode == 5 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Info" Size="Size.Small" OnClick="() => displayMode = 5">トビ</MudButton>
                    }
                    @if (rules.IsColdEnabled)
                    {
                        <MudButton Variant="@(displayMode == 6 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Info" Size="Size.Small" OnClick="() => displayMode = 6">コールド</MudButton>
                    }
                </MudStack>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="ConfirmReset">記録リセット</MudButton>
        </MudStack>
        <MudCard Class="mb-4" Elevation="0" Outlined="true">
            <MudCardContent Class="pa-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">チップ集計</MudText>
                <div style="display: flex; width: 100%; flex-wrap: nowrap; align-items: center; gap: 8px; overflow-x: auto; padding-bottom: 4px;">
                    @{
                        bool isChipError = ActiveSessionChips.Take(activeParticipantCount).Sum() != 0;
                    }
                    <div style="width: 25px; flex-shrink: 0;"></div>
                    @for (int i = 0; i < activeParticipantCount; i++)
                    {
                        var idx = i;
                        <div style="flex: 1; min-width: 4.5rem;">
                            <MudNumericField T="int" Label="@(string.IsNullOrWhiteSpace(currentPlayers[idx]) ? " " : currentPlayers[idx])" Value="ActiveSessionChips[idx]" ValueChanged="@(v => OnChipChanged(idx, v))" Step="1" HideSpinButtons="true" Margin="Margin.Dense" Style="@(isChipError ? "max-width: 4.0rem; color:#ff0000; font-weight:bold;" : "max-width: 4.5rem;")" />
                        </div>
                    }
                    <div style="width: 25px; flex-shrink: 0;"></div>
                </div>
            </MudCardContent>
        </MudCard>

        @* overflow-x: auto に変更 *@
        <div style="width: 100%; overflow-x: auto;">
            <MudTable Items="@ActiveHistory" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None" Style="width: 100%; table-layout: fixed;">
                <ColGroup>
                    <col style="width: 30px;" />
                    @for (int i = 0; i < activeParticipantCount; i++)
                    {
                        <col style="width: 60px;" />
                    }
                    <col style="width: 30px;" />
                </ColGroup>
                <HeaderContent>
                    <MudTh Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.65rem; letter-spacing: -0.5px;">時刻</MudTh>
                    @for (int i = 0; i < activeParticipantCount; i++)
                    {
                        var idx = i;
                        <MudTh Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.75rem; letter-spacing: -0.5px;">
                            @(string.IsNullOrWhiteSpace(currentPlayers[idx]) ? " " : currentPlayers[idx])
                        </MudTh>
                    }
                    <MudTh Style="padding: 4px 0px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.6rem; color: #666; letter-spacing: -0.5px;">
                        @context.Timestamp.ToString("HH:mm")
                    </MudTd>
                    @for (int i = 0; i < activeParticipantCount; i++)
                    {
                        var idx = i;
                        <MudTd Style="text-align: center; padding: 4px 0px; white-space: nowrap;">
                            <span style="@GetTdStyle(context, idx)">
                                @GetDisplayValue(context, idx)
                            </span>
                        </MudTd>
                    }
                    <MudTd Style="text-align: center; white-space: nowrap; padding: 4px 0px;">
                        <span @onclick="() => { }" @onclick:stopPropagation="true">
                            <MudIconButton Icon="@(armedDeleteTarget == context ? @DeleteEmpty : Icons.Material.Filled.Delete)" Color="@(armedDeleteTarget == context ? Color.Error : Color.Default)" Size="Size.Small" Style="@(armedDeleteTarget == context ? "padding: 0px;" : "padding: 0px; color: #9e9e9e;")" OnClick="() => HandleDeleteRequest(context)" />
                        </span>
                    </MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTd Style="text-align: center; background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; font-weight: bold; white-space: nowrap; padding: 6px 0px; font-size: 0.75rem;">
                        <MudIcon Icon="@(displayMode == 0 ? Icons.Material.Filled.Calculate : Icons.Material.Filled.Functions)" Style="font-size: 1rem; vertical-align: text-bottom; margin-right: 2px; color: #2e7d32;" />
                        @(displayMode == 0 ? "平均" : "合計")
                    </MudTd>
                    @for (int i = 0; i < activeParticipantCount; i++)
                    {
                        var idx = i;
                        <MudTd Style="@($"{GetTotalTdStyle(idx)} text-align: center; padding: 6px 0px; white-space: nowrap;")">
                            <span style="@GetTotalSpanStyle(idx)">
                                @GetTotalDisplayValue(idx)
                            </span>
                        </MudTd>
                    }
                    <MudTd Style="background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; padding: 6px 0px;"></MudTd>
                </FooterContent>
            </MudTable>

            @* 共有ボタン *@
            <div class="d-flex justify-end mt-4 gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Share" OnClick="ShareImageAsync" Disabled="isSharing" Style="white-space: nowrap;">
                    @(isSharing ? "画像を作成中..." : "結果を画像でシェア")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Link" OnClick="CopyShareUrlAsync" Style="white-space: nowrap;">
                    閲覧用URLをシェア
                </MudButton>
            </div>
        </div>
    </MudPaper>

    @* --- セクションX: シェア用の裏DOM（画面外に隠す） --- *@
    <div style="position: absolute; left: -9999px; top: 0;">
        <div id="share-target" style="width: @(800 + Math.Max(0, activeParticipantCount - 4) * 150)px; padding: 40px; background-color: #1a1a27; color: white; border-radius: 12px; font-family: 'Kaisei Decol', sans-serif;">
            <h2 style="text-align: center; margin-bottom: 20px; font-weight: bold; border-bottom: 2px solid #444; padding-bottom: 10px;">
                🀄 対局結果
            </h2>
            @* ルール・レート情報の表示 *@
            <div style="display: flex; flex-wrap: wrap; gap: 15px; margin-bottom: 20px; background-color: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; font-size: 0.95rem;">
                <div><strong>ルール名:</strong> @(string.IsNullOrWhiteSpace(rules.Name) ? "未設定" : rules.Name)</div>
                <div><strong>形式:</strong> @(rules.PlayerCount)人麻雀</div>
                <div><strong>設定:</strong> @(rules.StartingPoints)持ち / @(rules.ReturnPoints)返し</div>
                <div><strong>ウマ:</strong> @(rules.IsCustomUma? rules.GetUmaDisplayText(true) : $"{rules.Uma1} - {rules.Uma2}")</div>
                <div><strong>レート:</strong> @(rules.Rate)円/1k</div>
                @if (rules.ChipRate > 0)
                {
                    <div><strong>チップ:</strong> @(rules.ChipRate)円/枚</div>
                }
            </div>
            @* 成績テーブル *@
            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; text-align: center; font-variant-numeric: tabular-nums;">
                <thead>
                    <tr style="background-color: rgba(255,255,255,0.1); border-bottom: 2px solid #555;">
                        <th style="padding: 12px; width: 80px; font-size: 0.9rem;">局</th>
                        @for (int i = 0; i < activeParticipantCount; i++)
                        {
                            <th style="padding: 12px; font-size: 1.1rem;">@(string.IsNullOrWhiteSpace(currentPlayers[i]) ? " " : currentPlayers[i])</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @* 各局のポイント (+/-) 固定表示 *@
                    @for (int row = 0; row < ActiveHistory.Count; row++)
                    {
                        var game = ActiveHistory[row];
                        <tr style="border-bottom: 1px solid #333;">
                            <td style="padding: 10px; color: #aaa; font-size: 0.85rem; white-space: nowrap;">@(row + 1)局目</td>
                            @for (int i = 0; i < activeParticipantCount; i++)
                            {
                                @* 各局のフォントサイズ: 1.1rem *@
                                <td style="padding: 10px; font-size: 1.1rem; white-space: nowrap;">
                                    <span style="@GetSharePointStyle(game, i)">@GetSharePointValue(game, i)</span>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    @* ポイント合計行 *@
                    <tr style="background-color: rgba(46, 125, 50, 0.1); border-bottom: 2px solid #555;">
                        <td style="padding: 15px 10px; font-size: 0.9rem; color: #81c784; font-weight: bold; white-space: nowrap;">
                            Pt 合計
                        </td>
                        @for (int i = 0; i < activeParticipantCount; i++)
                        {
                            @* Pt合計のフォントサイズ: 1.2rem *@
                            <td style="padding: 15px 10px; font-size: 1.2rem; white-space: nowrap;">
                                <span style="@GetShareTotalPointStyle(i)">@GetShareTotalPointValue(i)</span>
                            </td>
                        }
                    </tr>
                    @* チップ行 (チップあり設定の場合のみ表示) *@
                    @if (rules.ChipRate > 0)
                    {
                        <tr style="background-color: rgba(46, 125, 50, 0.1); border-bottom: 2px solid #555;">
                            <td style="padding: 15px 10px; color: #ddd; font-size: 0.9rem; font-weight: bold; white-space: nowrap;">チップ</td>
                            @for (int i = 0; i < activeParticipantCount; i++)
                            {
                                int chip = ActiveSessionChips[i];
                                @* チップのフォントサイズ: 1.2rem (Pt合計と同等) *@
                                <td style="padding: 15px 10px; font-size: 1.2rem; white-space: nowrap;">
                                    <span style="display: inline-block; width: 4.5rem; text-align: right; @(chip > 0 ? "color: #ff6b6b;" : (chip < 0 ? "color: #4dabf7;" : "color: #9e9e9e;"))">
                                        @(chip > 0 ? $"+{chip}" : chip.ToString())枚
                                    </span>
                                </td>
                            }
                        </tr>
                    }
                    @* 円合計行 *@
                    <tr style="background-color: rgba(156, 39, 176, 0.1); font-weight: bold;">
                        <td style="padding: 15px 10px; font-size: 0.9rem; color: #ce93d8; white-space: nowrap;">
                            円 合計
                        </td>
                        @for (int i = 0; i < activeParticipantCount; i++)
                        {
                            @* 円合計のフォントサイズ: 1.4rem *@
                            <td style="padding: 15px 10px; font-size: 1.4rem; white-space: nowrap;">
                                <span style="@GetShareTotalYenStyle(i)">@GetShareTotalYenValue(i)</span>
                            </td>
                        }
                    </tr>
                </tfoot>
            </table>
            @* フッター情報 *@
            <div style="display: flex; justify-content: flex-end; font-size: 0.9rem; color: #888;">
                <span>@DateTime.Now.ToString("yyyy/MM/dd HH:mm") - 麻雀集計ツール</span>
            </div>
        </div>
    </div>
</MudContainer>

@code {
    private RuleSet rules = new();
    private List<RuleSet> rulePresets = new();
    private const int MaxParticipants = 7;
    private int activeParticipantCount = 4;
    private List<string> currentPlayers = new() { "Aさん", "Bさん", "Cさん", "Dさん", "Eさん", "Fさん", "Gさん" };
    private List<int?> currentScores = new() { null, null, null, null };
