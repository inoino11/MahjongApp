@page "/"
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject MahjongApp.Services.DatabaseService DatabaseService
@inject MahjongApp.Services.StatsCacheService StatsCache
@inject IJSRuntime JS

@* 素点入力欄のスタイル *@
<style>
    /* 名前入力欄 */
    .player-name-input input {
        text-align: center !important;
        letter-spacing: 1px;
    }

    /* フォーカスされていない時は下線を極限まで薄くする */
    .player-name-input:not(:focus-within) {
        opacity: 0.85;
    }

    .score-input input {
        text-align: right !important;
        font-size: 1.3rem !important;
        font-weight: 500 !important;
        padding-right: 2px !important;
    }

    .score-input.auto-filled input {
        color: var(--mud-palette-info) !important;
    }

    .score-input.mud-input-control .mud-input-outlined {
        height: 28px !important;
        min-height: 28px !important;
    }

    .score-input.mud-input-control .mud-input-outlined .mud-input-adornment-start {
        margin: 0 !important;
    }

    .score-input.mud-input-control .mud-input-outlined .mud-input-adornment-start svg {
        font-size: 16px !important;
    }

    .score-zeros {
        font-size: 1.3rem;
        font-weight: 500;
        color: #808080;
        margin-left: 2px;
        user-select: none;
    }

    /* 自動入力アイコン追加時に文字が上に浮く現象を修正 */
    .score-input .mud-input {
        align-items: baseline !important;
    }

    /* アイコン自体は高さの中央を維持する */
    .score-input .mud-input-adornment-start {
        align-self: center !important;
        margin-top: 0 !important;
    }

    /* オリジナルテンキーの固定コンテナ */
    .custom-keypad-container {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background-color: #1a261a;
        /* 雀卓のカード背景に近いシックな黒緑 */
        border-top: 2px solid #2e7d32;
        z-index: 1000;
        transform: translateY(100%);
        transition: transform 0.2s ease-out;
        padding: 8px 12px 24px 12px;
        /* スマホの下部バーを考慮した余白 */
        box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.6);
        box-sizing: border-box;
    }

    /* テンキーが開いている時の状態 */
    .custom-keypad-container.open {
        transform: translateY(0);
    }

    .keypad-table {
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
        border-collapse: separate;
        border-spacing: 6px;
        table-layout: fixed;
    }

    .keypad-btn {
        width: 100%;
        height: 48px;
        font-size: 1.2rem;
        font-weight: bold;
        border-radius: 8px;
        background-color: rgba(255, 255, 255, 0.06);
        color: #e0e0e0;
        border: none;
        outline: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        touch-action: manipulation;
        white-space: nowrap;
    }

    .keypad-btn:active {
        background-color: rgba(255, 255, 255, 0.18);
    }

    /* 演算子ボタン（＋、ー、閉じる） */
    .keypad-btn.op-key {
        background-color: #2e7d32;
        color: white;
    }

    .keypad-btn.op-key:active {
        background-color: #1b5e20;
    }

    /* アクションボタン（⌫、C） */
    .keypad-btn.action-key {
        background-color: #b71c1c;
        color: white;
    }

    .keypad-btn.action-key:active {
        background-color: #7f0000;
    }

    /* スコア入力欄がテンキー選択中の時のハイライト */
    .score-input-active {
        border: 1px solid #81c784 !important;
        box-shadow: 0 0 6px rgba(129, 199, 132, 0.5);
        background-color: rgba(76, 175, 80, 0.05) !important;
    }

    /* アプローチ1: 他の枠を入力中、自動入力（補完）枠を仮状態として半透明・斜体にする */
    .score-input-auto-filling input {
        opacity: 0.4 !important;
        transition: opacity 0.15s ease;
    }

    /* アプローチ2: 点数がピッタリ合致した時に出現する「 記録」ボタンのスタイル */
    .keypad-btn.record-key {
        background-color: #ff9800 !important;
        /* 目立つアクセントオレンジ */
        color: white !important;
        font-weight: bold;
        animation: keypad-pulse-border 1.5s infinite;
    }

    .keypad-btn.record-key:active {
        background-color: #e65100 !important;
    }

    /* 記録ボタンをフワフワと発光させてアピールするアニメーション */
    @@keyframes keypad-pulse-border {
        0% {
            box-shadow: 0 0 0 0 rgba(255, 152, 0, 0.7);
        }

        70% {
            box-shadow: 0 0 0 6px rgba(255, 152, 0, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(255, 152, 0, 0);
        }
    }

    /* テンキーが開いている時だけ、画面の一番下にテンキー分の大きな余白を作る */
    .keypad-open-padding {
        padding-bottom: 320px !important;
    }

    /* ▽アイコンの幅に合わせて左側を押し込む */
    .balanced-center-select input {
        text-align: center !important;
        padding-left: 10px !important;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="@($"mt-4 pb-10 {(activeScoreInputIndex.HasValue ? "keypad-open-padding" : "")}")" @onclick="OnContainerClick" Style="min-height: 100vh;">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        素点集計
    </MudText>

    @* --- セクション1: 設定 (折りたたみ可) --- *@
    <MudExpansionPanels Class="mb-6">
        <MudExpansionPanel Text="ルール設定" Style="font-weight:bold; white-space: nowrap;" @bind-Expanded="isSettingsExpanded">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mb-4" StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenPresetDialog">
                保存済みの設定を呼び出し
            </MudButton>
            <MudCard Outlined="true" Class="w-100">
                <MudCardHeader Class="pb-0">
                    <CardHeaderContent>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Settings" OnClick="OpenCustomRuleDialog">
                                    カスタム<span class="d-none d-sm-inline">ルール</span>
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="SavePreset">
                                    <span class="d-none d-sm-inline">現在の</span>設定保存
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-2 pa-sm-3 pt-1 mt-2">
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="8">
                            <MudTextField Label="ルール名" @bind-Value="rules.Name" Margin="Margin.Dense" onfocus="this.select();" Class="px-2" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudSelect T="int" Label="対局人数" Value="rules.PlayerCount" ValueChanged="OnPlayerCountChanged" Margin="Margin.Dense" Class="px-2">
                                <MudSelectItem Value="@(4)">四人麻雀</MudSelectItem>
                                <MudSelectItem Value="@(3)">三人麻雀</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="int" Label="持ち点" Value="rules.StartingPoints" ValueChanged="OnStartingPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" Class="px-2" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="int" Label="返し点" Value="rules.ReturnPoints" ValueChanged="OnReturnPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" Class="px-2" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField Label="レート(円/1k)" @bind-Value="rules.Rate" Step="10" Min="0" Margin="Margin.Dense" Class="px-2" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField Label="チップ(円/枚)" @bind-Value="rules.ChipRate" Step="50" Min="0" Margin="Margin.Dense" Class="px-2" />
                        </MudItem>
                        @if (rules.IsCustomUma)
                        {
                            <MudItem xs="12" sm="8">
                                <MudTextField Label="カスタム順位ウマ" Value="@rules.GetUmaDisplayText(true)" ReadOnly="true" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Close" OnAdornmentClick="DisableCustomUma" Style="font-variant-numeric: tabular-nums;" Class="px-2" />
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="6" sm="4">
                                <MudNumericField T="int" Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←2)" : "順位ウマ(2←3)")" Value="rules.Uma1" ValueChanged="@((int v) => { rules.Uma1 = v; SyncNormalToCustomUma(); })" Step="5" Min="0" Margin="Margin.Dense" Class="px-2" />
                            </MudItem>
                            <MudItem xs="6" sm="4">
                                <MudNumericField T="int" Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←3)" : "順位ウマ(1←4)")" Value="rules.Uma2" ValueChanged="@((int v) => { rules.Uma2 = v; SyncNormalToCustomUma(); })" Step="5" Min="0" Margin="Margin.Dense" Class="px-2" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* --- セクション2: 対局者＆素点入力 --- *@
    <MudPaper id="score-input-section" Class="pa-2 pa-sm-4 mb-6" Elevation="2">
        <div class="mb-3 px-1">
            <MudText Style="font-weight: bold;" Class="mb-1">素点入力</MudText>

            @* ▼ デバッグ用：登録プレイヤー名簿のリアルタイム表示エリア ▼ *@
            @* <div style="background-color: rgba(255, 255, 0, 0.05); border: 1px dashed #ffc107; padding: 8px; border-radius: 4px; margin-bottom: 12px; font-size: 0.85rem;">
                <div style="color: #ffc107; font-weight: bold; margin-bottom: 4px;">🛠 デバッグ: 登録済みプレイヤー名簿</div>
                <div>現在のマスター件数: <strong>@playerMaster.Count</strong> 件</div>
                @if (playerMaster.Count == 0)
                {
                    <div style="color: #aaa; font-style: italic;">（登録されているプレイヤーはまだありません。一度セッションを保存すると登録されます）</div>
                }
                else
                {
                    <ul style="margin: 4px 0 0 0; padding-left: 20px; color: #e0e0e0;">
                        @foreach (var p in playerMaster)
                        {
                            <li>名前: <strong style="color: #4caf50;">@p.Name</strong> (ID: @p.Id, チップ累計: @p.CumulativeChips 枚)</li>
                        }
                    </ul>
                }
            </div> *@
            @* ▲ デバッグ用エリア ここまで ▲ *@

            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%; overflow: hidden;">
                <div class="d-flex align-center">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddParticipant" Disabled="@(activeParticipantCount >= MaxParticipants)" Style="min-width: 0; padding-left: 4px; padding-right: 4px;">
                        <span style="white-space: nowrap;">追加</span>
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonRemove" OnClick="RemoveParticipant" Disabled="@(activeParticipantCount <= rules.PlayerCount)" Style="min-width: 0; padding-left: 4px; padding-right: 4px;">
                        <span style="white-space: nowrap;">削除</span>
                    </MudButton>
                </div>
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.History" OnClick="CopyPreviousGame" Disabled="@(ActiveHistory.Count == 0)" Style="white-space: nowrap; flex-shrink: 0; padding-left: 4px; padding-right: 4px;">
                    前局をコピー
                </MudButton>
            </MudStack>
        </div>
        <MudGrid Spacing="1" AlignItems="AlignItems.Center">
            @for (int i = 0; i < activeParticipantCount; i++)
            {
                var index = i;
                bool isSitOut = currentSitOuts[index];
                <MudItem xs="12" sm="6">
                    <MudPaper Outlined="true" Elevation="0" Class="d-flex align-center justify-space-between px-2 py-1" Style="@($"background-color: rgba(255,255,255,0.02); transition: opacity 0.3s; {(isSitOut ? "opacity: 0.4;" : "")}")">
                        @* 左ブロック: 名前入力 *@
                        <MudAutocomplete T="string" Placeholder="@($"対局者 {index + 1}")" Value="currentPlayers[index].Name" ValueChanged="@((string v) => OnPlayerNameChanged(index, v))" SearchFunc="@SearchRegisteredPlayers" CoerceText="true" CoerceValue="true" MinCharacters="0" ShowOnFocus="true" DisableUnderLine="true" Margin="Margin.Dense" Class="player-name-input balanced-center-select" Style="font-weight: bold; font-size: 0.95rem; width: 9.5em;" Disabled="isSitOut" onfocus="this.select();" />
                        <div class="d-flex align-center justify-center flex-grow-1">
                            @* 抜け番 *@
                            @if (activeParticipantCount > rules.PlayerCount)
                            {
                                <MudToggleIconButton Toggled="currentSitOuts[index]" ToggledChanged="@((bool v) => OnSitOutChanged(index, v))" Icon="@Icons.Material.Filled.Person" Color="Color.Default" Title="参加中" ToggledIcon="@Icons.Material.Filled.LocalCafe" ToggledColor="Color.Default" ToggledTitle="☕ 抜け番" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" />
                            }
                            @* 焼き鳥 *@
                            @if (rules.IsYakiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentYaki[index]" Icon="@Icons.Material.Filled.NoMeals" Color="Color.Default" Title="焼き鳥ではありません" ToggledIcon="@YakiIcon" ToggledColor="Color.Warning" ToggledTitle="🍗 焼き鳥です" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                            @* トビ *@
                            @if (rules.IsTobiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentTobiBonus[index]" Icon="@Icons.Material.Filled.Rocket" Color="Color.Default" Title="トビ賞を獲得しません" ToggledIcon="@Icons.Material.Filled.RocketLaunch" ToggledColor="Color.Error" ToggledTitle="🚀 トビ賞を獲得します" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                        </div>
                        @* 右ブロック: 素点入力 *@
                        <div id="score-input-@index" class="d-flex align-baseline" @onclick="@(async () => await OpenKeypad(index))" @onclick:stopPropagation="true">
                            <MudTextField T="string" Value="@scoreInputBuffers[index]" ReadOnly="true" DisableUnderLine="true" Margin="Margin.Dense" Class="@($"score-input {(index == autoFilledIndex ? "auto-filled" : "")} {(activeScoreInputIndex == index ? "score-input-active" : "")} {(activeScoreInputIndex.HasValue && index == autoFilledIndex ? "score-input-auto-filling" : "")}")" Style="width: 77px; cursor: pointer;" Disabled="isSitOut" Adornment="@(index == autoFilledIndex ? Adornment.Start : Adornment.None)" AdornmentIcon="@Icons.Material.Filled.AutoAwesome" AdornmentColor="Color.Info" />
                            <span class="score-zeros" style="cursor: pointer;">00</span>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" Class="mt-2 py-3" Disabled="@(!IsTotalCorrect)" OnClick="CalculateAndRecordGame">結果を記録する</MudButton>
    </MudPaper>

    @* --- セクション3: 集計結果 --- *@
    <MudPaper Class="pa-2 px-sm-4" Elevation="2">
        <ResultTable History="ActiveHistory" Players="TablePlayers" ActiveParticipantCount="TablePlayers.Count" @bind-DisplayMode="displayMode" Rules="rules" SessionChips="TablePlayers.Select(p => ActiveSessionChips.TryGetValue(p, out var v) ? v : 0).ToList()" IsReadOnly="false" ArmedDeleteTarget="armedDeleteTarget" OnDeleteRequested="HandleDeleteRequest" OnResetRequested="ConfirmReset" OnChipChanged="HandleChipChangedCallback" />
        @* DBへ保存するボタン *@
        <div class="d-flex justify-center mt-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.CloudUpload" Disabled="@(ActiveHistory.Count == 0)" OnClick="ConfirmFinalizeSession" Style="width: 100%; max-width: 400px; font-weight: bold; padding: 12px 0;">
                結果を通算成績に保存
            </MudButton>
        </div>
        @* 共有ボタン *@
        <div class="d-flex justify-end mt-4 gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Share" OnClick="ShareImageAsync" Disabled="isSharing" Style="width: 170px; white-space: nowrap;">
                @(isSharing ? "画像を作成中..." : "結果を画像でシェア")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Link" OnClick="CopyShareUrlAsync" Style="white-space: nowrap;">
                閲覧用URLをシェア
            </MudButton>
        </div>
    </MudPaper>

    <div style="position: absolute; left: -9999px; top: 0;">
        <div id="share-target" style="width: @(800 + Math.Max(0, TablePlayers.Count - 4) * 150)px; padding: 40px; background-color: #1a1a27; color: white; border-radius: 12px; font-family: 'Kaisei Decol', sans-serif;">
            <h2 style="text-align: center; margin-bottom: 20px; font-weight: bold; border-bottom: 2px solid #444; padding-bottom: 10px;">
                🀄 対局結果 🀄
            </h2>
            @* ルール・レート情報の表示 *@
            <div style="display: flex; flex-wrap: wrap; gap: 15px; margin-bottom: 20px; background-color: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; font-size: 0.95rem;">
                <div><strong>ルール名:</strong> @(string.IsNullOrWhiteSpace(rules.Name) ? "未設定" : rules.Name)</div>
                <div><strong>形式:</strong> @(rules.PlayerCount)人麻雀</div>
                <div><strong>設定:</strong> @(rules.StartingPoints)持ち / @(rules.ReturnPoints)返し</div>
                <div><strong>ウマ:</strong> @(rules.IsCustomUma ? rules.GetUmaDisplayText(true) : $"{rules.Uma1} - {rules.Uma2}")</div>
                <div><strong>レート:</strong> @(rules.Rate)円/1k</div>
                @if (rules.ChipRate > 0)
                {
                    <div><strong>チップ:</strong> @(rules.ChipRate)円/枚</div>
                }
            </div>
            @* 成績テーブル *@
            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; text-align: center; font-variant-numeric: tabular-nums;">
                <thead>
                    <tr style="background-color: rgba(255,255,255,0.1); border-bottom: 2px solid #555;">
                        <th style="padding: 12px; width: 80px; font-size: 0.9rem;">局</th>
                        @for (int i = 0; i < TablePlayers.Count; i++)
                        {
                            <th style="padding: 12px; font-size: 1.1rem;">@(string.IsNullOrWhiteSpace(TablePlayers[i]) ? " " : TablePlayers[i])</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @* 各局のポイント (+/-) 固定表示 *@
                    @for (int row = 0; row < ActiveHistory.Count; row++)
                    {
                        var game = ActiveHistory[row];
                        <tr style="border-bottom: 1px solid #333;">
                            <td style="padding: 10px; color: #aaa; font-size: 0.85rem; white-space: nowrap;">@(row + 1)局目</td>
                            @for (int i = 0; i < TablePlayers.Count; i++)
                            {
                                @* 各局のフォントサイズ: 1.1rem *@
                                <td style="padding: 10px; font-size: 1.1rem; white-space: nowrap;">
                                    <span style="@GetSharePointStyle(game, TablePlayers[i])">@GetSharePointValue(game, TablePlayers[i])</span>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    @* ポイント合計行 *@
                    <tr style="background-color: rgba(46, 125, 50, 0.1); border-bottom: 2px solid #555;">
                        <td style="padding: 15px 10px; font-size: 0.9rem; color: #ddd; font-weight: bold; white-space: nowrap;">
                            Pt 合計
                        </td>
                        @for (int i = 0; i < TablePlayers.Count; i++)
                        {
                            @* Pt合計のフォントサイズ: 1.2rem *@
                            <td style="padding: 15px 10px; font-size: 1.2rem; white-space: nowrap;">
                                <span style="@GetShareTotalPointStyle(TablePlayers[i])">@GetShareTotalPointValue(TablePlayers[i])</span>
                            </td>
                        }
                    </tr>
                    @* チップ行 (チップあり設定の場合のみ表示) *@
                    @if (rules.ChipRate > 0)
                    {
                        <tr style="background-color: rgba(46, 125, 50, 0.1); border-bottom: 2px solid #555;">
                            <td style="padding: 15px 10px; font-size: 0.9rem; color: #ddd; font-weight: bold; white-space: nowrap;">
                                チップ
                            </td>
                            @for (int i = 0; i < TablePlayers.Count; i++)
                            {
                                int chip = ActiveSessionChips.TryGetValue(TablePlayers[i], out var v) ? v : 0;
                                @* チップのフォントサイズ: 1.2rem (Pt合計と同等) *@
                                <td style="padding: 15px 10px; font-size: 1.2rem; white-space: nowrap;">
                                    <span style="display: inline-block; width: 4.5rem; text-align: right; @(chip > 0 ? "color: #ff6b6b;" : (chip < 0 ? "color: #4dabf7;" : "color: #9e9e9e;"))">
                                        @(chip > 0 ? $"+{chip}" : chip.ToString())枚
                                    </span>
                                </td>
                            }
                        </tr>
                    }
                    @* 円合計行 *@
                    <tr style="background-color: rgba(255, 255, 255, 0.06); font-weight: bold;">
                        <td style="padding: 15px 10px; font-size: 0.9rem; color: #eeeeee; white-space: nowrap;">
                            円 合計
                        </td>
                        @for (int i = 0; i < TablePlayers.Count; i++)
                        {
                            @* 円合計のフォントサイズ: 1.4rem *@
