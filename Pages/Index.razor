    @* 参加者枠を増やす *@
    private async Task AddParticipant()
    {
        if (activeParticipantCount < MaxParticipants)
        {
            int newIndex = activeParticipantCount;
            if (autoFilledIndex.HasValue)
                currentSitOuts[newIndex] = true;
            activeParticipantCount++;
            await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
            EvaluateAutoFill();
        }
    }

    @* 参加者枠を減らす *@
    private async Task RemoveParticipant()
    {
        if (activeParticipantCount > rules.PlayerCount)
        {
            activeParticipantCount--;
            currentScores[activeParticipantCount] = null;
            currentSitOuts[activeParticipantCount] = false;
            currentYaki[activeParticipantCount] = false;
            currentTobiBonus[activeParticipantCount] = false;
            if (activeParticipantCount == rules.PlayerCount)
            {
                for (int i = 0; i < activeParticipantCount; i++)
                {
                    if (currentSitOuts[i])
                    {
                        currentSitOuts[i] = false;
                        if (previousScores[i].HasValue)
                        {
                            currentScores[i] = previousScores[i];
                            previousScores[i] = null;
                        }
                    }
                }
            }
            await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
            EvaluateAutoFill();
        }
    }

    @* 抜け番状態の変更処理 *@
    private void OnSitOutChanged(int index, bool isSitOut)
    {
        currentSitOuts[index] = isSitOut;
        if (isSitOut)
        {
            // 消す前に直前の素点をバックアップ
            previousScores[index] = currentScores[index];
            currentScores[index] = null;
            currentYaki[index] = false;
            currentTobiBonus[index] = false;
            if (index == autoFilledIndex) autoFilledIndex = null;
        }
        else
        {
            // 復帰時、バックアップがあれば素点を復元する
            if (previousScores[index].HasValue)
            {
                currentScores[index] = previousScores[index];
                previousScores[index] = null;
            }
        }
        EvaluateAutoFill();
    }

    // 自動入力された枠のインデックスを保持
    private int? autoFilledIndex = null;

    // 状態を評価し、矛盾を正すコアメソッド
    private void EvaluateAutoFill()
    {
        var activeIndices = Enumerable.Range(0, activeParticipantCount).Where(i => !currentSitOuts[i]).ToList();

        if (activeIndices.Count != rules.PlayerCount)
        {
            ClearAutoFill();
            return;
        }
        var manualIndices = activeIndices.Where(i => i != autoFilledIndex).ToList();
        var nullManualIndices = manualIndices.Where(i => !currentScores[i].HasValue).ToList();
        if (nullManualIndices.Count == 0)
        {
            // 手動枠がすべて埋まっている場合、自動枠を再計算（追従）
            if (autoFilledIndex.HasValue)
            {
                int targetTotal = (rules.StartingPoints * rules.PlayerCount) / 100;
                int currentTotal = manualIndices.Sum(i => currentScores[i] ?? 0);
                currentScores[autoFilledIndex.Value] = targetTotal - currentTotal;
            }
        }
        else if (nullManualIndices.Count == 1)
        {
            if (autoFilledIndex.HasValue)
            {
                // 自動枠があるのに空欄ができた＝ユーザーが数値を消した（消去）
                ClearAutoFill();
            }
            else
            {
                // 新規で自動計算を発動
                autoFilledIndex = nullManualIndices[0];
                int targetTotal = (rules.StartingPoints * rules.PlayerCount) / 100;
                int currentTotal = activeIndices.Where(i => i != autoFilledIndex).Sum(i => currentScores[i] ?? 0);
                currentScores[autoFilledIndex.Value] = targetTotal - currentTotal;
            }
        }
        else
        {
            ClearAutoFill();
        }
    }

    private void ClearAutoFill()
    {
        if (autoFilledIndex.HasValue)
        {
            currentScores[autoFilledIndex.Value] = null;
            autoFilledIndex = null;
        }
    }

    @* 本日の対局セッションの終了確定確認ダイアログを表示 *@
    private async Task ConfirmFinalizeSession()
    {
        int chipSum = 0;
        for (int i = 0; i < TableParticipantCount; i++)
            chipSum += ActiveSessionChips[i];
        bool isChipError = chipSum != 0;
        string msg = "本日のすべての対局結果とチップの精算枚数を長期成績DBに記録し、現在の入力フォームをリセットしますか？";
        if (isChipError) msg = "<span style='color: #ff6b6b; font-weight: bold;'>【警告】チップの合計枚数がプラスマイナスゼロになっていません（現在: " + (chipSum > 0 ? "+" : "") + chipSum + "枚）。</span><br />このまま長期成績に強制保存しますか？";
        bool? result = await DialogService.ShowMessageBoxAsync(
            "対局セッションの終了確定",
            (MarkupString)msg,
            yesText: "終了して保存する",
            cancelText: "戻る"
        );
        if (result == true) await FinalizeAndSaveToDbAsync();
    }

    @* データを成形して長期成績DB（IndexedDBを想定）へ一括保存し、卓を片付けるコアロジック *@
    private async Task FinalizeAndSaveToDbAsync()
    {
        try
        {
            // 1. 各局（h）の PlayerNames の中から、対応する素点（RawScores）が null ではない（実際に打った）プレイヤー名のみを抽出
            var sessionPlayerNames = ActiveHistory
                .SelectMany(h => h.PlayerNames
                    .Select((name, idx) => new { Name = name, HasScore = idx < h.RawScores.Count && h.RawScores[idx].HasValue })
                    .Where(x => x.HasScore && !string.IsNullOrWhiteSpace(x.Name))
                    .Select(x => x.Name))
                .Distinct()
                .ToList();

            // 名前からIDを引くためのマッピングと、一括保存用コレクション
            var nameToIdMap = new Dictionary<string, string>();
            var playersToUpdate = new List<PlayerProfile>();
            var gameRecordsToSave = new List<SavedGameRecord>();
            
            var newSessionId = Guid.NewGuid().ToString();
            var currentTimestamp = DateTime.Now;

            // 2. 名簿マスター（playerMaster）と照合し、新規の名前にはIDを自動発行
            foreach (var name in sessionPlayerNames)
            {
                var existingPlayer = playerMaster.FirstOrDefault(p => p.Name == name);

                if (existingPlayer != null)
                {
                    nameToIdMap[name] = existingPlayer.Id;
                    playersToUpdate.Add(new PlayerProfile 
                    { 
                        Id = existingPlayer.Id, 
                        Name = existingPlayer.Name, 
                        CumulativeChips = existingPlayer.CumulativeChips, // 互換性のために残しますが、更新はしません
                        CreatedAt = existingPlayer.CreatedAt
                    });
                }
                else
                {
                    var newId = Guid.NewGuid().ToString();
                    var newProfile = new PlayerProfile 
                    { 
                        Id = newId, 
                        Name = name,
                        CumulativeChips = 0,
                        CreatedAt = currentTimestamp
                    };
                    
                    playerMaster.Add(newProfile);
                    playersToUpdate.Add(newProfile);
                    
                    nameToIdMap[name] = newId;
                }
            }

            // 3. 各局のデータを「IDベース」に変換し、保存用モデルを作成
            foreach (var game in ActiveHistory)
            {
                var savedRecord = new SavedGameRecord
                {
                    Id = Guid.NewGuid().ToString(),
                    SessionId = newSessionId,
                    RuleName = rules.Name,
                    PlayerCount = rules.PlayerCount,
                    Timestamp = game.Timestamp,
                    PlayerIds = game.PlayerNames.Select(name => !string.IsNullOrWhiteSpace(name) && nameToIdMap.ContainsKey(name) ? nameToIdMap[name] : null).ToList(),
                    RawScores = game.RawScores,
                    Points = game.Points,
                    Yen = game.Yen
                };
                
                gameRecordsToSave.Add(savedRecord);
            }

            // 4. セッション総括記録を作成（当時のレート・チップレートをここでスナップショット保存）
            var sessionRecord = new SavedSessionRecord
            {
                SessionId = newSessionId,
                Date = currentTimestamp,
                Rate = rules.Rate,         // ★追加：当時の基本レートを記録
                ChipRate = rules.ChipRate, // ★追加：当時のチップレートを記録
                ParticipantPlayerIds = new List<string>(),
                SettledChips = new List<int>()
            };

            for (int i = 0; i < TableParticipantCount; i++)
            {
                string name = currentPlayers[i].Name;
                if (!string.IsNullOrWhiteSpace(name) && nameToIdMap.TryGetValue(name, out var playerId))
                {
                    int chipCount = ActiveSessionChips[i];
                    
                    // セッション総括記録に追加
                    sessionRecord.ParticipantPlayerIds.Add(playerId);
                    sessionRecord.SettledChips.Add(chipCount);

                    // 💡 名簿（PlayerProfile）側への生枚数の累積・上書き処理は、今回の仕様変更（セッション毎清算）に伴い完全に撤廃しました。
                    // チップの金額は、すべてこのsessionRecordから動的に計算・集計します。
                }
            }

            // 5. JS相互運用で IndexedDB へ安全に一括保存
            await DatabaseService.SaveSessionAsync(playersToUpdate, sessionRecord, gameRecordsToSave);

            // 6. 卓情報のクリア
            ActiveHistory.Clear();
            ActiveSessionChips = Enumerable.Repeat(0, MaxParticipants).ToList();
            
            await LocalStorage.SetItemAsync("ActiveHistory", ActiveHistory);
            await LocalStorage.SetItemAsync("ActiveSessionChips", ActiveSessionChips);

            ResetInputForms();
            Snackbar.Add("本日の対局結果を通算成績に保存しました！", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add("保存中にエラーが発生しました: " + ex.Message, Severity.Error);
        }
    }
