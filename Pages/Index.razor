@page "/"
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6"
             Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        麻雀集計ツール</MudText>

        @* --- セクション1: 設定 (折りたたみ) --- *@
        <MudExpansionPanels Class="mb-6">
            <MudExpansionPanel Text="ルール・対局者設定" @bind-Expanded="isSettingsExpanded">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mb-4"
                           StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenPresetDialog">
                    保存済みの設定を呼び出し
                </MudButton>
                <MudGrid>
                    <MudItem xs="12" md="8" Class="d-flex">
                        <MudCard Outlined="true" Class="flex-grow-1">
                            <MudCardHeader Class="pb-0">
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:bold;">ルール設定</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Save" OnClick="SavePreset">現在の設定を保存</MudButton>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent Class="pa-3 pt-1">
                                <MudGrid Spacing="1">
                                    <MudItem xs="6" sm="4">
                                        <MudSelect T="int" Label="対局人数" @bind-Value="rules.PlayerCount"
                                                   Margin="Margin.Dense">
                                            <MudSelectItem Value="4">四人麻雀</MudSelectItem>
                                            <MudSelectItem Value="3">三人麻雀</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6" sm="8">
                                        <MudTextField Label="ルール名" @bind-Value="rules.Name" Margin="Margin.Dense" />
                                    </MudItem>
                                
                                    <MudItem xs="6" sm="4">
                                        <MudNumericField T="int" Label="持ち点" Value="rules.StartingPoints"
                                                         ValueChanged="OnStartingPointsChanged" Step="5000" Min="0"
                                                         Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4">
                                        <MudNumericField T="int" Label="返し点" Value="rules.ReturnPoints"
                                                         ValueChanged="OnReturnPointsChanged" Step="5000" Min="0"
                                                         Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4">
                                        <MudNumericField Label="レート(円/1k)" @bind-Value="rules.Rate" Step="10" Min="0"
                                                         Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4">
                                        <MudNumericField Label="チップ(円/枚)" @bind-Value="rules.ChipRate" Step="50" Min="0"
                                                         Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4">
                                        <MudNumericField Label="@(rules.PlayerCount == 3 ? "ウマ(1←2)" : "ウマ(2←3)")"
                                                         @bind-Value="rules.Uma1" Step="5" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4">
                                        <MudNumericField Label="@(rules.PlayerCount == 3 ? "ウマ(1←3)" : "ウマ(1←4)")"
                                                         @bind-Value="rules.Uma2" Step="5" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="d-flex">
                        <MudCard Outlined="true" Class="flex-grow-1">
                            <MudCardHeader Class="pb-0">
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:bold;">対局者名</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-3 pt-1">
                                <MudStack Spacing="0">
                                    @for (int i = 0; i < 4; i++)
                                    {
                                        var index = i;
                                        <MudTextField Placeholder="@($"対局者 {index + 1}")" Value="currentPlayers[index]"
                                                      ValueChanged="@((string v) => OnPlayerNameChanged(index, v))"
                                                      Disabled="@(index >= rules.PlayerCount)" Margin="Margin.Dense" />
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @* --- セクション2: 素点入力 --- *@
        <MudPaper Class="pa-4 mb-6" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Baseline" Class="mb-2">
                <MudText Typo="Typo.h6">素点入力</MudText>
            </MudStack>
            <MudGrid Spacing="1">
                @for (int i = 0; i < rules.PlayerCount; i++)
                {
                    var index = i;
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="int?" Label="@(string.IsNullOrWhiteSpace(currentPlayers[index]) ? " " : currentPlayers[index])" Value="currentScores[index]"
                                         ValueChanged="@(v => OnScoreChanged(index, v))" Step="100" Margin="Margin.Dense" />
                    </MudItem>
                }
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Class="mt-4 py-3"
                       Disabled="@(!IsTotalCorrect)" OnClick="RecordGame">結果を記録する</MudButton>
        </MudPaper>

        @* --- セクション3: 集計結果 --- *@
        <MudPaper Class="pa-2 px-sm-4" Elevation="2">
            <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                      Class="mb-4 gap-2">
                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Class="gap-2">
                    <MudText Typo="Typo.h6">集計結果</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudButton Variant="@(displayMode == 0 ? Variant.Filled : Variant.Outlined)" Color="Color.Primary"
                                   Size="Size.Small" OnClick="() => displayMode = 0">素点</MudButton>
                        <MudButton Variant="@(displayMode == 1 ? Variant.Filled : Variant.Outlined)" Color="Color.Primary"
                                   Size="Size.Small" OnClick="() => displayMode = 1">+/−</MudButton>
                        <MudButton Variant="@(displayMode == 2 ? Variant.Filled : Variant.Outlined)" Color="Color.Primary"
                                   Size="Size.Small" OnClick="() => displayMode = 2">円</MudButton>
                    </MudStack>
                </MudStack>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="ConfirmReset">記録リセット</MudButton>
            </MudStack>
            <MudCard Class="mb-4" Elevation="0" Outlined="true">
                <MudCardContent Class="pa-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">チップ集計</MudText>
                    <MudGrid Spacing="1">
                        @{
                            bool isChipError = ActiveSessionChips.Take(rules.PlayerCount).Sum() != 0;
                        }
                        @for (int i = 0; i < rules.PlayerCount; i++)
                        {
                            var idx = i;
                            <MudItem xs="3">
                                <MudNumericField T="int" Label="@(string.IsNullOrWhiteSpace(currentPlayers[idx]) ? " " : currentPlayers[idx])" Value="ActiveSessionChips[idx]"
                                                 ValueChanged="@(v => OnChipChanged(idx, v))" Step="1" HideSpinButtons="true"
                                                 Margin="Margin.Dense" Style="@(isChipError ? "color:#ff0000; font-weight:bold;" : "")" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <div style="width: 100%; overflow-x: hidden;">
                <MudTable Items="@ActiveHistory" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None"
                          Style="width: 100%; table-layout: fixed;">
                    <ColGroup>
                        <col style="width: 25px;" />
                        @for (int i = 0; i < rules.PlayerCount; i++)
                        {
                            <col />
                        }
                        <col style="width: 25px;" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh
                            Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.65rem; letter-spacing: -0.5px;">
                            時刻</MudTh>
                            @for (int i = 0; i < rules.PlayerCount; i++)
                            {
                                var idx = i;
                               <MudTh Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.75rem; letter-spacing: -0.5px;">
                                   @(string.IsNullOrWhiteSpace(currentPlayers[idx]) ? " " : currentPlayers[idx])
                               </MudTh>
                            }
                            <MudTh Style="padding: 4px 0px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd
                                Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.6rem; color: #666; letter-spacing: -0.5px;">
                                @context.Timestamp.ToString("HH:mm")
                            </MudTd>
                            @for (int i = 0; i < rules.PlayerCount; i++)
                            {
                                var idx = i;
                                <MudTd Style="text-align: center; padding: 4px 0px; white-space: nowrap;">
                                    <span style="@GetTdStyle(context, idx)">
                                        @GetDisplayValue(context, idx)
                                    </span>
                                </MudTd>
                            }
                            <MudTd Style="text-align: center; white-space: nowrap; padding: 4px 0px;">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Style="padding: 0px; color: #9e9e9e;" OnClick="() => DeleteResult(context)" />
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTd
                                Style="text-align: center; background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; font-weight: bold; white-space: nowrap; padding: 6px 0px; font-size: 0.75rem;">
                                <MudIcon
                                Icon="@(displayMode == 0 ? Icons.Material.Filled.Calculate : Icons.Material.Filled.Functions)"
                                Style="font-size: 1rem; vertical-align: text-bottom; margin-right: 2px; color: #2e7d32;" />
                                @(displayMode == 0 ? "平均" : "合計")
                            </MudTd>
                            @for (int i = 0; i < rules.PlayerCount; i++)
                            {
                                var idx = i;
                                <MudTd
                                    Style="@($"{GetTotalTdStyle(idx)} text-align: center; padding: 6px 0px; white-space: nowrap;")">
                                    <span style="@GetTotalSpanStyle(idx)">
                                        @GetTotalDisplayValue(idx)
                                    </span>
                                </MudTd>
                            }
                            <MudTd
                                Style="background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; padding: 6px 0px;">
                            </MudTd>
                        </FooterContent>
                    </MudTable>
                </div>
            </MudPaper>
        </MudContainer>

@code {
    private RuleSet rules = new();
    private List<RuleSet> rulePresets = new();
    private List<string> currentPlayers = new() { "Aさん", "Bさん", "Cさん", "Dさん" };
    private List<int?> currentScores = new() { null, null, null, null };
    private Dictionary<int, List<GameResult>> histories = new() { { 3, new() }, { 4, new() } };
    private Dictionary<int, List<int>> sessionChipsMap = new() { { 3, new() { 0, 0, 0 } }, { 4, new() { 0, 0, 0, 0 } } };
    private int displayMode = 1;
    private bool isSettingsExpanded = true;
    private List<GameResult> ActiveHistory => histories[rules.PlayerCount];
    private List<int> ActiveSessionChips => sessionChipsMap[rules.PlayerCount];
    private bool IsTotalCorrect => currentScores.Take(rules.PlayerCount).All(x => x.HasValue) &&
                                   currentScores.Take(rules.PlayerCount).Sum(x => x ?? 0) == rules.StartingPoints * rules.PlayerCount;

    protected override async Task OnInitializedAsync()
    {
        var savedRules = await LocalStorage.GetItemAsync<RuleSet>("rules");
        if (savedRules != null) rules = savedRules;
        var savedPlayers = await LocalStorage.GetItemAsync<List<string>>("currentPlayers");
        if (savedPlayers != null && savedPlayers.Count >= 4)
        {
            currentPlayers = savedPlayers;
        }
        var savedPresets = await LocalStorage.GetItemAsync<List<RuleSet>>("rulePresets");
        if (savedPresets != null) rulePresets = savedPresets;
        var dictHistories = await LocalStorage.GetItemAsync<Dictionary<int, List<GameResult>>>("histories_dict");
        if (dictHistories != null) histories = dictHistories;
        var dictChips = await LocalStorage.GetItemAsync<Dictionary<int, List<int>>>("sessionChips_dict");
        if (dictChips != null) sessionChipsMap = dictChips;
        if (!histories.ContainsKey(3)) histories[3] = new();
        if (!histories.ContainsKey(4)) histories[4] = new();
        if (!sessionChipsMap.ContainsKey(3)) sessionChipsMap[3] = new() { 0, 0, 0 };
        if (!sessionChipsMap.ContainsKey(4)) sessionChipsMap[4] = new() { 0, 0, 0, 0 };
        ResetCurrentScores();
    }

    private void ResetCurrentScores() => currentScores = Enumerable.Repeat((int?)null, 4).ToList();

    private void OnStartingPointsChanged(int val)
    {
        int diff = val - rules.StartingPoints;
        if (Math.Abs(diff) == 5000) rules.StartingPoints = val;
        else rules.StartingPoints = val * 100;
    }

    private void OnReturnPointsChanged(int val)
    {
        int diff = val - rules.ReturnPoints;
        if (Math.Abs(diff) == 5000) rules.ReturnPoints = val;
        else rules.ReturnPoints = val * 100;
    }

    private void OnScoreChanged(int index, int? val)
    {
        if (val.HasValue)
        {
            int diff = val.Value - (currentScores[index] ?? 0);
            if (Math.Abs(diff) == 100) currentScores[index] = val;
            else currentScores[index] = val.Value * 100;
        }
        else
        {
            currentScores[index] = null;
        }
        int pCount = rules.PlayerCount;
        var activeScores = currentScores.Take(pCount).ToList();
        var nullIndices = activeScores.Select((v, i) => new { v, i }).Where(x => !x.v.HasValue).Select(x => x.i).ToList();
        if (val.HasValue && nullIndices.Count == 1)
        {
            int lastIndex = nullIndices[0];
            int targetTotal = rules.StartingPoints * pCount;
            int currentTotal = activeScores.Sum(x => x ?? 0);
            currentScores[lastIndex] = targetTotal - currentTotal;
        }
    }

    private async Task OpenPresetDialog()
    {
        var parameters = new DialogParameters { ["Presets"] = rulePresets };
        var dialog = await DialogService.ShowAsync<PresetDialog>("保存済みの設定", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is RuleSet preset)
        {
            rules.Name = preset.Name;
            rules.PlayerCount = preset.PlayerCount;
            rules.StartingPoints = preset.StartingPoints;
            rules.ReturnPoints = preset.ReturnPoints;
            rules.Rate = preset.Rate;
            rules.Uma1 = preset.Uma1;
            rules.Uma2 = preset.Uma2;
            rules.ChipRate = preset.ChipRate;
            await LocalStorage.SetItemAsync("rules", rules);
            Snackbar.Add($"設定「{preset.Name}」を読み込みました", Severity.Success);
            StateHasChanged();
        }
    }

    private async Task SavePreset()
    {
        rulePresets.RemoveAll(p => p.Name == rules.Name);
        rulePresets.Add(new RuleSet
        {
            Name = rules.Name,
            PlayerCount = rules.PlayerCount,
            StartingPoints = rules.StartingPoints,
            ReturnPoints = rules.ReturnPoints,
            Rate = rules.Rate,
            Uma1 = rules.Uma1,
            Uma2 = rules.Uma2,
            ChipRate = rules.ChipRate
        });
        await LocalStorage.SetItemAsync("rulePresets", rulePresets);
        await LocalStorage.SetItemAsync("rules", rules);
        Snackbar.Add($"設定「{rules.Name}」を保存しました", Severity.Success);
    }

    private async Task ConfirmReset()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "記録のリセット",
            (MarkupString)$"{(rules.PlayerCount == 3 ? "三" : "四")}人麻雀の記録をリセットしますか？<br />（この操作は取り消せません）",
            yesText: "リセットする", cancelText: "キャンセル");
        if (result == true)
        {
            ActiveHistory.Clear();
            sessionChipsMap[rules.PlayerCount] = Enumerable.Repeat(0, rules.PlayerCount).ToList();
            await LocalStorage.SetItemAsync("histories_dict", histories);
            await LocalStorage.SetItemAsync("sessionChips_dict", sessionChipsMap);
            Snackbar.Add($"{(rules.PlayerCount == 3 ? "三" : "四")}人麻雀の記録をリセットしました", Severity.Info);
            StateHasChanged();
        }
    }

    private async Task OnChipChanged(int index, int value)
    {
        ActiveSessionChips[index] = value;
        await LocalStorage.SetItemAsync("sessionChips_dict", sessionChipsMap);
    }

    private async Task OnPlayerNameChanged(int index, string value)
    {
        currentPlayers[index] = value;
        await LocalStorage.SetItemAsync("currentPlayers", currentPlayers);
    }

    private async Task RecordGame()
    {
        int pCount = rules.PlayerCount;
        var activeScores = currentScores.Take(pCount).Select(x => x ?? 0).ToList();
        var activePlayers = currentPlayers.Take(pCount).ToList();
        var result = await OpenTieBreakerIfNeeded(activeScores, activePlayers);
        if (result == null) return;
        var resultData = new GameResult
        {
            Timestamp = DateTime.Now,
            PlayerNames = activePlayers,
            RawScores = activeScores
        };
        var rankedIndices = activeScores.Select((score, index) => new { score, index })
                               .OrderByDescending(x => x.score)
                               .ThenBy(x => result[x.index])
                               .Select(x => x.index)
                               .ToList();
        double[] points = new double[pCount];
        double oka = (rules.ReturnPoints - rules.StartingPoints) * pCount / 1000.0;
        for (int rank = 0; rank < pCount; rank++)
        {
            int pIndex = rankedIndices[rank];
            double basePoint = (activeScores[pIndex] - rules.ReturnPoints) / 1000.0;
            
            double uma = 0;
            if (pCount == 4)
            {
                if (rank == 0) uma = rules.Uma2;
                else if (rank == 1) uma = rules.Uma1;
                else if (rank == 2) uma = -rules.Uma1;
                else if (rank == 3) uma = -rules.Uma2;
            }
            else if (pCount == 3)
            {
                if (rank == 0) uma = rules.Uma1 + rules.Uma2;
                else if (rank == 1) uma = -rules.Uma1;
                else if (rank == 2) uma = -rules.Uma2;
            }
            points[pIndex] = rank == 0 ? basePoint + uma + oka : basePoint + uma;
        }
        resultData.Points = points.ToList();
        var yenList = points.Select(p => (int)Math.Round(p * rules.Rate)).ToList();        
        int yenSum = yenList.Sum();
        if (yenSum != 0)
        {
            int topPlayerIndex = rankedIndices[0];
            yenList[topPlayerIndex] -= yenSum; 
        }        
        resultData.Yen = yenList;
        ActiveHistory.Add(resultData);
        await LocalStorage.SetItemAsync("histories_dict", histories);
        await LocalStorage.SetItemAsync("rules", rules);
        ResetCurrentScores();
    }

    private async Task<Dictionary<int, int>?> OpenTieBreakerIfNeeded(List<int> scores, List<string> players)
    {
        var priority = new Dictionary<int, int>();
        if (scores.Distinct().Count() == scores.Count)
        {
            for (int i = 0; i < scores.Count; i++) priority[i] = i;
            return priority;
        }
        var parameters = new DialogParameters { ["Players"] = players };
        var dialog = await DialogService.ShowAsync<TieBreakerDialog>("順位の決定", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not List<string> orderedNames) return null;
        for (int i = 0; i < scores.Count; i++) priority[i] = orderedNames.IndexOf(players[i]);
        return priority;
    }

    private async Task DeleteResult(GameResult res)
    {
        ActiveHistory.Remove(res);
        await LocalStorage.SetItemAsync("histories_dict", histories);
    }

    private string GetDisplayValue(GameResult res, int idx)
    {
        if (displayMode == 0) return res.RawScores[idx].ToString("N0");
        if (displayMode == 1)
        {
            double pt = res.Points[idx];
            return pt > 0 ? $"+{pt:F1}" : pt.ToString("F1");
        }
        if (displayMode == 2)
        {
            int yen = res.Yen[idx];
            return yen > 0 ? $"+{yen:N0}円" : $"{yen:N0}円";
        }
        return "";
    }

    private string GetTdStyle(GameResult res, int idx)
    {
        double pt = res.Points[idx];
        string boxWidth = displayMode == 0 ? "3.4rem" : (displayMode == 1 ? "2.6rem" : "4.2rem");
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.8rem; letter-spacing: -0.5px; ";
        style += pt >= 0 ? "color: #ff0000; " : "color: #1976d2; ";
        if (res.Points.Distinct().Count() > 1 && (pt == res.Points.Max() || pt == res.Points.Min()))
        {
            style += "font-weight: bold; ";
        }
        return style;
    }

    private double GetTotalNumericValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return 0;
        if (displayMode == 0) return ActiveHistory.Count == 0 ? 0 : ActiveHistory.Average(h => h.RawScores[idx]);
        if (displayMode == 1) return ActiveHistory.Sum(h => h.Points[idx]);
        return ActiveHistory.Sum(h => h.Yen[idx]) + (ActiveSessionChips[idx] * rules.ChipRate);
    }

    private string GetTotalDisplayValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return "0";
        double val = GetTotalNumericValue(idx);
        if (displayMode == 0) return Math.Round(val).ToString("N0");
        if (displayMode == 1) return val > 0 ? $"+{val:F1}" : val.ToString("F1");
        if (displayMode == 2) return val > 0 ? $"+{val:N0}円" : $"{val:N0}円";
        return "";
    }

    private string GetTotalTdStyle(int idx)
    {
        return "background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; ";
    }

    private string GetTotalSpanStyle(int idx)
    {
        string boxWidth = displayMode == 0 ? "3.4rem" : (displayMode == 1 ? "2.6rem" : "4.2rem");
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.85rem; letter-spacing: -0.5px; ";
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return style;
        var allValues = Enumerable.Range(0, rules.PlayerCount).Select(i => GetTotalNumericValue(i)).ToList();
        double val = allValues[idx];
        if (allValues.Distinct().Count() > 1 && (val == allValues.Max() || val == allValues.Min()))
        {
            style += "font-weight: bold; ";
        }
        double pointSum = ActiveHistory.Sum(h => h.Points[idx]);
        double yenSum = ActiveHistory.Sum(h => h.Yen[idx]) + (ActiveSessionChips[idx] * rules.ChipRate);
        bool isPositive = (displayMode == 2) ? (yenSum >= 0) : (pointSum >= 0);
        style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";
        return style;
    }
}