@page "/"
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject MahjongApp.Services.DatabaseService DatabaseService
@inject MahjongApp.Services.StatsCacheService StatsCache
@inject IJSRuntime JS
@inject MahjongApp.Services.SessionStateService SessionState
@inject MahjongApp.Services.MahjongCalculatorService Calculator

@* 素点入力欄のスタイル *@
<style>
    /* 名前入力欄 */
    .player-name-input input {
        text-align: center !important;
        letter-spacing: 1px;
    }

    /* フォーカスされていない時は下線を極限まで薄くする */
    .player-name-input:not(:focus-within) {
        opacity: 0.85;
    }

    .score-input input {
        text-align: right !important;
        font-size: 1.3rem !important;
        font-weight: 500 !important;
        padding-right: 2px !important;
    }

    .score-input.auto-filled input {
        color: var(--mud-palette-info) !important;
    }

    .score-input.mud-input-control .mud-input-outlined {
        height: 28px !important;
        min-height: 28px !important;
    }

    .score-input.mud-input-control .mud-input-outlined .mud-input-adornment-start {
        margin: 0 !important;
    }

    .score-input.mud-input-control .mud-input-outlined .mud-input-adornment-start svg {
        font-size: 16px !important;
    }

    .score-zeros {
        font-size: 1.3rem;
        font-weight: 500;
        color: #808080;
        margin-left: 2px;
        user-select: none;
    }

    /* 自動入力アイコン追加時に文字が上に浮く現象を修正 */
    .score-input .mud-input {
        align-items: baseline !important;
    }

    /* アイコン自体は高さの中央を維持する */
    .score-input .mud-input-adornment-start {
        align-self: center !important;
        margin-top: 0 !important;
    }

    /* スコア入力欄がテンキー選択中の時のハイライト */
    .score-input-active {
        border: 1px solid #81c784 !important;
        box-shadow: 0 0 6px rgba(129, 199, 132, 0.5);
        background-color: rgba(76, 175, 80, 0.05) !important;
    }

    /* アプローチ1: 他の枠を入力中、自動入力（補完）枠を仮状態として半透明・斜体にする */
    .score-input-auto-filling input {
        opacity: 0.4 !important;
        transition: opacity 0.15s ease;
    }

    /* テンキーが開いている時だけ、画面の一番下にテンキー分の大きな余白を作る */
    .keypad-open-padding {
        padding-bottom: 320px !important;
    }

    /* ▽アイコンの幅に合わせて左側を押し込む */
    .balanced-center-select input {
        text-align: center !important;
        padding-left: 10px !important;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="@($"mt-4 pb-10 {(activeScoreInputIndex.HasValue ? "keypad-open-padding" : "")}")" @onclick="OnContainerClick" Style="min-height: 100vh;">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        <MudIcon Icon="@Icons.Material.Filled.Functions" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        素点集計
    </MudText>

    @* --- セクション1: 設定 (折りたたみ可) --- *@
    <MudExpansionPanels Class="mb-6">
        <MudExpansionPanel Text="ルール設定" Style="font-weight:bold; white-space: nowrap;" @bind-Expanded="isSettingsExpanded">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mb-4" StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenPresetDialog">
                保存済みの設定を呼び出し
            </MudButton>
            <MudCard Outlined="true" Class="w-100">
                <MudCardHeader Class="pb-0">
                    <CardHeaderContent>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Settings" OnClick="OpenCustomRuleDialog">
                                    カスタム<span class="d-none d-sm-inline">ルール</span>
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="SavePreset">
                                    <span class="d-none d-sm-inline">現在の</span>設定保存
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-2 pa-sm-3 pt-1 mt-2">
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="8">
                            <MudTextField Label="ルール名" @bind-Value="rules.Name" Margin="Margin.Dense" onfocus="this.select();" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudSelect T="int" Label="対局人数" Value="rules.PlayerCount" ValueChanged="OnPlayerCountChanged" Margin="Margin.Dense" Class="px-2">
                                <MudSelectItem Value="@(4)">四人麻雀</MudSelectItem>
                                <MudSelectItem Value="@(3)">三人麻雀</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="int" Label="持ち点" Value="rules.StartingPoints" ValueChanged="OnStartingPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="int" Label="返し点" Value="rules.ReturnPoints" ValueChanged="OnReturnPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField Label="レート(円/1k)" @bind-Value="rules.Rate" Step="10" Min="0" Margin="Margin.Dense" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField Label="チップ(円/枚)" @bind-Value="rules.ChipRate" Step="50" Min="0" Margin="Margin.Dense" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                        </MudItem>
                        @if (rules.IsCustomUma)
                        {
                            <MudItem xs="12" sm="8">
                                <MudTextField Label="カスタム順位ウマ" Value="@rules.GetUmaDisplayText(true)" ReadOnly="true" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Close" OnAdornmentClick="DisableCustomUma" Style="font-variant-numeric: tabular-nums;" Class="px-2" />
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="6" sm="4">
                                <MudNumericField T="int" Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←2)" : "順位ウマ(2←3)")" Value="rules.Uma1" ValueChanged="@((int v) => { rules.Uma1 = v; SyncNormalToCustomUma(); })" Step="5" Min="0" Margin="Margin.Dense" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                            </MudItem>
                            <MudItem xs="6" sm="4">
                                <MudNumericField T="int" Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←3)" : "順位ウマ(1←4)")" Value="rules.Uma2" ValueChanged="@((int v) => { rules.Uma2 = v; SyncNormalToCustomUma(); })" Step="5" Min="0" Margin="Margin.Dense" Class="px-2" @onfocusin="@(() => CloseKeypad())" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* --- セクション2: 対局者＆素点入力 --- *@
    <MudPaper id="score-input-section" Class="pa-2 pa-sm-4 mb-6" Elevation="2">
        <div class="mb-3 px-1">
            <MudText Style="font-weight: bold;" Class="mb-1">素点入力</MudText>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%; overflow: hidden;">
                <div class="d-flex align-center">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddParticipant" Disabled="@(activeParticipantCount >= MaxParticipants)" Style="min-width: 0; padding-left: 4px; padding-right: 4px;">
                        <span style="white-space: nowrap;">追加</span>
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonRemove" OnClick="RemoveParticipant" Disabled="@(activeParticipantCount <= rules.PlayerCount)" Style="min-width: 0; padding-left: 4px; padding-right: 4px;">
                        <span style="white-space: nowrap;">削除</span>
                    </MudButton>
                </div>
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.History" OnClick="CopyPreviousGame" Disabled="@(ActiveHistory.Count == 0)" Style="white-space: nowrap; flex-shrink: 0; padding-left: 4px; padding-right: 4px;">
                    前局をコピー
                </MudButton>
            </MudStack>
        </div>
        <MudGrid Spacing="1" AlignItems="AlignItems.Center">
            @for (int i = 0; i < activeParticipantCount; i++)
            {
                var index = i;
                bool isSitOut = currentSitOuts[index];
                <MudItem xs="12" sm="6">
                    <MudPaper Outlined="true" Elevation="0" Class="d-flex align-center justify-space-between px-2 py-1" Style="@($"background-color: rgba(255,255,255,0.02); transition: opacity 0.3s; {(isSitOut ? "opacity: 0.4;" : "")}")">
                        @* 左ブロック: 名前入力 *@
                        <MudAutocomplete T="string" Placeholder="@($"対局者 {index + 1}")" Value="currentPlayers[index].Name" ValueChanged="@((string v) => OnPlayerNameChanged(index, v))" SearchFunc="@SearchRegisteredPlayers" CoerceText="true" CoerceValue="true" MinCharacters="0" ShowOnFocus="true" DisableUnderLine="true" Margin="Margin.Dense" Class="player-name-input balanced-center-select" Style="font-weight: bold; font-size: 0.95rem; width: 9.5em;" Disabled="isSitOut" onfocus="this.select();" @onfocusin="@(() => CloseKeypad())" />
                        <div class="d-flex align-center justify-center flex-grow-1">
                            @* 抜け番 *@
                            @if (activeParticipantCount > rules.PlayerCount)
                            {
                                <MudToggleIconButton Toggled="currentSitOuts[index]" ToggledChanged="@((bool v) => OnSitOutChanged(index, v))" Icon="@Icons.Material.Filled.Person" Color="Color.Default" Title="参加中" ToggledIcon="@Icons.Material.Filled.LocalCafe" ToggledColor="Color.Default" ToggledTitle="☕ 抜け番" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" />
                            }
                            @* 焼き鳥 *@
                            @if (rules.IsYakiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentYaki[index]" Icon="@Icons.Material.Filled.NoMeals" Color="Color.Default" Title="焼き鳥ではありません" ToggledIcon="@YakiIcon" ToggledColor="Color.Warning" ToggledTitle="🍗 焼き鳥です" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                            @* トビ *@
                            @if (rules.IsTobiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentTobiBonus[index]" Icon="@Icons.Material.Filled.Rocket" Color="Color.Default" Title="トビ賞を獲得しません" ToggledIcon="@Icons.Material.Filled.RocketLaunch" ToggledColor="Color.Error" ToggledTitle="🚀 トビ賞を獲得します" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                        </div>
                        @* 右ブロック: 素点入力 *@
                        <div id="score-input-@index" class="d-flex align-baseline" @onclick="@(async () => await OpenKeypad(index))" @onclick:stopPropagation="true">
                            <MudTextField T="string" Value="@scoreInputBuffers[index]" ReadOnly="true" DisableUnderLine="true" Margin="Margin.Dense" Class="@($"score-input {(index == autoFilledIndex ? "auto-filled" : "")} {(activeScoreInputIndex == index ? "score-input-active" : "")} {(activeScoreInputIndex.HasValue && index == autoFilledIndex ? "score-input-auto-filling" : "")}")" Style="width: 77px; cursor: pointer;" Disabled="isSitOut" Adornment="@(index == autoFilledIndex ? Adornment.Start : Adornment.None)" AdornmentIcon="@Icons.Material.Filled.AutoAwesome" AdornmentColor="Color.Info" />
                            <span class="score-zeros" style="cursor: pointer;">00</span>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" Class="mt-2 py-3" Disabled="@(!IsTotalCorrect)" OnClick="CalculateAndRecordGame">結果を記録する</MudButton>
    </MudPaper>

    @* --- セクション3: 集計結果 --- *@
    <MudPaper Class="pa-2 px-sm-4" Elevation="2">
        <ResultTable History="ActiveHistory" Players="TablePlayers" ActiveParticipantCount="TablePlayers.Count" @bind-DisplayMode="displayMode" Rules="rules" SessionChips="TablePlayers.Select(p => ActiveSessionChips.TryGetValue(p, out var v) ? v : 0).ToList()" IsReadOnly="false" ArmedDeleteTarget="armedDeleteTarget" OnDeleteRequested="HandleDeleteRequest" OnResetRequested="ConfirmReset" OnChipChanged="HandleChipChangedCallback" />
        @* DBへ保存するボタン *@
        <div class="d-flex justify-center mt-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.CloudUpload" Disabled="@(ActiveHistory.Count == 0)" OnClick="ConfirmFinalizeSession" Style="width: 100%; max-width: 400px; font-weight: bold; padding: 12px 0;">
                結果を通算成績に保存
            </MudButton>
        </div>
        @* 共有ボタン *@
        <ShareButtonGroup Rules="rules" TablePlayers="TablePlayers" ActiveHistory="ActiveHistory" ActiveSessionChips="ActiveSessionChips" />
    </MudPaper>
</MudContainer>
@* テンキー *@
<ScoreKeypad IsOpen="activeScoreInputIndex.HasValue" IsTotalCorrect="IsTotalCorrect" OnKeyPress="OnKeypadPress" />

@code {
    // 画面の入力状態を管理するための内部クラス
    public class PlayerInputState
    {
        public string? Id { get; set; } // 登録済みの場合はID、新規手入力の場合はnull
        public string Name { get; set; } = string.Empty;
    }
    private RuleSet rules => SessionState.Rules;
    private List<RuleSet> rulePresets = new();
    private const int MaxParticipants = 7;
    private int activeParticipantCount
    {
        get => SessionState.ActiveParticipantCount;
        set => _ = SessionState.SaveActiveParticipantCountAsync(value); // 簡易書き換え用
    }
    private List<PlayerInputState> currentPlayers = Enumerable.Range(0, 7).Select(_ => new PlayerInputState()).ToList();
    private List<PlayerProfile> playerMaster = new();
    private List<int?> currentScores => scoreInputBuffers.Select(val => EvaluateScoreExpression(val)).ToList();
    private bool isFinalizing = false;
    private List<int?> previousScores = Enumerable.Repeat((int?)null, MaxParticipants).ToList();
    private List<GameResult> ActiveHistory => SessionState.ActiveHistory;
    private Dictionary<string, int> ActiveSessionChips => SessionState.ActiveSessionChips;
    private int displayMode = 1;
    private bool isSettingsExpanded = true;
    private bool IsTotalCorrect
    {
        get
        {
            var activeScores = currentScores.Take(activeParticipantCount).Where((s, i) => !currentSitOuts[i]).ToList();
            if (activeScores.Count(x => x.HasValue) != rules.PlayerCount) return false;
            return activeScores.Sum(x => x ?? 0) == (rules.StartingPoints * rules.PlayerCount) / 100;
        }
    }
    private List<bool> currentYaki = new(new bool[MaxParticipants]);
    private List<bool> currentTobiBonus = new(new bool[MaxParticipants]);
    private List<bool> currentSitOuts = new(new bool[MaxParticipants]);
    private const string YakiIcon = "<g transform=\"matrix(0.025, 0, 0, 0.025, 0, 24)\"><path d=\"M843-60 670-234l-85 85q-23 23-56.5 23T472-149l-57-56q-23-23-23-56.5t23-56.5l-56-57q-23 23-56.5 23T246-375l-57-56q-23-23-23-56.5t23-56.5l-56-57q-23-23-23-56.5t23-56.5l28-28L60-844l56-56 102 102 28-28q23-23 57-23t57 23l56 56q23-23 56.5-23t56.5 23l57 56q23 23 23 57t-23 57l56 56q23-23 56.5-23t56.5 23l57 56q23 23 23 57t-23 57l-85 84 172 173-56 57ZM529-205l227-226-57-57-227 227 57 56Zm-57-170 114-113-57-56-113 113 56 56Zm-170-56 227-227-57-56-226 226 56 57Zm-56-170 114-113-57-57-113 113 56 57Zm368 255ZM501-460ZM388-573ZM275-686Z\"/></g>";
    private int? armedDeleteIndex = null;
    private GameResult? armedDeleteTarget = null;
    private string FormatPlus(double val, string fmt = "F1") => val > 0 ? $"+{val.ToString(fmt)}" : val.ToString(fmt);
    private int? activeScoreInputIndex = null;
    private string[] scoreInputBuffers
    {
        get => SessionState.ScoreInputBuffers;
        set => _ = SessionState.SaveScoreBuffersAsync(value);
    }

    @* ローカルストレージからのデータ復元と初期化 *@
    protected override async Task OnInitializedAsync()
    {
        // 1. すべての状態の復元をサービスに委譲
        await SessionState.InitializeStateAsync();
        // 2. データベース（名簿マスター）の読み込み
        try
        {
            var dbData = await DatabaseService.GetAllDataAsync();
            if (dbData?.Players != null) playerMaster = dbData.Players;
        }
        catch
        {
            // 初回起動時などでDBが存在しない場合は空のまま
        }
        // 3. 画面表示用のプレイヤー名・IDマッピング（サービスからIndex側の一時変数へ）
        for (int i = 0; i < 7; i++)
        {
            string savedName = SessionState.CurrentPlayerNames[i];
            currentPlayers[i].Name = savedName;
            if (!string.IsNullOrEmpty(savedName))
            {
                var matched = playerMaster.FirstOrDefault(p => p.Name == savedName);
                if (matched != null) currentPlayers[i].Id = matched.Id;
            }
        }
        // 4. ルールプリセットの初期化（初回のみ）
        var savedPresets = await LocalStorage.GetItemAsync<List<RuleSet>>(StorageKeys.RulePresets);
        if (savedPresets == null || savedPresets.Count == 0)
        {
            // 初回起動時のデフォルトプリセット
            rulePresets = new List<RuleSet>
            {
                new RuleSet
                {
                    Name = "一般的な四麻",
                    PlayerCount = 4,
                    StartingPoints = 25000,
                    ReturnPoints = 30000,
                    Uma1 = 10,
                    Uma2 = 20
                },
                new RuleSet
                {
                    Name = "一般的な三麻",
                    PlayerCount = 3,
                    StartingPoints = 35000,
                    ReturnPoints = 40000,
                    Uma1 = 10,
                    Uma2 = 20
                },
                new RuleSet
                {
                    Name = "Mリーグルール",
                    PlayerCount = 4,
                    StartingPoints = 25000,
                    ReturnPoints = 30000,
                    Uma1 = 10,
                    Uma2 = 30,
                    Rate = 0,
                    ChipRate = 0,
                    TieBreaker = TieBreakerRule.Split
                }
            };
            await LocalStorage.SetItemAsync(StorageKeys.RulePresets, rulePresets);
        }
        else
        {
            rulePresets = savedPresets;
        }
        ResetInputForms();
        EvaluateAutoFill(); // 自動計算枠などを再評価
    }

    // 初回の描画（データバインド済みの状態）が完了した瞬間に、ローディング画面をフェードアウトさせる
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500);
            await JSRuntime.InvokeVoidAsync("hideMahjongLoader");
        }
    }

    @* 持ち点の処理 *@
    private void OnStartingPointsChanged(int val)
    {
        int currentOka = Math.Max(0, rules.ReturnPoints - rules.StartingPoints);
        rules.StartingPoints = val;
        rules.ReturnPoints = rules.StartingPoints + currentOka;
        EvaluateAutoFill();
    }

    @* 返し点の処理 *@
    private void OnReturnPointsChanged(int val)
    {
        rules.ReturnPoints = val;
        if (rules.ReturnPoints < rules.StartingPoints)
            rules.ReturnPoints = rules.StartingPoints;
    }

    // 通常のウマ設定(Uma1, Uma2)をCustomUmaに反映
    public void SyncNormalToCustomUma()
    {
        // カスタムウマモードがONのときは、ユーザーの手入力を上書きしないよう同期をスキップ
        if (rules.IsCustomUma) return;
        if (rules.PlayerCount == 4)
        {
            rules.CustomUma4_1 = rules.Uma2; // 1位ウマ
            rules.CustomUma4_2 = rules.Uma1; // 2位ウマ
            rules.CustomUma4_3 = -rules.Uma1; // 3位ウマ
            rules.CustomUma4_4 = -rules.Uma2; // 4位ウマ
        }
        else if (rules.PlayerCount == 3)
        {
            rules.CustomUma3_1 = rules.Uma1 + rules.Uma2; // 1位ウマ
            rules.CustomUma3_2 = -rules.Uma1; // 2位ウマ
            rules.CustomUma3_3 = -rules.Uma2; // 3位ウマ
        }
    }

    /// 現在の人数に応じたCustomUmaの値を取得
    public double[] GetCustomUmaArray()
    {
        if (rules.PlayerCount == 4)
        {
            return new double[] { rules.CustomUma4_1, rules.CustomUma4_2, rules.CustomUma4_3, rules.CustomUma4_4 };
        }
        else
        {
            return new double[] { rules.CustomUma3_1, rules.CustomUma3_2, rules.CustomUma3_3 };
        }
    }

    @* 最後の1人の素点自動入力（数式対応） *@
    private async Task HandleScoreStringInput(int index, string val)
    {
        int? parsedVal = EvaluateScoreExpression(val);
        if (parsedVal == null && currentScores[index] != null)
        {
            currentScores[index] = null;
            StateHasChanged();
            await Task.Yield();
        }
        if (index == autoFilledIndex && parsedVal != null)
            autoFilledIndex = null;
        currentScores[index] = parsedVal;
        EvaluateAutoFill();
    }

    @* 文字列の数式（+ / -）を計算して整数を返す *@
    private int? EvaluateScoreExpression(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        input = input.Replace(" ", "").Replace("　", "");
        try
        {
            int total = 0;
            string currentNumber = "";
            char currentOp = '+';
            for (int i = 0; i < input.Length; i++)
            {
                char c = input[i];
                if (c == '+' || c == '-')
                {
                    // 先頭が符号の場合の処理
                    if (string.IsNullOrEmpty(currentNumber))
                    {
                        currentOp = c == '-' && currentOp == '+' ? '-' : c;
                        continue;
                    }
                    int val = int.Parse(currentNumber);
                    total = currentOp == '+' ? total + val : total - val;
                    currentNumber = "";
                    currentOp = c;
                }
                else if (char.IsDigit(c))
                {
                    currentNumber += c;
                }
                else
                {
                    return null;
                }
            }
            // 最後の数字を加減
            if (!string.IsNullOrEmpty(currentNumber))
            {
                int val = int.Parse(currentNumber);
                total = currentOp == '+' ? total + val : total - val;
            }
            return total;
        }
        catch
        {
            return null; // パースに失敗した場合は空欄に戻す
        }
    }

    @* ユーザーの入力文字からサジェストを検索するメソッド *@
    private Task<IEnumerable<string>> SearchRegisteredPlayers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(playerMaster.Select(p => p.Name));
        var result = playerMaster
            .Where(p => p.Name.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(p => p.Name);
        return Task.FromResult(result);
    }

