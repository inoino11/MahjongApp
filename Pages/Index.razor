@page "/"
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<style>
    /* 素点入力欄の数字を右寄せにし、大きくはっきりと見せる */
    .score-input input {
        text-align: right !important;
        font-size: 1.3rem !important;
        font-weight: 500 !important;
        padding-right: 2px !important;
    }
    
    /* 外側に置く「00」のスタイル */
    .score-zeros {
        font-size: 1.3rem;
        font-weight: 500;
        color: #808080;
        margin-left: 2px;
        user-select: none;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-10" @onclick="CancelDelete">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6"
             Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        麻雀集計ツール</MudText>

        @* --- セクション1: 設定 (折りたたみ) --- *@
        <MudExpansionPanels Class="mb-6" @onclick:stopPropagation="true">
            <MudExpansionPanel Text="ルール・対局者設定" @bind-Expanded="isSettingsExpanded">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mb-4"
                           StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenPresetDialog">
                    保存済みの設定を呼び出し
                </MudButton>
                <MudGrid>
                    <MudItem xs="12" md="8" Class="d-flex">
                        <MudCard Outlined="true" Class="flex-grow-1">
                            <MudCardHeader Class="pb-0">
                                <CardHeaderContent>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold; white-space: nowrap;">ルール設定</MudText>
                                        
                                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.Settings" OnClick="OpenCustomRuleDialog">
                                                カスタム<span class="d-none d-sm-inline">ルール</span>
                                            </MudButton>
                                            
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.Save" OnClick="SavePreset">
                                                <span class="d-none d-sm-inline">現在の</span>設定保存
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-3 pt-1 mt-2">
                                <MudGrid Spacing="1">
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudSelect T="int" Label="対局人数" @bind-Value="rules.PlayerCount" Margin="Margin.Dense">
                                            <MudSelectItem Value="@(4)">四人麻雀</MudSelectItem>
                                            <MudSelectItem Value="@(3)">三人麻雀</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6" sm="8" Class="pr-3">
                                        <MudTextField Label="ルール名" @bind-Value="rules.Name" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudNumericField T="int" Label="持ち点" Value="rules.StartingPoints"
                                                         ValueChanged="OnStartingPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudNumericField T="int" Label="返し点" Value="rules.ReturnPoints"
                                                         ValueChanged="OnReturnPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudNumericField Label="レート(円/1k)" @bind-Value="rules.Rate" Step="10" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6" sm="4" Class="pr-3">
                                        <MudNumericField Label="チップ(円/枚)" @bind-Value="rules.ChipRate" Step="50" Min="0" Margin="Margin.Dense" />
                                    </MudItem>
                                    @if (rules.IsCustomUma)
                                    {
                                        @* カスタムON時: 幅を2つ分(xs="12" sm="8")使って1欄にまとめる *@
                                        <MudItem xs="12" sm="8">
                                            <MudTextField Label="カスタム順位ウマ" 
                                                          Value="@rules.GetUmaDisplayText(true)" ReadOnly="true" Margin="Margin.Dense"
                                                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Close" 
                                                          OnAdornmentClick="DisableCustomUma" 
                                                          Style="font-variant-numeric: tabular-nums;" />
                                        </MudItem>
                                    }
                                    else
                                    {
                                        @* カスタムOFF時: 通常の2欄(xs="6" sm="4"を2つ) *@
                                        <MudItem xs="6" sm="4" Class="pr-3">
                                            <MudNumericField Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←2)" : "順位ウマ(2←3)")"
                                                             @bind-Value="rules.Uma1" Step="5" Min="0" Margin="Margin.Dense" />
                                        </MudItem>
                                        <MudItem xs="6" sm="4" Class="pr-3">
                                            <MudNumericField Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←3)" : "順位ウマ(1←4)")"
                                                             @bind-Value="rules.Uma2" Step="5" Min="0" Margin="Margin.Dense" />
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="d-flex">
                        <MudCard Outlined="true" Class="flex-grow-1">
                            <MudCardHeader Class="pb-0">
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:bold;">対局者名</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-3 pt-1">
                                <MudStack Spacing="0">
                                    @for (int i = 0; i < 4; i++)
                                    {
                                        var index = i;
                                        <MudTextField Placeholder="@($"対局者 {index + 1}")" Value="currentPlayers[index]"
                                                      ValueChanged="@((string v) => OnPlayerNameChanged(index, v))"
                                                      Disabled="@(index >= rules.PlayerCount)" Margin="Margin.Dense" />
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @* --- セクション2: 素点入力 --- *@
        <MudPaper Class="pa-4 mb-6" Elevation="2" @onclick:stopPropagation="true">
            <MudStack Row="true" AlignItems="AlignItems.Baseline" Class="mb-2">
                @* タイトルに注記を追加 *@
                <MudText Typo="Typo.h6">素点入力 <span style="font-size: 0.8rem; color: gray;">(100点単位)</span></MudText>
            </MudStack>
            <MudGrid Spacing="1" AlignItems="AlignItems.Center">
                @for (int i = 0; i < rules.PlayerCount; i++)
                {
                    var index = i;
                    <MudItem xs="12" sm="6" Class="pa-2">
                        <MudPaper Outlined="true" Elevation="0" Class="d-flex align-center px-3 py-1" Style="background-color: rgba(255,255,255,0.02);">
                            
                            @* 左側：名前 *@
                            <MudText Typo="Typo.body1" Style="font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 40%;">
                                @(string.IsNullOrWhiteSpace(currentPlayers[index]) ? " " : currentPlayers[index])
                            </MudText>
                            
                            @* 中央：余白を自動で押し広げる *@
                            <MudSpacer /> 
                            
                            @* 右側：アイコン ＋ 点数入力 *@
                            <div class="d-flex align-center">
                                
                                @* 焼き鳥・トビのトグルボタン（点数の左側にスモールサイズで配置） *@
                                @if (rules.IsYakitoriEnabled)
                                {
                                    @* Titleの三項演算子は不要です（ToggledTitleと自動で切り替わるため） *@
                                    <MudToggleIconButton @bind-Toggled="currentYakitori[index]"
                                                         Icon="@Icons.Material.Filled.NoMeals" Color="Color.Default" Title="焼き鳥ではありません"
                                                         ToggledIcon="@YakitoriIcon" ToggledColor="Color.Warning" ToggledTitle="🍗 焼き鳥です" 
                                                         Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" />
                                }
                                @if (rules.IsTobiEnabled)
                                {
                                    <MudToggleIconButton @bind-Toggled="currentTobiBonus[index]"
                                                         Icon="@Icons.Material.Filled.Rocket" Color="Color.Default" Title="トビ賞を獲得しません"
                                                         ToggledIcon="@Icons.Material.Filled.RocketLaunch" ToggledColor="Color.Error" ToggledTitle="🚀 トビ賞を獲得します" 
                                                         Size="Size.Small" ToggledSize="Size.Small" Class="mr-2" />
                                }

                                @* 点数入力（幅を固定し、下線を消す） *@
                                <div class="d-flex align-baseline">
                                    <MudNumericField T="int?" Value="currentScores[index]" ValueChanged="@(v => OnScoreChanged(index, v))" 
                                                     HideSpinButtons="true" DisableUnderLine="true" 
                                                     Margin="Margin.Dense" Class="score-input" Style="width: 70px;" />
                                    <span class="score-zeros">00</span>
                                </div>
                                
                            </div>
                            
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Class="mt-4 py-3"
                       Disabled="@(!IsTotalCorrect)" OnClick="RecordGame">結果を記録する</MudButton>
        </MudPaper>

        @* --- セクション3: 集計結果 --- *@
        <MudPaper Class="pa-2 px-sm-4" Elevation="2" @onclick="CancelDelete">
            <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                      Class="mb-4 gap-2">
                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    <MudButton Variant="@(displayMode == 0 ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small" OnClick="() => displayMode = 0">素点</MudButton>
                    <MudButton Variant="@(displayMode == 1 ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small" OnClick="() => displayMode = 1">+/−</MudButton>
                    <MudButton Variant="@(displayMode == 2 ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small" OnClick="() => displayMode = 2">円</MudButton>
                    @if (rules.IsYakitoriEnabled)
                    {
                        <MudButton Variant="@(displayMode == 3 ? Variant.Filled : Variant.Outlined)" Color="Color.Warning" Size="Size.Small" OnClick="() => displayMode = 3">焼き鳥</MudButton>
                    }
                    @if (rules.IsTobiEnabled)
                    {
                        <MudButton Variant="@(displayMode == 4 ? Variant.Filled : Variant.Outlined)" Color="Color.Info" Size="Size.Small" OnClick="() => displayMode = 4">トビ</MudButton>
                    }
                </MudStack>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="ConfirmReset">記録リセット</MudButton>
            </MudStack>
            <MudCard Class="mb-4" Elevation="0" Outlined="true">
                <MudCardContent Class="pa-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">チップ集計</MudText>
                    <MudGrid Spacing="1">
                        @{
                            bool isChipError = ActiveSessionChips.Take(rules.PlayerCount).Sum() != 0;
                        }
                        @for (int i = 0; i < rules.PlayerCount; i++)
                        {
                            var idx = i;
                            <MudItem xs="3">
                                <MudNumericField T="int" Label="@(string.IsNullOrWhiteSpace(currentPlayers[idx]) ? " " : currentPlayers[idx])" Value="ActiveSessionChips[idx]"
                                                 ValueChanged="@(v => OnChipChanged(idx, v))" Step="1" HideSpinButtons="true"
                                                 Margin="Margin.Dense" Style="@(isChipError ? "color:#ff0000; font-weight:bold;" : "")" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <div style="width: 100%; overflow-x: hidden;">
                <MudTable Items="@ActiveHistory" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None"
                          Style="width: 100%; table-layout: fixed;">
                    <ColGroup>
                        <col style="width: 25px;" />
                        @for (int i = 0; i < rules.PlayerCount; i++)
                        {
                            <col />
                        }
                        <col style="width: 25px;" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh
                            Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.65rem; letter-spacing: -0.5px;">
                            時刻</MudTh>
                            @for (int i = 0; i < rules.PlayerCount; i++)
                            {
                                var idx = i;
                               <MudTh Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.75rem; letter-spacing: -0.5px;">
                                   @(string.IsNullOrWhiteSpace(currentPlayers[idx]) ? " " : currentPlayers[idx])
                               </MudTh>
                            }
                            <MudTh Style="padding: 4px 0px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd
                                Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.6rem; color: #666; letter-spacing: -0.5px;">
                                @context.Timestamp.ToString("HH:mm")
                            </MudTd>
                            @for (int i = 0; i < rules.PlayerCount; i++)
                            {
                                var idx = i;
                                <MudTd Style="text-align: center; padding: 4px 0px; white-space: nowrap;">
                                    <span style="@GetTdStyle(context, idx)">
                                        @GetDisplayValue(context, idx)
                                    </span>
                                </MudTd>
                            }
                            <MudTd Style="text-align: center; white-space: nowrap; padding: 4px 0px;">
                                <span @onclick="() => {}" @onclick:stopPropagation="true">
                                    <MudIconButton 
                                        Icon="@(armedDeleteTarget == context ? @DeleteEmpty : Icons.Material.Filled.Delete)" 
                                        Color="@(armedDeleteTarget == context ? Color.Error : Color.Default)" 
                                        Size="Size.Small"
                                        Style="@(armedDeleteTarget == context ? "padding: 0px;" : "padding: 0px; color: #9e9e9e;")" 
                                        OnClick="() => OnDeleteClicked(context)" />
                                </span>
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTd
                                Style="text-align: center; background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; font-weight: bold; white-space: nowrap; padding: 6px 0px; font-size: 0.75rem;">
                                <MudIcon
                                Icon="@(displayMode == 0 ? Icons.Material.Filled.Calculate : Icons.Material.Filled.Functions)"
                                Style="font-size: 1rem; vertical-align: text-bottom; margin-right: 2px; color: #2e7d32;" />
                                @(displayMode == 0 ? "平均" : "合計")
                            </MudTd>
                            @for (int i = 0; i < rules.PlayerCount; i++)
                            {
                                var idx = i;
                                <MudTd
                                    Style="@($"{GetTotalTdStyle(idx)} text-align: center; padding: 6px 0px; white-space: nowrap;")">
                                    <span style="@GetTotalSpanStyle(idx)">
                                        @GetTotalDisplayValue(idx)
                                    </span>
                                </MudTd>
                            }
                            <MudTd
                                Style="background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; padding: 6px 0px;">
                            </MudTd>
                        </FooterContent>
                    </MudTable>
                </div>
        </MudPaper>
        </MudContainer>

@code {
    private RuleSet rules = new();
    private List<RuleSet> rulePresets = new();
    private List<string> currentPlayers = new() { "Aさん", "Bさん", "Cさん", "Dさん" };
    private List<int?> currentScores = new() { null, null, null, null };
    private Dictionary<int, List<GameResult>> histories = new() { { 3, new() }, { 4, new() } };
    private Dictionary<int, List<int>> sessionChipsMap = new() { { 3, new() { 0, 0, 0 } }, { 4, new() { 0, 0, 0, 0 } } };
    private int displayMode = 1;
    private bool isSettingsExpanded = true;
    private List<GameResult> ActiveHistory => histories[rules.PlayerCount];
    private List<int> ActiveSessionChips => sessionChipsMap[rules.PlayerCount];
    private bool IsTotalCorrect => currentScores.Take(rules.PlayerCount).All(x => x.HasValue) &&
                                   currentScores.Take(rules.PlayerCount).Sum(x => x ?? 0) == (rules.StartingPoints * rules.PlayerCount) / 100;
    private List<bool> currentYakitori = new() { false, false, false, false };
    private List<bool> currentTobiBonus = new() { false, false, false, false };
    private const string YakitoriIcon = "<g transform=\"matrix(0.025, 0, 0, 0.025, 0, 24)\"><path d=\"M843-60 670-234l-85 85q-23 23-56.5 23T472-149l-57-56q-23-23-23-56.5t23-56.5l-56-57q-23 23-56.5 23T246-375l-57-56q-23-23-23-56.5t23-56.5l-56-57q-23-23-23-56.5t23-56.5l28-28L60-844l56-56 102 102 28-28q23-23 57-23t57 23l56 56q23-23 56.5-23t56.5 23l57 56q23 23 23 57t-23 57l56 56q23-23 56.5-23t56.5 23l57 56q23 23 23 57t-23 57l-85 84 172 173-56 57ZM529-205l227-226-57-57-227 227 57 56Zm-57-170 114-113-57-56-113 113 56 56Zm-170-56 227-227-57-56-226 226 56 57Zm-56-170 114-113-57-57-113 113 56 57Zm368 255ZM501-460ZM388-573ZM275-686Z\"/></g>";
    private const string DeleteEmpty = "<path d=\"M20.37,8.91L19.37,10.64L7.24,3.64L8.24,1.91L11.28,3.66L12.64,3.29L16.97,5.79L17.34,7.16L20.37,8.91M6,19V7H11.07L18,11V19A2,2 0 0,1 16,21H8A2,2 0 0,1 6,19Z\"/>";
    private int? armedDeleteIndex = null;
    private GameResult? armedDeleteTarget = null;
    
    protected override async Task OnInitializedAsync()
    {
        var savedRules = await LocalStorage.GetItemAsync<RuleSet>("rules");
        if (savedRules != null) rules = savedRules;
        var savedPlayers = await LocalStorage.GetItemAsync<List<string>>("currentPlayers");
        if (savedPlayers != null && savedPlayers.Count >= 4)
        {
            currentPlayers = savedPlayers;
        }
        var savedPresets = await LocalStorage.GetItemAsync<List<RuleSet>>("rulePresets");
        if (savedPresets != null) rulePresets = savedPresets;
        var dictHistories = await LocalStorage.GetItemAsync<Dictionary<int, List<GameResult>>>("histories_dict");
        if (dictHistories != null) histories = dictHistories;
        var dictChips = await LocalStorage.GetItemAsync<Dictionary<int, List<int>>>("sessionChips_dict");
        if (dictChips != null) sessionChipsMap = dictChips;
        if (!histories.ContainsKey(3)) histories[3] = new();
        if (!histories.ContainsKey(4)) histories[4] = new();
        if (!sessionChipsMap.ContainsKey(3)) sessionChipsMap[3] = new() { 0, 0, 0 };
        if (!sessionChipsMap.ContainsKey(4)) sessionChipsMap[4] = new() { 0, 0, 0, 0 };
        ResetCurrentScores();
    }

    private void ResetCurrentScores()
    {
        currentScores = Enumerable.Repeat((int?)null, 4).ToList();
        currentYakitori = new() { false, false, false, false };
        currentTobiBonus = new() { false, false, false, false };
    }

    private void OnStartingPointsChanged(int val)
    {
        int diff = val - rules.StartingPoints;
        if (Math.Abs(diff) == 5000) rules.StartingPoints = val;
        else rules.StartingPoints = val * 100;
    }

    private void OnReturnPointsChanged(int val)
    {
        int diff = val - rules.ReturnPoints;
        if (Math.Abs(diff) == 5000) rules.ReturnPoints = val;
        else rules.ReturnPoints = val * 100;
    }

    private void OnScoreChanged(int index, int? val)
    {
        currentScores[index] = val; // そのまま代入（250など）
        int pCount = rules.PlayerCount;
        var activeScores = currentScores.Take(pCount).ToList();
        var nullIndices = activeScores.Select((v, i) => new { v, i }).Where(x => !x.v.HasValue).Select(x => x.i).ToList();
        if (val.HasValue && nullIndices.Count == 1)
        {
            int lastIndex = nullIndices[0];
            int targetTotal = (rules.StartingPoints * pCount) / 100; // 100点単位での目標合計値
            int currentTotal = activeScores.Sum(x => x ?? 0);
            currentScores[lastIndex] = targetTotal - currentTotal;
        }
    }

    private void AdjustFractions(double[] points, List<int> orderedIndices)
    {
        double sum = points.Sum();
        double diff = Math.Round(0 - sum, 1); // ゼロサムからのズレ
        if (Math.Abs(diff) < 0.05) return; 
        int steps = (int)Math.Round(Math.Abs(diff) * 10);
        double adjustment = diff > 0 ? 0.1 : -0.1; // 足りないなら+0.1を配る、多すぎるなら-0.1を配る
        // マイナスを分配する場合は、下位から順に（逆順に）背負わせる
        var targetIndices = diff > 0 ? orderedIndices : Enumerable.Reverse(orderedIndices).ToList();
        for (int i = 0; i < steps; i++)
        {
            int targetIndex = targetIndices[i % targetIndices.Count];
            points[targetIndex] += adjustment;
            points[targetIndex] = Math.Round(points[targetIndex], 1); // 浮動小数点誤差の補正
        }
    }

    private void ValidateDisplayMode()
    {
        if (displayMode == 3 && !rules.IsYakitoriEnabled)
        {
            displayMode = 1;
        }
        if (displayMode == 4 && !rules.IsTobiEnabled)
        {
            displayMode = 1;
        }
    }

    private async Task OpenPresetDialog()
    {
        var parameters = new DialogParameters { ["Presets"] = rulePresets };
        var dialog = await DialogService.ShowAsync<PresetDialog>("保存済みの設定", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is RuleSet preset)
        {
            rules = preset.DeepClone();
            await LocalStorage.SetItemAsync("rules", rules);
            Snackbar.Add($"設定「{preset.Name}」を読み込みました", Severity.Success);
            ValidateDisplayMode();
            StateHasChanged();
        }
    }

    private async Task SavePreset()
    {
        rulePresets.RemoveAll(p => p.Name == rules.Name);
        var newPreset = rules.DeepClone();
        rulePresets.Add(newPreset);
        
        await LocalStorage.SetItemAsync("rulePresets", rulePresets);
        await LocalStorage.SetItemAsync("rules", rules);
        Snackbar.Add($"設定「{rules.Name}」を保存しました", Severity.Success);
    }

    private async Task DisableCustomUma()
    {
        rules.IsCustomUma = false;
        await LocalStorage.SetItemAsync("rules", rules);
        Snackbar.Add("順位ウマの個別設定を解除しました", Severity.Info);
        StateHasChanged();
    }

    private async Task ConfirmReset()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "記録のリセット",
            (MarkupString)$"{(rules.PlayerCount == 3 ? "三" : "四")}人麻雀の記録をリセットしますか？<br />（この操作は取り消せません）",
            yesText: "リセットする", cancelText: "キャンセル");
        if (result == true)
        {
            ActiveHistory.Clear();
            sessionChipsMap[rules.PlayerCount] = Enumerable.Repeat(0, rules.PlayerCount).ToList();
            await LocalStorage.SetItemAsync("histories_dict", histories);
            await LocalStorage.SetItemAsync("sessionChips_dict", sessionChipsMap);
            Snackbar.Add($"{(rules.PlayerCount == 3 ? "三" : "四")}人麻雀の記録をリセットしました", Severity.Info);
            StateHasChanged();
        }
    }

    private async Task OnDeleteClicked(GameResult item)
    {
        if (armedDeleteTarget == item)
        {
            ActiveHistory.Remove(item);
            armedDeleteTarget = null;
            await LocalStorage.SetItemAsync("histories_dict", histories);
        }
        else
        {
            armedDeleteTarget = item;
        }
    }

    private void CancelDelete()
    {
        if (armedDeleteTarget != null)
        {
            armedDeleteTarget = null;
            StateHasChanged();
        }
    }

