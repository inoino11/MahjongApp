    @* 直前の局の素点・焼き鳥・トビ賞を再現 *@
    private async Task CopyPreviousGame()
    {
        if (ActiveHistory.Count == 0) return;
        var lastGame = ActiveHistory.Last();
        int requiredCount = lastGame.RawScores.Count;
        if (activeParticipantCount < requiredCount && activeParticipantCount < MaxParticipants)
            await SessionState.SaveActiveParticipantCountAsync(Math.Min(requiredCount, MaxParticipants));
        for (int i = 0; i < activeParticipantCount; i++)
            if (i < lastGame.RawScores.Count)
            {
                scoreInputBuffers[i] = lastGame.RawScores[i]?.ToString() ?? string.Empty;
                if (lastGame.YakiPlayers != null && i < lastGame.YakiPlayers.Count) currentYaki[i] = lastGame.YakiPlayers[i];
                if (lastGame.TobiBonusRecipients != null && i < lastGame.TobiBonusRecipients.Count) currentTobiBonus[i] = lastGame.TobiBonusRecipients[i];
            }
        autoFilledIndex = null;
        EvaluateAutoFill();
        StateHasChanged();
        await SessionState.SaveScoreBuffersAsync(scoreInputBuffers);
    }

    // 表に表示する対局者リストを動的に構築するプロパティ
    private List<string> TablePlayers
    {
        get
        {
            // 0局目の時は、現在の入力欄の対局者（空欄含む）をそのまま仮ヘッダーとして表示
            if (ActiveHistory.Count == 0)
                return currentPlayers.Take(activeParticipantCount).Select(p => p.Name).ToList();
            // 1局目以降は、履歴から実際にスコアが記録されたユニークなプレイヤー名を抽出
            var players = new List<string>();
            foreach (var game in ActiveHistory)
                for (int i = 0; i < game.PlayerNames.Count; i++)
                    if (i < game.RawScores.Count && game.RawScores[i].HasValue)
                    {
                        var name = game.PlayerNames[i];
                        if (!string.IsNullOrWhiteSpace(name) && !players.Contains(name)) players.Add(name);
                    }
            return players;
        }
    }

    @* 素点入力欄を初期化 *@
    private void ResetInputForms()
    {
        previousScores = Enumerable.Repeat((int?)null, MaxParticipants).ToList();
        currentYaki = new(new bool[MaxParticipants]);
        currentTobiBonus = new(new bool[MaxParticipants]);
        currentSitOuts = new(new bool[MaxParticipants]);
        autoFilledIndex = null;
        scoreInputBuffers = Enumerable.Repeat(string.Empty, MaxParticipants).ToArray();
    }

    @* 特殊ルールOFF時のスコア表示モード切替 *@
    private void ValidateDisplayMode()
    {
        displayMode = displayMode switch
        {
            3 when !rules.IsSinkEnabled => 1,
            4 when !rules.IsYakiEnabled => 1,
            5 when !rules.IsTobiEnabled => 1,
            6 when !rules.IsColdEnabled => 1,
            _ => displayMode
        };
    }

    @* 席順入力 *@
    private async Task<Dictionary<int, int>?> OpenTieBreakerIfNeeded(List<int> scores, List<string> players)
    {
        var priority = new Dictionary<int, int>();
        // 全員の点数がバラバラならダイアログは不要
        if (scores.Distinct().Count() == scores.Count)
        {
            for (int i = 0; i < scores.Count; i++) priority[i] = i;
            return priority;
        }
        var parameters = new DialogParameters { ["Players"] = players };
        var dialog = await DialogService.ShowAsync<TieBreakerDialog>("順位の決定", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not List<int> orderedIndices) return null;
        for (int i = 0; i < scores.Count; i++) priority[i] = orderedIndices.IndexOf(i);
        return priority;
    }

