    @* 直前の局の素点・焼き鳥・トビ賞を再現 *@
    private async Task CopyPreviousGame()
    {
        if (ActiveHistory.Count == 0) return;
        var lastGame = ActiveHistory.Last();
        // コピー対象の人数に応じて、足りない場合は「枠を追加」する
        int requiredCount = lastGame.RawScores.Count;
        while (activeParticipantCount < requiredCount && activeParticipantCount < MaxParticipants)
        {
            activeParticipantCount++;
            await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
        }
        for (int i = 0; i < activeParticipantCount; i++)
            if (i < lastGame.RawScores.Count)
            {
                currentScores[i] = lastGame.RawScores[i];
                if (lastGame.YakiPlayers != null && i < lastGame.YakiPlayers.Count)
                    currentYaki[i] = lastGame.YakiPlayers[i];
                if (lastGame.TobiBonusRecipients != null && i < lastGame.TobiBonusRecipients.Count)
                    currentTobiBonus[i] = lastGame.TobiBonusRecipients[i];
            }
        autoFilledIndex = null;
        EvaluateAutoFill();
        StateHasChanged();
    }

    @* 結果表示人数を求める *@
    private int TableParticipantCount
    {
        get
        {
            int maxDataIndex = -1;
            foreach (var game in ActiveHistory)
                for (int i = 0; i < game.RawScores.Count; i++)
                    if (game.RawScores[i].HasValue && i > maxDataIndex) maxDataIndex = i;
            return Math.Max(activeParticipantCount, maxDataIndex + 1);
        }
    }

