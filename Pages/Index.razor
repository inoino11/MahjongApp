    @* ローカルストレージからのデータ復元と初期化 *@
    protected override async Task OnInitializedAsync()
    {
        var savedRules = await LocalStorage.GetItemAsync<RuleSet>("rules");
        if (savedRules != null) rules = savedRules;
        var savedPlayers = await LocalStorage.GetItemAsync<List<string>>("currentPlayers");
        if (savedPlayers != null)
        {
            for (int i = 0; i < savedPlayers.Count && i < MaxParticipants; i++)
            {
                currentPlayers[i] = savedPlayers[i];
            }
        }
        var savedActiveCount = await LocalStorage.GetItemAsync<int?>("activeParticipantCount");
        activeParticipantCount = savedActiveCount ?? rules.PlayerCount;
        var savedPresets = await LocalStorage.GetItemAsync<List<RuleSet>>("rulePresets");
        if (savedPresets != null) rulePresets = savedPresets;
        var dictHistories = await LocalStorage.GetItemAsync<Dictionary<int, List<GameResult>>>("histories_dict");
        if (dictHistories != null) histories = dictHistories;
        var dictChips = await LocalStorage.GetItemAsync<Dictionary<int, List<int>>>("sessionChips_dict");
        if (dictChips != null)
        {
            sessionChipsMap = dictChips;
            foreach (var key in sessionChipsMap.Keys.ToList())
            {
                while (sessionChipsMap[key].Count < MaxParticipants)
                {
                    sessionChipsMap[key].Add(0);
                }
            }
        }
        if (!histories.ContainsKey(3)) histories[3] = new();
        if (!histories.ContainsKey(4)) histories[4] = new();
        if (!sessionChipsMap.ContainsKey(3)) sessionChipsMap[3] = new int[MaxParticipants].ToList();
        if (!sessionChipsMap.ContainsKey(4)) sessionChipsMap[4] = new int[MaxParticipants].ToList();
        ResetInputForms();
    }

    @* 持ち点の100倍処理 *@
    private void OnStartingPointsChanged(int val)
    {
        int diff = val - rules.StartingPoints;
        if (Math.Abs(diff) == 5000) rules.StartingPoints = val;
        else rules.StartingPoints = val * 100;
    }

    @* 返し点の100倍処理 *@
    private void OnReturnPointsChanged(int val)
    {
        int diff = val - rules.ReturnPoints;
        if (Math.Abs(diff) == 5000) rules.ReturnPoints = val;
        else rules.ReturnPoints = val * 100;
    }

    @* 最後の1人の素点自動入力 *@
    private void HandleScoreInputWithAutoFill(int index, int? val)
    {
        currentScores[index] = val;

        // 表示されている参加者のうち、抜け番アイコンがOFFの人だけを抽出
        var activeIndices = Enumerable.Range(0, activeParticipantCount)
         .Where(i => !currentSitOuts[i])
         .ToList();

        // 自動計算の発動条件:
        // 1. 抜け番以外のアクティブな人数が、ルール上の対局人数（3 or 4）と正確に一致していること
        // 2. その中で空欄が「残り1人」であること
        if (activeIndices.Count == rules.PlayerCount)
        {
            var nullIndices = activeIndices.Where(i => !currentScores[i].HasValue).ToList();
            if (nullIndices.Count == 1)
            {
                int lastIndex = nullIndices[0];
                int targetTotal = (rules.StartingPoints * rules.PlayerCount) / 100;
                int currentTotal = activeIndices.Where(i => i != lastIndex).Sum(i => currentScores[i] ?? 0);
                currentScores[lastIndex] = targetTotal - currentTotal;
            }
        }
    }

