    @* 各局の結果を保存 *@
    private async Task CalculateAndRecordGame()
    {
        // 抜け番ではないプレイヤーのインデックスを抽出
        int pCount = rules.PlayerCount;
        var activeIndices = Enumerable.Range(0, activeParticipantCount).Where(i => !currentSitOuts[i]).ToList();
        if (activeIndices.Count != pCount) return;
        // 計算用の抽出配列
        var activeScores = activeIndices.Select(i => (currentScores[i] ?? 0) * 100).ToList();
        var activePlayers = activeIndices.Select(i => currentPlayers[i].Name).ToList();
        var activeYaki = activeIndices.Select(i => currentYaki[i]).ToList();
        var activeTobiBonus = activeIndices.Select(i => currentTobiBonus[i]).ToList();
        // 名無しチェック
        if (activePlayers.Any(string.IsNullOrWhiteSpace))
        {
            Snackbar.Add("対局者の名前を入力してください", Severity.Error);
            return;
        }
        // 同名チェック
        if (activePlayers.Distinct().Count() != activePlayers.Count)
        {
            Snackbar.Add("対局者の中に同じ名前があります", Severity.Error);
            return;
        }
        // 削除済みチェック
        if (activePlayers.Any(name => name == "削除済み"))
        {
            Snackbar.Add("名前「削除済み」は使用できません", Severity.Error);
            return;
        }
        // 簡易入力ミスチェック
        if (rules.IsTobiEnabled)
        {
            bool hasTobi = activeScores.Any(s => rules.TobiJustIsTobi ? s <= rules.TobiPoint : s < rules.TobiPoint);
            bool hasTobiBonus = activeTobiBonus.Any(b => b);
            if (hasTobi != hasTobiBonus)
            {
                string msg = hasTobi
                ? "トビが発生していますが\nボーナス獲得者（🚀）が選択されていません"
                : "トビが発生していないのに\nボーナス獲得者（🚀）が選択されています";
                Snackbar.Add(msg, Severity.Error);
                return;
            }
        }
        // オカ・順位ウマのベースポイント算出
        double[] baseUmaOka = new double[pCount];
        double oka = (rules.ReturnPoints - rules.StartingPoints) * pCount / 1000.0;
        baseUmaOka[0] += oka; // 1位にオカを加算
        double[] umaArray = GetCustomUmaArray();
        for (int rank = 0; rank < pCount; rank++)
            baseUmaOka[rank] += umaArray[rank];
        // 各個人の素点と端数処理
        double[] points = new double[pCount];
        double totalPts = 0;
        for (int i = 0; i < pCount; i++)
        {
            double rawPt = (activeScores[i] - rules.ReturnPoints) / 1000.0;
            points[i] = ApplyRounding(rawPt, rules.Rounding);
            totalPts += points[i];
        }
        int fractionsToAdjust = (int)Math.Round(-(totalPts + oka) * 10);
        // 同着グループの分析と「席順入力ダイアログ」の要否判定
        var groupedScores = activeScores.Select((score, index) => new { score, index })
        .GroupBy(x => x.score)
        .OrderByDescending(g => g.Key)
        .ToList();
        bool needsTieBreaker = false;
        if (groupedScores.Any(g => g.Count() > 1))
        {
            if (rules.TieBreaker == TieBreakerRule.Kamicha)
            {
                needsTieBreaker = true;
            }
            else
            {
                int currentRank = 0;
                foreach (var group in groupedScores)
                {
                    int count = group.Count();
                    if (count > 1)
                    {
                        if (fractionsToAdjust > currentRank && fractionsToAdjust < currentRank + count) needsTieBreaker = true;

                        double sumUmaOka = 0;
                        for (int i = 0; i < count; i++) sumUmaOka += baseUmaOka[currentRank + i];
                        double splitBase = Math.Floor(sumUmaOka / count * 10) / 10.0;
                        double remainder = Math.Round(sumUmaOka - (splitBase * count), 1);
                        if (remainder > 0) needsTieBreaker = true;
                    }
                    currentRank += count;
                }
                if (!needsTieBreaker)
                {
                    int topCount = groupedScores.First().Count();
                    if (topCount > 1)
                    {
                        if (rules.IsSinkEnabled && rules.SinkUmaDistribution == PenaltyDistribution.WinnerTakeAll)
                        {
                            int borderPoint = rules.IsSinkBaseCustom ? rules.SinkUmaBasePoint : rules.StartingPoints;
                            int shizumiCount = activeScores.Count(s => rules.SinkJustIsUki ? s < borderPoint : s <= borderPoint);
                            if (shizumiCount > 0 && shizumiCount < pCount && (shizumiCount * rules.SinkUmaPenalty * 10) % topCount != 0)
                                needsTieBreaker = true;
                        }
                        if (!needsTieBreaker && rules.IsYakiEnabled && rules.YakiDistribution == PenaltyDistribution.WinnerTakeAll)
                        {
                            int yakiCount = activeYaki.Count(y => y);
                            if (yakiCount > 0 && yakiCount < pCount && (yakiCount * rules.YakiPenalty * 10) % topCount != 0)
                                needsTieBreaker = true;
                        }
                    }
                }
            }
        }
        // 席順入力ダイアログ
        Dictionary<int, int>? priority = needsTieBreaker
        ? await OpenTieBreakerIfNeeded(activeScores, activePlayers)
        : Enumerable.Range(0, pCount).ToDictionary(i => i, i => i);
        if (priority == null) return;
        var rankedIndices = activeScores.Select((score, index) => new { score, index })
        .OrderByDescending(x => x.score)
        .ThenBy(x => priority[x.index])
        .Select(x => x.index)
        .ToList();
        int currentR = 0;
        while (currentR < pCount)
        {
            int score = activeScores[rankedIndices[currentR]];
            int tieCount = 1;
            for (int i = currentR + 1; i < pCount; i++)
            {
                if (activeScores[rankedIndices[i]] == score) tieCount++;
                else break;
            }
            if (rules.TieBreaker == TieBreakerRule.Split && tieCount > 1)
            {
                double sumUmaOka = 0;
                for (int i = 0; i < tieCount; i++) sumUmaOka += baseUmaOka[currentR + i];
                double splitBase = Math.Floor(sumUmaOka / tieCount * 10) / 10.0;
                double remainder = Math.Round(sumUmaOka - (splitBase * tieCount), 1);
                int remainderUnits = (int)Math.Round(remainder * 10);
                for (int i = 0; i < tieCount; i++)
                {
                    double addPt = splitBase + (i < remainderUnits ? 0.1 : 0);
                    points[rankedIndices[currentR + i]] += addPt;
                }
            }
            else
            {
                for (int i = 0; i < tieCount; i++) points[rankedIndices[currentR + i]] += baseUmaOka[currentR + i];
            }
            currentR += tieCount;
        }
        AdjustFractions(points, rankedIndices);
        // 沈みウマ
        double[] preSinkPts = points.ToArray();
        if (rules.IsSinkEnabled)
        {
            int borderPoint = rules.IsSinkBaseCustom ? rules.SinkUmaBasePoint : rules.StartingPoints;
            var ukiIndices = new List<int>();
            var shizumiIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                bool isUki = rules.SinkJustIsUki ? activeScores[i] >= borderPoint : activeScores[i] > borderPoint;
                if (isUki) ukiIndices.Add(i); else shizumiIndices.Add(i);
            }
            if (shizumiIndices.Count > 0 && ukiIndices.Count > 0)
            {
                int totalPenalty = shizumiIndices.Count * rules.SinkUmaPenalty;
                foreach (var i in shizumiIndices) points[i] -= rules.SinkUmaPenalty;
                if (rules.SinkUmaDistribution == PenaltyDistribution.WinnerTakeAll)
                {
                    int topScore = activeScores[rankedIndices[0]];
                    int topCount = 1;
                    for (int i = 1; i < pCount; i++)
                    {
                        if (activeScores[rankedIndices[i]] == topScore) topCount++;
                        else break;
                    }
                    if (rules.TieBreaker == TieBreakerRule.Split && topCount > 1)
                    {
                        double splitBase = Math.Floor((double)totalPenalty / topCount * 10) / 10.0;
                        double remainder = Math.Round(totalPenalty - (splitBase * topCount), 1);
                        int remainderUnits = (int)Math.Round(remainder * 10);
                        for (int i = 0; i < topCount; i++) points[rankedIndices[i]] += splitBase + (i < remainderUnits ? 0.1 : 0);
                        AdjustFractions(points, rankedIndices);
                    }
                    else points[rankedIndices[0]] += totalPenalty;
                }
                else
                {
                    double splitBase = Math.Floor((double)totalPenalty / ukiIndices.Count * 10) / 10.0;
                    double remainder = Math.Round(totalPenalty - (splitBase * ukiIndices.Count), 1);
                    int remainderUnits = (int)Math.Round(remainder * 10);
                    var orderedUki = rankedIndices.Where(idx => ukiIndices.Contains(idx)).ToList();
                    for (int j = 0; j < orderedUki.Count; j++) points[orderedUki[j]] += splitBase + (j < remainderUnits ? 0.1 : 0);
                }
            }
        }
        var currentSinkPts = points.Select((p, i) => Math.Round(p - preSinkPts[i], 1)).ToList();
        // 焼き鳥
        double[] preYakiPts = points.ToArray();
        if (rules.IsYakiEnabled)
        {
            var yakiIndices = new List<int>();
            var safeIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                if (activeYaki[i]) yakiIndices.Add(i); else safeIndices.Add(i);
            }
            if (yakiIndices.Count > 0 && yakiIndices.Count < pCount)
            {
                int totalPenalty = yakiIndices.Count * rules.YakiPenalty;
                foreach (var i in yakiIndices) points[i] -= rules.YakiPenalty;
                if (rules.YakiDistribution == PenaltyDistribution.WinnerTakeAll)
                {
                    int topScore = activeScores[rankedIndices[0]];
                    int topCount = 1;
                    for (int i = 1; i < pCount; i++)
                    {
                        if (activeScores[rankedIndices[i]] == topScore) topCount++;
                        else break;
                    }
                    if (rules.TieBreaker == TieBreakerRule.Split && topCount > 1)
                    {
                        double splitBase = Math.Floor((double)totalPenalty / topCount * 10) / 10.0;
                        double remainder = Math.Round(totalPenalty - (splitBase * topCount), 1);
                        int remainderUnits = (int)Math.Round(remainder * 10);
                        for (int i = 0; i < topCount; i++) points[rankedIndices[i]] += splitBase + (i < remainderUnits ? 0.1 : 0);
                        AdjustFractions(points, rankedIndices);
                    }
                    else points[rankedIndices[0]] += totalPenalty;
                }
                else
                {
                    double splitBase = Math.Floor((double)totalPenalty / safeIndices.Count * 10) / 10.0;
                    double remainder = Math.Round(totalPenalty - (splitBase * safeIndices.Count), 1);
                    int remainderUnits = (int)Math.Round(remainder * 10);
                    var orderedSafe = rankedIndices.Where(idx => safeIndices.Contains(idx)).ToList();
                    for (int j = 0; j < orderedSafe.Count; j++) points[orderedSafe[j]] += splitBase + (j < remainderUnits ? 0.1 : 0);
                }
            }
        }
        var yakiPts = points.Select((p, i) => Math.Round(p - preYakiPts[i], 1)).ToList();
        // トビ
        double[] preTobiPts = points.ToArray();
        if (rules.IsTobiEnabled)
        {
            var tobiIndices = new List<int>();
            var bonusIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                if (rules.TobiJustIsTobi ? activeScores[i] <= rules.TobiPoint : activeScores[i] < rules.TobiPoint) tobiIndices.Add(i);
                if (activeTobiBonus[i]) bonusIndices.Add(i);
            }
            if (tobiIndices.Count > 0 && bonusIndices.Count > 0)
            {
                int totalPenalty = tobiIndices.Count * rules.TobiPenalty;
                foreach (var i in tobiIndices) points[i] -= rules.TobiPenalty;

                double splitBase = Math.Floor((double)totalPenalty / bonusIndices.Count * 10) / 10.0;
                double remainder = Math.Round(totalPenalty - (splitBase * bonusIndices.Count), 1);
                int remainderUnits = (int)Math.Round(remainder * 10);
                var orderedBonus = rankedIndices.Where(idx => bonusIndices.Contains(idx)).ToList();
                for (int j = 0; j < orderedBonus.Count; j++) points[orderedBonus[j]] += splitBase + (j < remainderUnits ? 0.1 : 0);
            }
        }
        var tobiPts = points.Select((p, i) => Math.Round(p - preTobiPts[i], 1)).ToList();
        // コールド
        double[] preColdPts = points.ToArray();
        if (rules.IsColdEnabled)
        {
            var coldIndices = new List<int>();
            var nonColdIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                if (rules.ColdJustIsCold ? activeScores[i] >= rules.ColdPoint : activeScores[i] > rules.ColdPoint) coldIndices.Add(i);
                else nonColdIndices.Add(i);
            }
            if (coldIndices.Count > 0 && nonColdIndices.Count > 0)
            {
                int bonusPerColdPlayer = nonColdIndices.Count * rules.ColdBonus;
                int penaltyPerNonColdPlayer = coldIndices.Count * rules.ColdBonus;
                foreach (var i in coldIndices) points[i] += bonusPerColdPlayer;
                foreach (var i in nonColdIndices) points[i] -= penaltyPerNonColdPlayer;
            }
        }
        var currentColdPts = points.Select((p, i) => Math.Round(p - preColdPts[i], 1)).ToList();
        // 円算出
        double[] exactYen = new double[pCount];
        int[] baseYen = new int[pCount];
        double[] fractions = new double[pCount];
        int totalBaseYen = 0;
        for (int i = 0; i < pCount; i++)
        {
            exactYen[i] = points[i] * rules.Rate;
            baseYen[i] = (int)Math.Floor(exactYen[i]);
            fractions[i] = exactYen[i] - baseYen[i];
            totalBaseYen += baseYen[i];
        }
        int shortage = 0 - totalBaseYen;
        var yenDistributionOrder = Enumerable.Range(0, pCount)
        .OrderByDescending(i => fractions[i])
        .ThenBy(i => rankedIndices.IndexOf(i))
        .ToList();
        for (int i = 0; i < shortage; i++) baseYen[yenDistributionOrder[i]] += 1;
        // 結果を「元の参加枠インデックス」へマッピングして保存
        List<int?> finalRawScores = Enumerable.Repeat((int?)null, activeParticipantCount).ToList();
        List<double> finalPoints = Enumerable.Repeat(0.0, activeParticipantCount).ToList();
        List<double> finalSinkPts = Enumerable.Repeat(0.0, activeParticipantCount).ToList();
        List<double> finalYakiPts = Enumerable.Repeat(0.0, activeParticipantCount).ToList();
        List<double> finalTobiPts = Enumerable.Repeat(0.0, activeParticipantCount).ToList();
        List<double> finalColdPts = Enumerable.Repeat(0.0, activeParticipantCount).ToList();
        List<int> finalYen = Enumerable.Repeat(0, activeParticipantCount).ToList();
        List<bool> finalTobiPlayers = Enumerable.Repeat(false, activeParticipantCount).ToList();
        for (int i = 0; i < pCount; i++)
        {
            int originalIdx = activeIndices[i];
            finalRawScores[originalIdx] = currentScores[originalIdx];
            finalPoints[originalIdx] = points[i];
            finalSinkPts[originalIdx] = currentSinkPts[i];
            finalYakiPts[originalIdx] = yakiPts[i];
            finalTobiPts[originalIdx] = tobiPts[i];
            finalColdPts[originalIdx] = currentColdPts[i];
            finalYen[originalIdx] = baseYen[i];
            finalTobiPlayers[originalIdx] = rules.TobiJustIsTobi ? activeScores[i] <= rules.TobiPoint : activeScores[i] < rules.TobiPoint;
        }
        ActiveHistory.Add(new GameResult
        {
            Timestamp = DateTime.Now,
            PlayerNames = currentPlayers.Take(activeParticipantCount).Select(p => p.Name).ToList(),
            RawScores = finalRawScores,
            Points = finalPoints,
            YakiPlayers = currentYaki.Take(activeParticipantCount).ToList(),
            TobiPlayers = finalTobiPlayers,
            TobiBonusRecipients = currentTobiBonus.Take(activeParticipantCount).ToList(),
            SinkPoints = finalSinkPts,
            YakiPoints = finalYakiPts,
            TobiPoints = finalTobiPts,
            ColdPoints = finalColdPts,
            Yen = finalYen
        });
        // ローカルストレージに保存
        await LocalStorage.SetItemAsync("ActiveHistory", ActiveHistory);
        await LocalStorage.SetItemAsync(StorageKeys.Rules, rules);
        ResetInputForms();
        armedDeleteIndex = null;
        await LocalStorage.SetItemAsync("ActiveSessionChips", ActiveSessionChips);
        await LocalStorage.RemoveItemAsync("backup_score_buffers");
    }

    @* 全スコアリセット *@
    private async Task ConfirmReset()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "記録のリセット",
            (MarkupString)$"現在の記録とチップをすべてリセットしますか？<br />（この操作は取り消せません）",
            yesText: "リセットする", cancelText: "キャンセル");
        if (result == true)
        {
            ActiveHistory.Clear();
            ActiveSessionChips.Clear();
            await LocalStorage.SetItemAsync("ActiveHistory", ActiveHistory);
            await LocalStorage.SetItemAsync("ActiveSessionChips", ActiveSessionChips);
            Snackbar.Add("記録をリセットしました", Severity.Info);
            StateHasChanged();
        }
    }

    @* 各局のスコア消去 *@
    private async Task HandleDeleteRequest(GameResult item)
    {
        if (armedDeleteTarget == item)
        {
            ActiveHistory.Remove(item);
            armedDeleteTarget = null;
            await LocalStorage.SetItemAsync("ActiveHistory", ActiveHistory);
        }
        else
        {
            armedDeleteTarget = item;
        }
    }

    @* 各局のスコア消去待機状態解除 *@
    private void CancelDelete()
    {
        if (armedDeleteTarget != null)
        {
            armedDeleteTarget = null;
            StateHasChanged();
        }
    }

    @* 直前の局の素点・焼き鳥・トビ賞を再現 *@
    private async Task CopyPreviousGame()
    {
        if (ActiveHistory.Count == 0) return;
        var lastGame = ActiveHistory.Last();
        int requiredCount = lastGame.RawScores.Count;
        while (activeParticipantCount < requiredCount && activeParticipantCount < MaxParticipants)
        {
            activeParticipantCount++;
            await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
        }
        for (int i = 0; i < activeParticipantCount; i++)
        {
            if (i < lastGame.RawScores.Count)
            {
                scoreInputBuffers[i] = lastGame.RawScores[i]?.ToString() ?? string.Empty;
                if (lastGame.YakiPlayers != null && i < lastGame.YakiPlayers.Count) currentYaki[i] = lastGame.YakiPlayers[i];
                if (lastGame.TobiBonusRecipients != null && i < lastGame.TobiBonusRecipients.Count) currentTobiBonus[i] = lastGame.TobiBonusRecipients[i];
            }
        }
        autoFilledIndex = null;
        EvaluateAutoFill();
        StateHasChanged();
        await LocalStorage.SetItemAsync("backup_score_buffers", scoreInputBuffers);
    }

    // 表に表示する対局者リストを動的に構築するプロパティ
    private List<string> TablePlayers
    {
        get
        {
            // 0局目の時は、現在の入力欄の対局者（空欄含む）をそのまま仮ヘッダーとして表示
            if (ActiveHistory.Count == 0)
                return currentPlayers.Take(activeParticipantCount).Select(p => p.Name).ToList();
            // 1局目以降は、履歴から実際にスコアが記録されたユニークなプレイヤー名を抽出
            var players = new List<string>();
            foreach (var game in ActiveHistory)
                for (int i = 0; i < game.PlayerNames.Count; i++)
                    if (i < game.RawScores.Count && game.RawScores[i].HasValue)
                    {
                        var name = game.PlayerNames[i];
                        if (!string.IsNullOrWhiteSpace(name) && !players.Contains(name)) players.Add(name);
                    }
            return players;
        }
    }

    @* 結果共有画像を生成 *@
    private async Task ShareImageAsync()
    {
        isSharing = true;
        StateHasChanged();
