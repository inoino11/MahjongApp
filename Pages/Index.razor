@page "/"
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject MahjongApp.Services.DatabaseService DatabaseService

@* 素点入力欄のスタイル *@
<style>
    /* 名前入力欄 */
    .player-name-input input {
        text-align: center !important;
        letter-spacing: 1px;
    }

    /* フォーカスされていない時は下線を極限まで薄くする */
    .player-name-input:not(:focus-within) {
        opacity: 0.85;
    }

    .score-input input {
        text-align: right !important;
        font-size: 1.3rem !important;
        font-weight: 500 !important;
        padding-right: 2px !important;
    }

    .score-input.auto-filled input {
        color: var(--mud-palette-info) !important;
    }

    .score-input.mud-input-control .mud-input-outlined {
        height: 28px !important;
        min-height: 28px !important;
    }

    .score-input.mud-input-control .mud-input-outlined .mud-input-adornment-start {
        margin: 0 !important;
    }

    .score-input.mud-input-control .mud-input-outlined .mud-input-adornment-start svg {
        font-size: 16px !important;
    }

    .score-zeros {
        font-size: 1.3rem;
        font-weight: 500;
        color: #808080;
        margin-left: 2px;
        user-select: none;
    }

    /* 自動入力アイコン追加時に文字が上に浮く現象を修正 */
    .score-input .mud-input {
        align-items: baseline !important;
    }

    /* アイコン自体は高さの中央を維持する */
    .score-input .mud-input-adornment-start {
        align-self: center !important;
        margin-top: 0 !important;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-10" @onclick="CancelDelete">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        麻雀集計ツール
    </MudText>

    @* --- セクション1: 設定 (折りたたみ可) --- *@
    <MudExpansionPanels Class="mb-6" @onclick:stopPropagation="true">
        <MudExpansionPanel Text="ルール設定" Style="font-weight:bold; white-space: nowrap;" @bind-Expanded="isSettingsExpanded">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mb-4" StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenPresetDialog">
                保存済みの設定を呼び出し
            </MudButton>
            <MudCard Outlined="true" Class="w-100">
                <MudCardHeader Class="pb-0">
                    <CardHeaderContent>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Settings" OnClick="OpenCustomRuleDialog">
                                    カスタム<span class="d-none d-sm-inline">ルール</span>
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="SavePreset">
                                    <span class="d-none d-sm-inline">現在の</span>設定保存
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-2 pa-sm-3 pt-1 mt-2">
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="8">
                            <MudTextField Label="ルール名" @bind-Value="rules.Name" Margin="Margin.Dense" onfocus="this.select();" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudSelect T="int" Label="対局人数" Value="rules.PlayerCount" ValueChanged="OnPlayerCountChanged" Margin="Margin.Dense">
                                <MudSelectItem Value="@(4)">四人麻雀</MudSelectItem>
                                <MudSelectItem Value="@(3)">三人麻雀</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="int" Label="持ち点" Value="rules.StartingPoints" ValueChanged="OnStartingPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="int" Label="返し点" Value="rules.ReturnPoints" ValueChanged="OnReturnPointsChanged" Step="5000" Min="0" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField Label="レート(円/1k)" @bind-Value="rules.Rate" Step="10" Min="0" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField Label="チップ(円/枚)" @bind-Value="rules.ChipRate" Step="50" Min="0" Margin="Margin.Dense" />
                        </MudItem>
                        @if (rules.IsCustomUma)
                        {
                            <MudItem xs="12" sm="8">
                                <MudTextField Label="カスタム順位ウマ" Value="@rules.GetUmaDisplayText(true)" ReadOnly="true" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Close" OnAdornmentClick="DisableCustomUma" Style="font-variant-numeric: tabular-nums;" />
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="6" sm="4">
                                <MudNumericField T="int" Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←2)" : "順位ウマ(2←3)")" Value="rules.Uma1" ValueChanged="@((int v) => { rules.Uma1 = v; SyncNormalToCustomUma(); })" Step="5" Min="0" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="6" sm="4">
                                <MudNumericField T="int" Label="@(rules.PlayerCount == 3 ? "順位ウマ(1←3)" : "順位ウマ(1←4)")" Value="rules.Uma2" ValueChanged="@((int v) => { rules.Uma2 = v; SyncNormalToCustomUma(); })" Step="5" Min="0" Margin="Margin.Dense" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* --- セクション2: 対局者＆素点入力 --- *@
    <MudPaper Class="pa-2 pa-sm-4 mb-6" Elevation="2" @onclick:stopPropagation="true">
        <div class="mb-3 px-1">
            <MudText Style="font-weight: bold;" Class="mb-1">素点入力</MudText>

            @* ▼ デバッグ用：登録プレイヤー名簿のリアルタイム表示エリア ▼ *@
            @* <div style="background-color: rgba(255, 255, 0, 0.05); border: 1px dashed #ffc107; padding: 8px; border-radius: 4px; margin-bottom: 12px; font-size: 0.85rem;">
                <div style="color: #ffc107; font-weight: bold; margin-bottom: 4px;">🛠 デバッグ: 登録済みプレイヤー名簿</div>
                <div>現在のマスター件数: <strong>@playerMaster.Count</strong> 件</div>
                @if (playerMaster.Count == 0)
                {
                    <div style="color: #aaa; font-style: italic;">（登録されているプレイヤーはまだありません。一度セッションを保存すると登録されます）</div>
                }
                else
                {
                    <ul style="margin: 4px 0 0 0; padding-left: 20px; color: #e0e0e0;">
                        @foreach (var p in playerMaster)
                        {
                            <li>名前: <strong style="color: #4caf50;">@p.Name</strong> (ID: @p.Id, チップ累計: @p.CumulativeChips 枚)</li>
                        }
                    </ul>
                }
            </div> *@
            @* ▲ デバッグ用エリア ここまで ▲ *@

            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%; overflow: hidden;">
                <div class="d-flex align-center">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddParticipant" Disabled="@(activeParticipantCount >= MaxParticipants)" Style="min-width: 0; padding-left: 4px; padding-right: 4px;">
                        <span style="white-space: nowrap;">追加</span>
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonRemove" OnClick="RemoveParticipant" Disabled="@(activeParticipantCount <= rules.PlayerCount)" Style="min-width: 0; padding-left: 4px; padding-right: 4px;">
                        <span style="white-space: nowrap;">削除</span>
                    </MudButton>
                </div>
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.History" OnClick="CopyPreviousGame" Disabled="@(ActiveHistory.Count == 0)" Style="white-space: nowrap; flex-shrink: 0; padding-left: 4px; padding-right: 4px;">
                    前局をコピー
                </MudButton>
            </MudStack>
        </div>
        <MudGrid Spacing="1" AlignItems="AlignItems.Center">
            @for (int i = 0; i < activeParticipantCount; i++)
            {
                var index = i;
                bool isSitOut = currentSitOuts[index];
                <MudItem xs="12" sm="6">
                    <MudPaper Outlined="true" Elevation="0" Class="d-flex align-center justify-space-between px-2 py-1" Style="@($"background-color: rgba(255,255,255,0.02); transition: opacity 0.3s; {(isSitOut ? "opacity: 0.4;" : "")}")">
                        @* 左ブロック: 名前入力 *@
                        <MudAutocomplete T="string" Placeholder="@($"対局者 {index + 1}")" Value="currentPlayers[index].Name" ValueChanged="@((string v) => OnPlayerNameChanged(index, v))" SearchFunc="@SearchRegisteredPlayers" CoerceText="true" CoerceValue="true" MinCharacters="0" ShowOnFocus="true" DisableUnderLine="true" Margin="Margin.Dense" Class="player-name-input" Style="font-weight: bold; font-size: 0.95rem; width: 8.0em;" Disabled="isSitOut" onfocus="this.select();" />
                        <div class="d-flex align-center justify-center flex-grow-1">
                            @* 抜け番 *@
                            @if (activeParticipantCount > rules.PlayerCount)
                            {
                                <MudToggleIconButton Toggled="currentSitOuts[index]" ToggledChanged="@((bool v) => OnSitOutChanged(index, v))" Icon="@Icons.Material.Filled.Person" Color="Color.Default" Title="参加中" ToggledIcon="@Icons.Material.Filled.LocalCafe" ToggledColor="Color.Default" ToggledTitle="☕ 抜け番" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" />
                            }
                            @* 焼き鳥 *@
                            @if (rules.IsYakiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentYaki[index]" Icon="@Icons.Material.Filled.NoMeals" Color="Color.Default" Title="焼き鳥ではありません" ToggledIcon="@YakiIcon" ToggledColor="Color.Warning" ToggledTitle="🍗 焼き鳥です" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                            @* トビ *@
                            @if (rules.IsTobiEnabled)
                            {
                                <MudToggleIconButton @bind-Toggled="currentTobiBonus[index]" Icon="@Icons.Material.Filled.Rocket" Color="Color.Default" Title="トビ賞を獲得しません" ToggledIcon="@Icons.Material.Filled.RocketLaunch" ToggledColor="Color.Error" ToggledTitle="🚀 トビ賞を獲得します" Size="Size.Small" ToggledSize="Size.Small" Class="mr-1" Disabled="isSitOut" />
                            }
                        </div>
                        @* 右ブロック: 素点入力 *@
                        <div class="d-flex align-baseline">
                            <MudTextField T="string" Value="@(currentScores[index]?.ToString())" ValueChanged="@(v => HandleScoreStringInput(index, v))" DisableUnderLine="true" Margin="Margin.Dense" Class="@($"score-input {(index == autoFilledIndex ? "auto-filled" : "")}")" Style="width: 77px;" Disabled="isSitOut" Adornment="@(index == autoFilledIndex ? Adornment.Start : Adornment.None)" AdornmentIcon="@Icons.Material.Filled.AutoAwesome" AdornmentColor="Color.Info" />
                            <span class="score-zeros">00</span>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Class="mt-2 py-3" Disabled="@(!IsTotalCorrect)" OnClick="CalculateAndRecordGame">結果を記録する</MudButton>
    </MudPaper>

    @* --- セクション3: 集計結果 --- *@
    <MudPaper Class="pa-2 px-sm-4" Elevation="2" @onclick="CancelDelete">
        <ResultTable History="ActiveHistory" Players="currentPlayers.Select(p => p.Name).ToList()" ActiveParticipantCount="TableParticipantCount" @bind-DisplayMode="displayMode" Rules="rules" SessionChips="ActiveSessionChips" IsReadOnly="false" ArmedDeleteTarget="armedDeleteTarget" OnDeleteRequested="HandleDeleteRequest" OnResetRequested="ConfirmReset" OnChipChanged="HandleChipChangedCallback" />
        @* DBへ保存するボタン *@
        <div class="d-flex justify-center mt-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.CloudUpload" Disabled="@(ActiveHistory.Count == 0)" OnClick="ConfirmFinalizeSession" Style="width: 100%; max-width: 400px; font-weight: bold; padding: 12px 0;">
                結果を通算成績に保存
            </MudButton>
        </div>
        @* 共有ボタン *@
        <div class="d-flex justify-end mt-4 gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Share" OnClick="ShareImageAsync" Disabled="isSharing" Style="width: 170px; white-space: nowrap;">
                @(isSharing ? "画像を作成中..." : "結果を画像でシェア")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Link" OnClick="CopyShareUrlAsync" Style="white-space: nowrap;">
                閲覧用URLをシェア
            </MudButton>
        </div>
    </MudPaper>

    @* --- セクションX: シェア用の裏DOM（画面外に隠す） --- *@
    <div style="position: absolute; left: -9999px; top: 0;">
        <div id="share-target" style="width: @(800 + Math.Max(0, TableParticipantCount - 4) * 150)px; padding: 40px; background-color: #1a1a27; color: white; border-radius: 12px; font-family: 'Kaisei Decol', sans-serif;">
            <h2 style="text-align: center; margin-bottom: 20px; font-weight: bold; border-bottom: 2px solid #444; padding-bottom: 10px;">
                🀄 対局結果 🀄
            </h2>
            @* ルール・レート情報の表示 *@
            <div style="display: flex; flex-wrap: wrap; gap: 15px; margin-bottom: 20px; background-color: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; font-size: 0.95rem;">
                <div><strong>ルール名:</strong> @(string.IsNullOrWhiteSpace(rules.Name) ? "未設定" : rules.Name)</div>
                <div><strong>形式:</strong> @(rules.PlayerCount)人麻雀</div>
                <div><strong>設定:</strong> @(rules.StartingPoints)持ち / @(rules.ReturnPoints)返し</div>
                <div><strong>ウマ:</strong> @(rules.IsCustomUma ? rules.GetUmaDisplayText(true) : $"{rules.Uma1} - {rules.Uma2}")</div>
                <div><strong>レート:</strong> @(rules.Rate)円/1k</div>
                @if (rules.ChipRate > 0)
                {
                    <div><strong>チップ:</strong> @(rules.ChipRate)円/枚</div>
                }
            </div>
            @* 成績テーブル *@
            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; text-align: center; font-variant-numeric: tabular-nums;">
                <thead>
                    <tr style="background-color: rgba(255,255,255,0.1); border-bottom: 2px solid #555;">
                        <th style="padding: 12px; width: 80px; font-size: 0.9rem;">局</th>
                        @for (int i = 0; i < TableParticipantCount; i++)
                        {
                            <th style="padding: 12px; font-size: 1.1rem;">@(string.IsNullOrWhiteSpace(currentPlayers[i].Name) ? " " : currentPlayers[i].Name)</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @* 各局のポイント (+/-) 固定表示 *@
                    @for (int row = 0; row < ActiveHistory.Count; row++)
                    {
                        var game = ActiveHistory[row];
                        <tr style="border-bottom: 1px solid #333;">
                            <td style="padding: 10px; color: #aaa; font-size: 0.85rem; white-space: nowrap;">@(row + 1)局目</td>
                            @for (int i = 0; i < TableParticipantCount; i++)
                            {
                                @* 各局のフォントサイズ: 1.1rem *@
                                <td style="padding: 10px; font-size: 1.1rem; white-space: nowrap;">
                                    <span style="@GetSharePointStyle(game, i)">@GetSharePointValue(game, i)</span>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    @* ポイント合計行 *@
                    <tr style="background-color: rgba(46, 125, 50, 0.1); border-bottom: 2px solid #555;">
                        <td style="padding: 15px 10px; font-size: 0.9rem; color: #ddd; font-weight: bold; white-space: nowrap;">
                            Pt 合計
                        </td>
                        @for (int i = 0; i < TableParticipantCount; i++)
                        {
                            @* Pt合計のフォントサイズ: 1.2rem *@
                            <td style="padding: 15px 10px; font-size: 1.2rem; white-space: nowrap;">
                                <span style="@GetShareTotalPointStyle(i)">@GetShareTotalPointValue(i)</span>
                            </td>
                        }
                    </tr>
                    @* チップ行 (チップあり設定の場合のみ表示) *@
                    @if (rules.ChipRate > 0)
                    {
                        <tr style="background-color: rgba(46, 125, 50, 0.1); border-bottom: 2px solid #555;">
                            <td style="padding: 15px 10px; font-size: 0.9rem; color: #ddd; font-weight: bold; white-space: nowrap;">
                                チップ
                            </td>
                            @for (int i = 0; i < TableParticipantCount; i++)
                            {
                                int chip = ActiveSessionChips[i];
                                @* チップのフォントサイズ: 1.2rem (Pt合計と同等) *@
                                <td style="padding: 15px 10px; font-size: 1.2rem; white-space: nowrap;">
                                    <span style="display: inline-block; width: 4.5rem; text-align: right; @(chip > 0 ? "color: #ff6b6b;" : (chip < 0 ? "color: #4dabf7;" : "color: #9e9e9e;"))">
                                        @(chip > 0 ? $"+{chip}" : chip.ToString())枚
                                    </span>
                                </td>
                            }
                        </tr>
                    }
                    @* 円合計行 *@
                    <tr style="background-color: rgba(255, 255, 255, 0.06); font-weight: bold;">
                        <td style="padding: 15px 10px; font-size: 0.9rem; color: #eeeeee; white-space: nowrap;">
                            円 合計
                        </td>
                        @for (int i = 0; i < TableParticipantCount; i++)
                        {
                            @* 円合計のフォントサイズ: 1.4rem *@
                            <td style="padding: 15px 10px; font-size: 1.4rem; white-space: nowrap;">
                                <span style="@GetShareTotalYenStyle(i)">@GetShareTotalYenValue(i)</span>
                            </td>
                        }
                    </tr>
                </tfoot>
            </table>
            @* フッター情報 *@
            <div style="display: flex; justify-content: flex-end; font-size: 0.9rem; color: #888;">
                <span>@DateTime.Now.ToString("yyyy/MM/dd HH:mm") - 麻雀集計ツール</span>
            </div>
        </div>
    </div>
</MudContainer>

@code {
    // 画面の入力状態を管理するための内部クラス
    public class PlayerInputState
    {
        public string? Id { get; set; } // 登録済みの場合はID、新規手入力の場合はnull
        public string Name { get; set; } = string.Empty;
    }
    private RuleSet rules = new();
    private List<RuleSet> rulePresets = new();
    private const int MaxParticipants = 7;
    private int activeParticipantCount = 4;
    private List<PlayerInputState> currentPlayers = Enumerable.Range(0, MaxParticipants)
        .Select(_ => new PlayerInputState()).ToList();
    private List<PlayerProfile> playerMaster = new();
    private List<int?> currentScores = new() { null, null, null, null };
    private List<int?> previousScores = Enumerable.Repeat((int?)null, MaxParticipants).ToList();
    private List<GameResult> ActiveHistory = new();
    private List<int> ActiveSessionChips = Enumerable.Repeat(0, MaxParticipants).ToList();
    private int displayMode = 1;
    private bool isSettingsExpanded = true;
    private bool IsTotalCorrect
    {
        get
        {
            var activeScores = currentScores.Take(activeParticipantCount).Where((s, i) => !currentSitOuts[i]).ToList();
            if (activeScores.Count(x => x.HasValue) != rules.PlayerCount) return false;
            return activeScores.Sum(x => x ?? 0) == (rules.StartingPoints * rules.PlayerCount) / 100;
        }
    }
    private List<bool> currentYaki = new() { false, false, false, false };
    private List<bool> currentTobiBonus = new() { false, false, false, false };
    private List<bool> currentSitOuts = new(new bool[MaxParticipants]);
    private const string YakiIcon = "<g transform=\"matrix(0.025, 0, 0, 0.025, 0, 24)\"><path d=\"M843-60 670-234l-85 85q-23 23-56.5 23T472-149l-57-56q-23-23-23-56.5t23-56.5l-56-57q-23 23-56.5 23T246-375l-57-56q-23-23-23-56.5t23-56.5l-56-57q-23-23-23-56.5t23-56.5l28-28L60-844l56-56 102 102 28-28q23-23 57-23t57 23l56 56q23-23 56.5-23t56.5 23l57 56q23 23 23 57t-23 57l56 56q23-23 56.5-23t56.5 23l57 56q23 23 23 57t-23 57l-85 84 172 173-56 57ZM529-205l227-226-57-57-227 227 57 56Zm-57-170 114-113-57-56-113 113 56 56Zm-170-56 227-227-57-56-226 226 56 57Zm-56-170 114-113-57-57-113 113 56 57Zm368 255ZM501-460ZM388-573ZM275-686Z\"/></g>";
    private int? armedDeleteIndex = null;
    private GameResult? armedDeleteTarget = null;
    private bool isSharing = false;
    private string FormatPlus(double val, string fmt = "F1") => val > 0 ? $"+{val.ToString(fmt)}" : val.ToString(fmt);

    @* ローカルストレージからのデータ復元と初期化 *@
    protected override async Task OnInitializedAsync()
    {
        var savedRules = await LocalStorage.GetItemAsync<RuleSet>(StorageKeys.Rules);
        if (savedRules != null) rules = savedRules;
        try
        {
            var dbData = await DatabaseService.GetAllDataAsync();
            if (dbData != null && dbData.Players != null) playerMaster = dbData.Players;
        }
        catch
        {
            // 初回起動時などでDBが存在しない場合は空のまま
        }
        var savedPlayers = await LocalStorage.GetItemAsync<List<string>>(StorageKeys.CurrentPlayers);
        if (savedPlayers != null)
        {
            for (int i = 0; i < savedPlayers.Count && i < MaxParticipants; i++)
            {
                currentPlayers[i].Name = savedPlayers[i];
                var matched = playerMaster.FirstOrDefault(p => p.Name == savedPlayers[i]);
                if (matched != null) currentPlayers[i].Id = matched.Id;
            }
        }
        var savedActiveCount = await LocalStorage.GetItemAsync<int?>(StorageKeys.ActiveParticipantCount);
        activeParticipantCount = savedActiveCount ?? rules.PlayerCount;
        var savedPresets = await LocalStorage.GetItemAsync<List<RuleSet>>(StorageKeys.RulePresets);
        if (savedPresets != null && savedPresets.Count > 0)
        {
            rulePresets = savedPresets;
        }
        else
        {
            // 初回起動時のデフォルトプリセット
            rulePresets = new List<RuleSet>
            {
                new RuleSet
                {
                    Name = "一般的な四麻",
                    PlayerCount = 4,
                    StartingPoints = 25000,
                    ReturnPoints = 30000,
                    Uma1 = 10,
                    Uma2 = 20
                },
                new RuleSet
                {
                    Name = "一般的な三麻",
                    PlayerCount = 3,
                    StartingPoints = 35000,
                    ReturnPoints = 40000,
                    Uma1 = 10,
                    Uma2 = 20
                },
                new RuleSet
                {
                    Name = "Mリーグルール",
                    PlayerCount = 4,
                    StartingPoints = 25000,
                    ReturnPoints = 30000,
                    Uma1 = 10,
                    Uma2 = 30,
                    Rate = 0,
                    ChipRate = 0,
                    TieBreaker = TieBreakerRule.Split
                }
            };
            await LocalStorage.SetItemAsync(StorageKeys.RulePresets, rulePresets);
        }
        var savedHistory = await LocalStorage.GetItemAsync<List<GameResult>>("ActiveHistory");
        if (savedHistory != null) ActiveHistory = savedHistory;
        var savedChips = await LocalStorage.GetItemAsync<List<int>>("ActiveSessionChips");
        if (savedChips != null)
        {
            ActiveSessionChips = savedChips;
            while (ActiveSessionChips.Count < MaxParticipants) ActiveSessionChips.Add(0);
        }
        else
        {
            ActiveSessionChips = Enumerable.Repeat(0, MaxParticipants).ToList();
        }
        ResetInputForms();
        await JSRuntime.InvokeVoidAsync("hideMahjongLoader");
    }

    @* 持ち点の処理 *@
    private void OnStartingPointsChanged(int val)
    {
        int currentOka = Math.Max(0, rules.ReturnPoints - rules.StartingPoints);
        int diff = val - rules.StartingPoints;
        if (Math.Abs(diff) == 5000) rules.StartingPoints = val;
        else rules.StartingPoints = val * 100;
        rules.ReturnPoints = rules.StartingPoints + currentOka;
        EvaluateAutoFill();
    }

    @* 返し点の処理 *@
    private void OnReturnPointsChanged(int val)
    {
        int diff = val - rules.ReturnPoints;
        if (Math.Abs(diff) == 5000) rules.ReturnPoints = val;
        else rules.ReturnPoints = val * 100;
        if (rules.ReturnPoints < rules.StartingPoints)
            rules.ReturnPoints = rules.StartingPoints;
    }

    // 通常のウマ設定(Uma1, Uma2)をCustomUmaに反映
    public void SyncNormalToCustomUma()
    {
        // カスタムウマモードがONのときは、ユーザーの手入力を上書きしないよう同期をスキップ
        if (rules.IsCustomUma) return;
        if (rules.PlayerCount == 4)
        {
            rules.CustomUma4_1 = rules.Uma2; // 1位ウマ
            rules.CustomUma4_2 = rules.Uma1; // 2位ウマ
            rules.CustomUma4_3 = -rules.Uma1; // 3位ウマ
            rules.CustomUma4_4 = -rules.Uma2; // 4位ウマ
        }
        else if (rules.PlayerCount == 3)
        {
            rules.CustomUma3_1 = rules.Uma1 + rules.Uma2; // 1位ウマ
            rules.CustomUma3_2 = -rules.Uma1; // 2位ウマ
            rules.CustomUma3_3 = -rules.Uma2; // 3位ウマ
        }
    }

    /// 現在の人数に応じたCustomUmaの値を取得
    public double[] GetCustomUmaArray()
    {
        if (rules.PlayerCount == 4)
        {
            return new double[] { rules.CustomUma4_1, rules.CustomUma4_2, rules.CustomUma4_3, rules.CustomUma4_4 };
        }
        else
        {
            return new double[] { rules.CustomUma3_1, rules.CustomUma3_2, rules.CustomUma3_3 };
        }
    }

    @* 最後の1人の素点自動入力（数式対応） *@
    private async Task HandleScoreStringInput(int index, string val)
    {
        int? parsedVal = EvaluateScoreExpression(val);
        if (parsedVal == null && currentScores[index] != null)
        {
            currentScores[index] = null;
            StateHasChanged();
            await Task.Yield();
        }
        if (index == autoFilledIndex && parsedVal != null)
            autoFilledIndex = null;
        currentScores[index] = parsedVal;
        EvaluateAutoFill();
    }

    @* 文字列の数式（+ / -）を計算して整数を返す *@
    private int? EvaluateScoreExpression(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        input = input.Replace(" ", "").Replace("　", "");
        try
        {
            int total = 0;
            string currentNumber = "";
            char currentOp = '+';
            for (int i = 0; i < input.Length; i++)
            {
                char c = input[i];
                if (c == '+' || c == '-')
                {
                    // 先頭が符号（例: "-100"）の場合の処理
                    if (string.IsNullOrEmpty(currentNumber))
                    {
                        currentOp = c == '-' && currentOp == '+' ? '-' : c;
                        continue;
                    }
                    int val = int.Parse(currentNumber);
                    total = currentOp == '+' ? total + val : total - val;
                    currentNumber = "";
                    currentOp = c;
                }
                else if (char.IsDigit(c))
                {
                    currentNumber += c;
                }
                else
                {
                    return null;
                }
            }
            // 最後の数字を加減
            if (!string.IsNullOrEmpty(currentNumber))
            {
                int val = int.Parse(currentNumber);
                total = currentOp == '+' ? total + val : total - val;
            }
            return total;
        }
        catch
        {
            return null; // パースに失敗した場合は空欄に戻す
        }
    }

    @* ユーザーの入力文字からサジェストを検索するメソッド *@
    private Task<IEnumerable<string>> SearchRegisteredPlayers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(playerMaster.Select(p => p.Name));
        var result = playerMaster
            .Where(p => p.Name.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(p => p.Name);
        return Task.FromResult(result);
    }

