    @* 特殊ルールOFF時のスコア表示モード切替 *@
    private void ValidateDisplayMode()
    {
        displayMode = displayMode switch
        {
            3 when !rules.IsSinkEnabled => 1,
            4 when !rules.IsYakiEnabled => 1,
            5 when !rules.IsTobiEnabled => 1,
            6 when !rules.IsColdEnabled => 1,
            _ => displayMode
        };
    }

    @* 席順入力 *@
    private async Task<Dictionary<int, int>?> OpenTieBreakerIfNeeded(List<int> scores, List<string> players)
    {
        var priority = new Dictionary<int, int>();
        if (scores.Distinct().Count() == scores.Count)
        {
            for (int i = 0; i < scores.Count; i++) priority[i] = i;
            return priority;
        }
        var parameters = new DialogParameters { ["Players"] = players };
        var dialog = await DialogService.ShowAsync<TieBreakerDialog>("順位の決定", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not List<string> orderedNames) return null;
        for (int i = 0; i < scores.Count; i++) priority[i] = orderedNames.IndexOf(players[i]);
        return priority;
    }

    @* ポイントの端数調整 *@
    private void AdjustFractions(double[] points, List<int> orderedIndices)
    {
        double diff = Math.Round(0 - points.Sum(), 1);
        if (Math.Abs(diff) < 0.05) return;
        int steps = (int)Math.Round(Math.Abs(diff) * 10);
        double adjustment = diff > 0 ? 0.1 : -0.1;
        var targetIndices = diff > 0 ? orderedIndices : Enumerable.Reverse(orderedIndices).ToList();
        for (int i = 0; i < steps; i++)
        {
            int targetIndex = targetIndices[i % targetIndices.Count];
            points[targetIndex] = Math.Round(points[targetIndex] + adjustment, 1);
        }
    }

    @* 設定に応じた端数丸め *@
    private double ApplyRounding(double value, RoundingRule rule) => rule switch
    {
        RoundingRule.ShishaGonyu => Math.Round(value, MidpointRounding.AwayFromZero),
        RoundingRule.RoundDown => Math.Floor(value),
        RoundingRule.RoundUp => Math.Ceiling(value),
        RoundingRule.GoshaRokunyu => Math.Floor(value + 0.4),
        _ => value
    };

    @* 文字列フォーマット用の共通ヘルパー (正数に+を付与) *@
    private string FormatPlus(double val, string fmt = "F1") => val > 0 ? $"+{val.ToString(fmt)}" : val.ToString(fmt);

    @* 結果表示モード *@
    private string GetDisplayValue(GameResult res, int idx)
    {
        // 変更: 過去の履歴などでインデックスが範囲外の場合はハイフン
        if (idx >= res.RawScores.Count || res.RawScores[idx] == null) return "-";

        return displayMode switch
        {
            0 => (res.RawScores[idx] * 100)?.ToString("N0") ?? "-",
            1 => FormatPlus(res.Points[idx]),
            2 => $"{FormatPlus(res.Yen[idx], "N0")}円",
            3 => FormatExtra(res.SinkPoints, idx, "📈", "📉"),
            4 => FormatExtra(res.YakiPoints, idx, "🍴", "🍗"),
            5 => FormatExtra(res.TobiPoints, idx, "🚀", "💥"),
            6 => FormatExtra(res.ColdPoints, idx, "👑", "🏳️"),
            _ => ""
        };
        string FormatExtra(List<double>? list, int i, string posIcon, string negIcon)
        {
            if (list == null || i >= list.Count || list[i] == 0) return "-";
            double pt = list[i];
            return pt > 0 ? $"{posIcon} +{pt:F1}" : $"{negIcon} {pt:F1}";
        }
    }

    @* 結果表示モードに応じてスタイルを調整 *@
    private string GetTdStyle(GameResult res, int idx)
    {
        var valList = displayMode switch
        {
            0 => res.RawScores.Select(x => (double)(x ?? 0)).ToList(),
            1 => res.Points,
            2 => res.Yen.Select(x => (double)x).ToList(),
            3 => res.SinkPoints?.Count > idx ? res.SinkPoints : new(),
            4 => res.YakiPoints?.Count > idx ? res.YakiPoints : new(),
            5 => res.TobiPoints?.Count > idx ? res.TobiPoints : new(),
            6 => res.ColdPoints?.Count > idx ? res.ColdPoints : new(),
            _ => new()
        };
        if (idx >= valList.Count) return "";
        double val = valList[idx];
        string boxWidth = displayMode switch { 0 => "3.4rem", 2 => "4.2rem", _ => "3.2rem" };
        string style = $"display:inline-block; width:{boxWidth}; text-align:right; font-variant-numeric:tabular-nums; font-size:0.8rem; letter-spacing:-0.5px; ";
        if (res.RawScores[idx] == null) return style + "color: #9e9e9e; font-weight: normal; text-align: center;";
        if (displayMode >= 3 && val == 0) return style + "color: #9e9e9e; font-weight: bold;";
        bool isPositive = (displayMode == 0) ? res.Points[idx] >= 0 : val >= 0;
        style += $"color:{(isPositive ? "#ff0000" : "#1976d2")}; ";
        if (valList.Distinct().Count() > 1 && (val == valList.Max() || val == valList.Min())) style += "font-weight:bold;";
        if (displayMode == 1) style += "position: relative; right: 0.7rem; ";
        return style;
    }

    @* 結果表示モードに応じて集計値を算出 *@
    private double GetTotalNumericValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return 0;
        return displayMode switch
        {
            0 => ActiveHistory.Any(h => h.RawScores.Count > idx && h.RawScores[idx].HasValue)
                ? ActiveHistory.Where(h => h.RawScores.Count > idx && h.RawScores[idx].HasValue).Average(h => h.RawScores[idx]!.Value) * 100
                : 0,
            1 => ActiveHistory.Sum(h => h.Points.Count > idx ? h.Points[idx] : 0),
            2 => ActiveHistory.Sum(h => h.Yen.Count > idx ? h.Yen[idx] : 0) + (ActiveSessionChips[idx] * rules.ChipRate),
            3 => ActiveHistory.Sum(h => h.SinkPoints?.Count > idx ? h.SinkPoints[idx] : 0),
            4 => ActiveHistory.Sum(h => h.YakiPoints?.Count > idx ? h.YakiPoints[idx] : 0),
            5 => ActiveHistory.Sum(h => h.TobiPoints?.Count > idx ? h.TobiPoints[idx] : 0),
            6 => ActiveHistory.Sum(h => h.ColdPoints?.Count > idx ? h.ColdPoints[idx] : 0),
            _ => 0
        };
    }

    @* 結果表示モードに応じた単位を付加 *@
    private string GetTotalDisplayValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return "0";
        double val = GetTotalNumericValue(idx);
        if (displayMode == 0) return Math.Round(val).ToString("N0");
        if (displayMode == 2) return FormatPlus(val, "N0") + "円";
        return FormatPlus(val, "F1");
    }

    @* 結果表示の集計行のスタイルを取得 *@
    private string GetTotalTdStyle(int idx) => "background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; ";

    @* 結果表示の集計値フォント切り替え *@
    private string GetTotalSpanStyle(int idx)
    {
        string boxWidth = displayMode == 0 ? "3.4rem" : (displayMode == 2 ? "4.2rem" : "3.2rem");
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.85rem; letter-spacing: -0.5px; ";
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return style;
        var allValues = Enumerable.Range(0, activeParticipantCount).Select(GetTotalNumericValue).ToList();
        double val = allValues[idx];
        if (displayMode >= 3 && val == 0) return style + "color: #9e9e9e; font-weight: normal; ";
        if (allValues.Distinct().Count() > 1 && (val == allValues.Max() || val == allValues.Min())) style += "font-weight: bold; ";
        bool isPositive = displayMode == 0 ? ActiveHistory.Sum(h => h.Points.Count > idx ? h.Points[idx] : 0) >= 0 : val >= 0;
        style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";
        if (displayMode == 1) style += "position: relative; right: 0.7rem; ";
        return style;
    }

    @* シェア画像専用ヘルパーメソッド *@
    private string BuildShareStyle(double val, IEnumerable<double> allVals, string width)
    {
        string style = $"display: inline-block; width: {width}; text-align: right; font-variant-numeric: tabular-nums; ";
        style += val >= 0 ? "color: #ff6b6b; " : "color: #4dabf7; ";
        var dist = allVals.Distinct().ToList();
        if (dist.Count > 1 && (val == dist.Max() || val == dist.Min())) style += "font-weight: bold; ";
        return style;
    }

    private string GetSharePointValue(GameResult res, int idx) => (idx >= res.RawScores.Count || res.RawScores[idx] == null) ? "-" : FormatPlus(res.Points[idx]);
    
    private string GetSharePointStyle(GameResult res, int idx)
    {
        double pt = (idx < res.Points.Count) ? res.Points[idx] : 0;
        return BuildShareStyle(pt, res.Points, "4.5rem");
    }

    private string GetShareTotalPointValue(int idx) => ActiveHistory.Count == 0 ? "0.0" : FormatPlus(ActiveHistory.Sum(h => h.Points.Count > idx ? h.Points[idx] : 0));
    private string GetShareTotalPointStyle(int idx)
    {
        if (ActiveHistory.Count == 0) return "display: inline-block; width: 4.5rem; text-align: right; font-variant-numeric: tabular-nums; color: #ffffff;";
        var allTotalPts = Enumerable.Range(0, activeParticipantCount).Select(i => ActiveHistory.Sum(h => h.Points.Count > i ? h.Points[i] : 0)).ToList();
        return BuildShareStyle(allTotalPts[idx], allTotalPts, "4.5rem");
    }

    private string GetShareTotalYenValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return "0円";
        double totalYen = ActiveHistory.Sum(h => h.Yen.Count > idx ? h.Yen[idx] : 0) + (ActiveSessionChips[idx] * rules.ChipRate);
        return $"{FormatPlus(totalYen, "N0")}円";
    }

    private string GetShareTotalYenStyle(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return "display: inline-block; width: 6.0rem; text-align: right; font-variant-numeric: tabular-nums; color: #ffffff;";
        var allTotalYen = Enumerable.Range(0, activeParticipantCount).Select(i => (double)(ActiveHistory.Sum(h => h.Yen.Count > i ? h.Yen[i] : 0) + (ActiveSessionChips[i] * rules.ChipRate))).ToList();
        return BuildShareStyle(allTotalYen[idx], allTotalYen, "6.0rem");
    }

    @* 結果共有用のURLを生成してクリップボードにコピー *@
    private async Task CopyShareUrlAsync()
    {
        try
        {
            var payload = new
            {
                r = rules,
                p = currentPlayers.Take(activeParticipantCount).ToList(),
                c = ActiveSessionChips.Take(activeParticipantCount).ToList(),
                h = ActiveHistory.Select(g => new
                {
                    t = g.Timestamp.Ticks,
                    s = g.RawScores,
                    pt = g.Points,
                    yp = g.YakiPlayers,
                    tb = g.TobiBonusRecipients,
                    sp = g.SinkPoints,
                    ypt = g.YakiPoints,
                    tpt = g.TobiPoints,
                    cp = g.ColdPoints,
                    y = g.Yen
                }).ToList()
            };
            string json = System.Text.Json.JsonSerializer.Serialize(payload);
            byte[] jsonBytes = System.Text.Encoding.UTF8.GetBytes(json);
            using var ms = new System.IO.MemoryStream();
            using (var gzip = new System.IO.Compression.GZipStream(ms, System.IO.Compression.CompressionLevel.Optimal))
            {
                gzip.Write(jsonBytes, 0, jsonBytes.Length);
            }
            string base64 = Convert.ToBase64String(ms.ToArray());
            string urlEncoded = Uri.EscapeDataString(base64);
            string shareUrl = $"{NavigationManager.BaseUri}shared?d={urlEncoded}";
            string result = await JSRuntime.InvokeAsync<string>("shareUrlNative", "麻雀集計ツール - 対局結果", shareUrl);
            if (result == "COPIED") Snackbar.Add("閲覧用URLをクリップボードにコピーしました！", Severity.Success);
            else if (result.StartsWith("ERROR")) Snackbar.Add("共有またはコピーに失敗しました。", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"URLの生成に失敗しました: {ex.Message}", Severity.Error);
        }
    }

    @* 対局人数変更時の処理 (参加枠をリセット) *@
    private async Task OnPlayerCountChanged(int val)
    {
        rules.PlayerCount = val;
        activeParticipantCount = val; // 枠数をルール人数に強制同期
        ResetInputForms();
        await LocalStorage.SetItemAsync("rules", rules);
        await LocalStorage.SetItemAsync("activeParticipantCount", activeParticipantCount);
        ValidateDisplayMode();
        StateHasChanged();
    }

    @* 参加者枠を増やす *@
    private async Task AddParticipant()
    {
        if (activeParticipantCount < MaxParticipants)
        {
            activeParticipantCount++;
            await LocalStorage.SetItemAsync("activeParticipantCount", activeParticipantCount);
        }
    }

    @* 参加者枠を減らす *@
    private async Task RemoveParticipant()
    {
        if (activeParticipantCount > rules.PlayerCount)
        {
            activeParticipantCount--;
            // 隠れる枠の入力状態をリセット
            currentScores[activeParticipantCount] = null;
            currentSitOuts[activeParticipantCount] = false;
            currentYaki[activeParticipantCount] = false;
            currentTobiBonus[activeParticipantCount] = false;
            await LocalStorage.SetItemAsync("activeParticipantCount", activeParticipantCount);
            // 枠が減ることで残り1人が確定する可能性があるため、自動計算を再評価
            HandleScoreInputWithAutoFill(0, currentScores[0]);
        }
    }

    @* 抜け番状態の変更処理 *@
    private void OnSitOutChanged(int index, bool isSitOut)
    {
        currentSitOuts[index] = isSitOut;
        if (isSitOut)
        {
            currentScores[index] = null;
            currentYaki[index] = false;
            currentTobiBonus[index] = false;
        }
        // 抜け番が確定することで残り1人が確定する可能性があるため、自動計算をフック
        HandleScoreInputWithAutoFill(index, currentScores[index]);
    }
}