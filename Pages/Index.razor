    }

    private async Task RecordGame()
    {
        int pCount = rules.PlayerCount;
        var activeScores = currentScores.Take(pCount).Select(x => (x ?? 0) * 100).ToList();        
        var activePlayers = currentPlayers.Take(pCount).ToList();
        // 1. 入力ミスチェック（トビとボーナス獲得者の不一致）
        if (rules.IsTobiEnabled)
        {
            bool hasTobi = activeScores.Any(s => rules.TobiJustIsTobi ? s <= rules.TobiPoint : s < rules.TobiPoint);
            bool hasTobiBonus = currentTobiBonus.Take(pCount).Any(b => b);
            if (hasTobi && !hasTobiBonus)
            {
                Snackbar.Add("トビが発生していますが、ボーナス獲得者（🚀）が選択されていません。", Severity.Error);
                return;
            }
            if (!hasTobi && hasTobiBonus)
            {
                Snackbar.Add("トビが発生していないのに、ボーナス獲得者（🚀）が選択されています。", Severity.Error);
                return;
            }
        }

        // 1. オカ・順位ウマのベースポイント算出（席順や素点に依存しない固定値）
        double[] baseUmaOka = new double[pCount];
        double oka = (rules.ReturnPoints - rules.StartingPoints) * pCount / 1000.0;
        baseUmaOka[0] += oka;

        for (int rank = 0; rank < pCount; rank++)
        {
            double uma = 0;
            if (pCount == 4)
            {
                if (rank == 0) uma = rules.IsCustomUma ? rules.CustomUma4_1 : rules.Uma2;
                else if (rank == 1) uma = rules.IsCustomUma ? rules.CustomUma4_2 : rules.Uma1;
                else if (rank == 2) uma = rules.IsCustomUma ? rules.CustomUma4_3 : -rules.Uma1;
                else if (rank == 3) uma = rules.IsCustomUma ? rules.CustomUma4_4 : -rules.Uma2;
            }
            else if (pCount == 3)
            {
                if (rank == 0) uma = rules.IsCustomUma ? rules.CustomUma3_1 : rules.Uma1 + rules.Uma2;
                else if (rank == 1) uma = rules.IsCustomUma ? rules.CustomUma3_2 : -rules.Uma1;
                else if (rank == 2) uma = rules.IsCustomUma ? rules.CustomUma3_3 : -rules.Uma2;
            }
            baseUmaOka[rank] += uma;
        }

        // 2. 各個人の素点と端数処理
        double[] points = new double[pCount];
        double totalPts = 0;
        for (int i = 0; i < pCount; i++)
        {
            double rawPt = (activeScores[i] - rules.ReturnPoints) / 1000.0;
            points[i] = ApplyRounding(rawPt, rules.Rounding);
            totalPts += points[i];
        }

        // ゼロサムにするために必要な +0.1 の数
        int fractionsToAdjust = (int)Math.Round(-(totalPts + oka) * 10);

        // 3. 同着グループの分析と「席順入力ダイアログ」の要否判定
        var groupedScores = activeScores.Select((score, index) => new { score, index })
                                        .GroupBy(x => x.score)
                                        .OrderByDescending(g => g.Key)
                                        .ToList();

        bool needsTieBreaker = false;
        if (groupedScores.Any(g => g.Count() > 1))
        {
            if (rules.TieBreaker == TieBreakerRule.Kamicha)
            {
                needsTieBreaker = true; // 上家取りルールの場合は同着があれば必ず必要
            }
            else // 折半 (TieBreakerRule.Split) の場合
            {
                int currentRank = 0;
                foreach (var group in groupedScores)
                {
                    int count = group.Count();
                    if (count > 1)
                    {
                        // a. 素点の端数調整で、同着者の間に「+0.1配る/配らない」の境界線が引かれるか？
                        if (fractionsToAdjust > currentRank && fractionsToAdjust < currentRank + count)
                        {
                            needsTieBreaker = true;
                        }                    
                        // b. オカ・ウマの折半で、0.1単位で割り切れない端数が出るか？（例: 40 ÷ 3）
                        double sumUmaOka = 0;
                        for (int i = 0; i < count; i++) sumUmaOka += baseUmaOka[currentRank + i];
                        
                        double splitBase = Math.Floor(sumUmaOka / count * 10) / 10.0;
                        double remainder = Math.Round(sumUmaOka - (splitBase * count), 1);
                        if (remainder > 0)
                        {
                            needsTieBreaker = true; // 割り切れない余り(0.1)を上家に渡すため必要
                        }
                    }
                    currentRank += count;
                }

                // c. 【追加】沈みウマ・焼き鳥の「1着総取り」における端数チェック
                if (!needsTieBreaker)
                {
                    int topCount = groupedScores.First().Count();
                    if (topCount > 1)
                    {
                        // 沈みウマの端数チェック
                        if (rules.IsSunkenUmaEnabled && rules.SunkenUmaDistribution == PenaltyDistribution.WinnerTakeAll)
                        {
                            int borderPoint = rules.IsSunkenBaseCustom ? rules.SunkenUmaBasePoint : rules.StartingPoints;
                            int shizumiCount = activeScores.Count(s => rules.SunkenJustIsUki ? s < borderPoint : s <= borderPoint);
                            if (shizumiCount > 0 && shizumiCount < pCount)
                            {
                                int totalPenalty = shizumiCount * rules.SunkenUmaPenalty;
                                // 10倍して割ることで、0.1単位の余りが出るかを正確に判定
                                if ((totalPenalty * 10) % topCount != 0) needsTieBreaker = true;
                            }
                        }

                        // 焼き鳥の端数チェック
                        if (!needsTieBreaker && rules.IsYakitoriEnabled && rules.YakitoriDistribution == PenaltyDistribution.WinnerTakeAll)
                        {
                            int yakiCount = currentYakitori.Take(pCount).Count(y => y);
                            if (yakiCount > 0 && yakiCount < pCount)
                            {
                                int totalPenalty = yakiCount * rules.YakitoriPenalty;
                                if ((totalPenalty * 10) % topCount != 0) needsTieBreaker = true;
                            }
                        }
                    }
                }
            }
        }

        // 席順の決定
        Dictionary<int, int>? priority = null;
        if (needsTieBreaker)
        {
            priority = await OpenTieBreakerIfNeeded(activeScores, activePlayers);
            if (priority == null) return; // キャンセルされたら処理中断
        }
        else
        {
            priority = Enumerable.Range(0, pCount).ToDictionary(i => i, i => i);
        }

        // 4. 最終的な順位付け（同点の場合は priority で上家優先にソート）
        var rankedIndices = activeScores.Select((score, index) => new { score, index })
                                        .OrderByDescending(x => x.score)
                                        .ThenBy(x => priority[x.index])
                                        .Select(x => x.index)
                                        .ToList();


        // 5. 順位ウマ・オカの分配 (上家取り or 折半)
        int currentR = 0;
        while (currentR < pCount)
        {
            int score = activeScores[rankedIndices[currentR]];
            int tieCount = 1;
            for (int i = currentR + 1; i < pCount; i++)
            {
                if (activeScores[rankedIndices[i]] == score) tieCount++;
                else break;
            }
            if (rules.TieBreaker == TieBreakerRule.Split && tieCount > 1)
            {
                // 折半処理
                double sumUmaOka = 0;
                for (int i = 0; i < tieCount; i++) sumUmaOka += baseUmaOka[currentR + i];
                
                // 0.1単位で綺麗に折半し、割り切れなかった分は上家へ
                double splitBase = Math.Floor(sumUmaOka / tieCount * 10) / 10.0;
                double remainder = Math.Round(sumUmaOka - (splitBase * tieCount), 1);
                int remainderUnits = (int)Math.Round(remainder * 10); // 上家に配るべき +0.1 の数

                for (int i = 0; i < tieCount; i++)
                {
                    double addPt = splitBase;
                    if (i < remainderUnits) addPt += 0.1; // 割り切れなかった分は上家（配列の前の方）から優先
                    points[rankedIndices[currentR + i]] += addPt;
                }
            }
            else
            {
                // 上家取り、または単独順位
                for (int i = 0; i < tieCount; i++)
                {
                    points[rankedIndices[currentR + i]] += baseUmaOka[currentR + i];
                }
            }
            currentR += tieCount;
        }
        AdjustFractions(points, rankedIndices);

        // 4. イベント（沈みウマ、焼き鳥、トビ、コールド）処理
        
        // 【沈みウマ】
        if (rules.IsSunkenUmaEnabled)
        {
            int borderPoint = rules.IsSunkenBaseCustom ? rules.SunkenUmaBasePoint : rules.StartingPoints;
            var ukiIndices = new List<int>();
            var shizumiIndices = new List<int>();
            
            for (int i = 0; i < pCount; i++)
            {
                bool isUki = rules.SunkenJustIsUki ? activeScores[i] >= borderPoint : activeScores[i] > borderPoint;
                if (isUki) ukiIndices.Add(i); else shizumiIndices.Add(i);
            }

            if (shizumiIndices.Count > 0 && ukiIndices.Count > 0)
            {
                int totalPenalty = shizumiIndices.Count * rules.SunkenUmaPenalty;
                foreach (var i in shizumiIndices) points[i] -= rules.SunkenUmaPenalty;

                if (rules.SunkenUmaDistribution == PenaltyDistribution.WinnerTakeAll)
                {
                    int topScore = activeScores[rankedIndices[0]];
                    int topCount = 1;
                    for (int i = 1; i < pCount; i++)
                    {
                        if (activeScores[rankedIndices[i]] == topScore) topCount++;
                        else break;
                    }

                    if (rules.TieBreaker == TieBreakerRule.Split && topCount > 1)
                    {
                        double splitBase = Math.Floor((double)totalPenalty / topCount * 10) / 10.0;
                        double remainder = Math.Round(totalPenalty - (splitBase * topCount), 1);
                        int remainderUnits = (int)Math.Round(remainder * 10);

                        for (int i = 0; i < topCount; i++)
                        {
                            double addPt = splitBase;
                            if (i < remainderUnits) addPt += 0.1;
                            points[rankedIndices[i]] += addPt;
                        }
                        AdjustFractions(points, rankedIndices);
                    }
                    else
                    {
                        points[rankedIndices[0]] += totalPenalty;
                    }
                }
                else // 分配
                {
                    double splitBase = Math.Floor((double)totalPenalty / ukiIndices.Count * 10) / 10.0;
                    double remainder = Math.Round(totalPenalty - (splitBase * ukiIndices.Count), 1);
                    int remainderUnits = (int)Math.Round(remainder * 10);
                    // 浮きの人だけを抽出し、順位（上家優先）の順番に並べる
                    var orderedUki = rankedIndices.Where(idx => ukiIndices.Contains(idx)).ToList();
                    for (int j = 0; j < orderedUki.Count; j++)
                    {
                        double addPt = splitBase;
                        if (j < remainderUnits) addPt += 0.1; // 割り切れない0.1ptは上位から優先
                        points[orderedUki[j]] += addPt;
                    }
                }
            }
        }

        // 【焼き鳥】
        double[] preYakiPts = points.ToArray();
        if (rules.IsYakitoriEnabled)
        {
            var yakiIndices = new List<int>();
            var safeIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                if (currentYakitori[i]) yakiIndices.Add(i); else safeIndices.Add(i);
            }

            if (yakiIndices.Count > 0 && yakiIndices.Count < pCount) // 全員焼き鳥はペナルティなし等の慣例
            {
                int totalPenalty = yakiIndices.Count * rules.YakitoriPenalty;
                foreach (var i in yakiIndices) points[i] -= rules.YakitoriPenalty;

                if (rules.YakitoriDistribution == PenaltyDistribution.WinnerTakeAll)
                {
                    int topScore = activeScores[rankedIndices[0]];
                    int topCount = 1;
                    for (int i = 1; i < pCount; i++)
                    {
                        if (activeScores[rankedIndices[i]] == topScore) topCount++;
                        else break;
                    }

                    if (rules.TieBreaker == TieBreakerRule.Split && topCount > 1)
                    {
                        double splitBase = Math.Floor((double)totalPenalty / topCount * 10) / 10.0;
                        double remainder = Math.Round(totalPenalty - (splitBase * topCount), 1);
                        int remainderUnits = (int)Math.Round(remainder * 10);

                        for (int i = 0; i < topCount; i++)
                        {
                            double addPt = splitBase;
                            if (i < remainderUnits) addPt += 0.1;
                            points[rankedIndices[i]] += addPt;
                        }
                        AdjustFractions(points, rankedIndices);
                    }
                    else
                    {
                        points[rankedIndices[0]] += totalPenalty;
                    }
                }
                else // 分配
                {
                    double splitBase = Math.Floor((double)totalPenalty / safeIndices.Count * 10) / 10.0;
                    double remainder = Math.Round(totalPenalty - (splitBase * safeIndices.Count), 1);
                    int remainderUnits = (int)Math.Round(remainder * 10);
                    // 回避した人だけを抽出し、順位（上家優先）の順番に並べる
                    var orderedSafe = rankedIndices.Where(idx => safeIndices.Contains(idx)).ToList();
                    for (int j = 0; j < orderedSafe.Count; j++)
                    {
                        double addPt = splitBase;
                        if (j < remainderUnits) addPt += 0.1;
                        points[orderedSafe[j]] += addPt;
                    }
                }
            }
        }
        var yakitoriPts = points.Select((p, i) => Math.Round(p - preYakiPts[i], 1)).ToList();

        // 【トビ】
        double[] preTobiPts = points.ToArray();
        if (rules.IsTobiEnabled)
        {
            var tobiIndices = new List<int>();
            var bonusIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                bool isTobi = rules.TobiJustIsTobi ? activeScores[i] <= rules.TobiPoint : activeScores[i] < rules.TobiPoint;
                if (isTobi) tobiIndices.Add(i);
                if (currentTobiBonus[i]) bonusIndices.Add(i);
            }
            if (tobiIndices.Count > 0 && bonusIndices.Count > 0)
            {
                int totalPenalty = tobiIndices.Count * rules.TobiPenalty;
                foreach (var i in tobiIndices) points[i] -= rules.TobiPenalty;
                double splitBase = Math.Floor((double)totalPenalty / bonusIndices.Count * 10) / 10.0;
                double remainder = Math.Round(totalPenalty - (splitBase * bonusIndices.Count), 1);
                int remainderUnits = (int)Math.Round(remainder * 10);
                // ボーナス獲得者だけを抽出し、順位（上家優先）の順番に並べる
                var orderedBonus = rankedIndices.Where(idx => bonusIndices.Contains(idx)).ToList();
                for (int j = 0; j < orderedBonus.Count; j++)
                {
                    double addPt = splitBase;
                    if (j < remainderUnits) addPt += 0.1;
                    points[orderedBonus[j]] += addPt;
                }
            }
        }
        var tobiPts = points.Select((p, i) => Math.Round(p - preTobiPts[i], 1)).ToList();

        // 【コールド】
        if (rules.IsColdEnabled)
        {
            var coldIndices = new List<int>();
            var nonColdIndices = new List<int>();
            for (int i = 0; i < pCount; i++)
            {
                bool isCold = rules.ColdJustIsCold ? activeScores[i] >= rules.ColdPoint : activeScores[i] > rules.ColdPoint;
                if (isCold) coldIndices.Add(i);
                else nonColdIndices.Add(i);
            }
            // コールド達成者と非達成者が両方いる場合のみ精算
            if (coldIndices.Count > 0 && nonColdIndices.Count > 0)
            {
                // 達成者がもらうポイント ＝ 非達成者の人数 × コールドボーナス
                int bonusPerColdPlayer = nonColdIndices.Count * rules.ColdBonus;   
                // 非達成者が払うポイント ＝ 達成者の人数 × コールドボーナス
                int penaltyPerNonColdPlayer = coldIndices.Count * rules.ColdBonus;
                foreach (var i in coldIndices) points[i] += bonusPerColdPlayer;
                foreach (var i in nonColdIndices) points[i] -= penaltyPerNonColdPlayer;
            }
        }

        // 5. 円の計算 (上家・上位優先の端数処理ロジック)
        double[] exactYen = new double[pCount];
        int[] baseYen = new int[pCount];
        double[] fractions = new double[pCount];
        int totalBaseYen = 0;

        for (int i = 0; i < pCount; i++)
        {
            exactYen[i] = points[i] * rules.Rate; 
            baseYen[i] = (int)Math.Floor(exactYen[i]);
            fractions[i] = exactYen[i] - baseYen[i]; 
            totalBaseYen += baseYen[i];
        }
        int shortage = 0 - totalBaseYen;
        var yenDistributionOrder = Enumerable.Range(0, pCount)
            .OrderByDescending(i => fractions[i])
            .ThenBy(i => rankedIndices.IndexOf(i))
            .ToList();
        for (int i = 0; i < shortage; i++)
        {
            int targetIndex = yenDistributionOrder[i];
            baseYen[targetIndex] += 1;
        }
        // 結果オブジェクトの構築
        var resultData = new GameResult
        {
            Timestamp = DateTime.Now,
            PlayerNames = activePlayers,
            RawScores = activeScores,
            Points = points.ToList(),
            YakitoriPlayers = currentYakitori.Take(pCount).ToList(),
            TobiPlayers = activeScores.Select(s => rules.TobiJustIsTobi ? s <= rules.TobiPoint : s < rules.TobiPoint).ToList(),
            TobiBonusRecipients = currentTobiBonus.Take(pCount).ToList(),
            YakitoriPoints = yakitoriPts,
            TobiPoints = tobiPts,
            Yen = baseYen.ToList()
        };

        // 保存処理へ
        ActiveHistory.Add(resultData);
        await LocalStorage.SetItemAsync("histories_dict", histories);
        await LocalStorage.SetItemAsync("rules", rules);
        ResetCurrentScores();
        armedDeleteIndex = null;
    }

    private async Task<Dictionary<int, int>?> OpenTieBreakerIfNeeded(List<int> scores, List<string> players)
    {
        var priority = new Dictionary<int, int>();
        if (scores.Distinct().Count() == scores.Count)
        {
            for (int i = 0; i < scores.Count; i++) priority[i] = i;
            return priority;
        }
        var parameters = new DialogParameters { ["Players"] = players };
        var dialog = await DialogService.ShowAsync<TieBreakerDialog>("順位の決定", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not List<string> orderedNames) return null;
        for (int i = 0; i < scores.Count; i++) priority[i] = orderedNames.IndexOf(players[i]);
        return priority;
    }

    private async Task DeleteResult(GameResult res)
    {
        ActiveHistory.Remove(res);
        await LocalStorage.SetItemAsync("histories_dict", histories);
    }

    private async Task OpenCustomRuleDialog()
    {
        var parameters = new DialogParameters { ["OriginalRules"] = rules };
        var options = new DialogOptions 
    { 
        CloseOnEscapeKey = false, 
        BackdropClick = false, 
        MaxWidth = MaxWidth.Medium, 
        FullWidth = true,
        Position = DialogPosition.TopCenter 
    };
        var dialog = await DialogService.ShowAsync<CustomRuleDialog>("カスタムルール", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is RuleSet newRules)
        {
            rules = newRules;
            await LocalStorage.SetItemAsync("rules", rules);
            ValidateDisplayMode();
            StateHasChanged();
        }
    }

    private string GetDisplayValue(GameResult res, int idx)
    {
        if (displayMode == 0) return res.RawScores[idx].ToString("N0");
        if (displayMode == 1) return res.Points[idx] > 0 ? $"+{res.Points[idx]:F1}" : res.Points[idx].ToString("F1");
        if (displayMode == 2) return res.Yen[idx] > 0 ? $"+{res.Yen[idx]:N0}円" : $"{res.Yen[idx]:N0}円";
        
        // ▼ 追加: 焼き鳥表示 (3)
        if (displayMode == 3)
        {
            if (res.YakitoriPoints == null || res.YakitoriPoints.Count <= idx) return "-";
            double pt = res.YakitoriPoints[idx];
            if (pt == 0) return "0.0";
            // 焼き鳥本人には 🍗 を付ける
            string icon = (res.YakitoriPlayers.Count > idx && res.YakitoriPlayers[idx]) ? "🍗 " : "";
            return pt > 0 ? $"{icon}+{pt:F1}" : $"{icon}{pt:F1}";
        }
        
        // ▼ 追加: トバし表示 (4)
        if (displayMode == 4)
        {
            if (res.TobiPoints == null || res.TobiPoints.Count <= idx) return "-";
            double pt = res.TobiPoints[idx];
            if (pt == 0) return "0.0";
            // トバした人には 🚀、トんだ人には 💥 を付ける
            string icon = (res.TobiBonusRecipients.Count > idx && res.TobiBonusRecipients[idx]) ? "🚀 " : 
                          ((res.TobiPlayers.Count > idx && res.TobiPlayers[idx]) ? "💥 " : "");
            return pt > 0 ? $"{icon}+{pt:F1}" : $"{icon}{pt:F1}";
        }
        return "";
    }

    private string GetTdStyle(GameResult res, int idx)
    {
        double val = 0;
        List<double> valList = new();

        // 選択されている表示モードに応じて、評価対象の数値とリストを切り替える
        if (displayMode == 0) 
        {
            val = res.RawScores[idx];
            valList = res.RawScores.Select(x => (double)x).ToList();
        }
        else if (displayMode == 1) 
        {
            val = res.Points[idx];
            valList = res.Points;
        }
        else if (displayMode == 2) 
        {
            val = res.Yen[idx];
            valList = res.Yen.Select(x => (double)x).ToList();
        }
        else if (displayMode == 3)
        {
            if (res.YakitoriPoints == null || res.YakitoriPoints.Count <= idx) return "";
            val = res.YakitoriPoints[idx];
            valList = res.YakitoriPoints;
        }
        else if (displayMode == 4)
        {
            if (res.TobiPoints == null || res.TobiPoints.Count <= idx) return "";
            val = res.TobiPoints[idx];
            valList = res.TobiPoints;
        }

        // 絵文字が入る分、モード1,3,4の幅を少し広め(3.2rem)に確保
        string boxWidth = displayMode == 0 ? "3.4rem" : (displayMode == 2 ? "4.2rem" : "3.2rem");
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.8rem; letter-spacing: -0.5px; ";
        
        // 色の判定: 素点モード(0)の時は総合ポイントの浮き沈みで判定、それ以外は現在の表示項目の値で判定
        bool isPositive = (displayMode == 0) ? (res.Points[idx] >= 0) : (val >= 0);
        style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";

        // 太字の判定: 現在の表示項目の中での最大値・最小値を太字にする
        if (valList.Count > 0 && valList.Distinct().Count() > 1 && (val == valList.Max() || val == valList.Min()))
        {
            style += "font-weight: bold; ";
        }
        
        return style;
    }

    private double GetTotalNumericValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return 0;
        if (displayMode == 0) return ActiveHistory.Count == 0 ? 0 : ActiveHistory.Average(h => h.RawScores[idx]);
        if (displayMode == 1) return ActiveHistory.Sum(h => h.Points[idx]);
        if (displayMode == 2) return ActiveHistory.Sum(h => h.Yen[idx]) + (ActiveSessionChips[idx] * rules.ChipRate);
        if (displayMode == 3) return ActiveHistory.Sum(h => h.YakitoriPoints != null && h.YakitoriPoints.Count > idx ? h.YakitoriPoints[idx] : 0);
        if (displayMode == 4) return ActiveHistory.Sum(h => h.TobiPoints != null && h.TobiPoints.Count > idx ? h.TobiPoints[idx] : 0);
        return 0;
    }

    private double ApplyRounding(double value, RoundingRule rule)
    {
        return rule switch
        {
            RoundingRule.ShishaGonyu => Math.Round(value, MidpointRounding.AwayFromZero),
            RoundingRule.RoundDown => Math.Floor(value),
            RoundingRule.RoundUp => Math.Ceiling(value),
            RoundingRule.GoshaRokunyu => Math.Floor(value + 0.4), // 0.5以下は切り捨て(+0.4してFloor)、0.6以上は切り上げ
            _ => value
        };
    }

    private string GetTotalDisplayValue(int idx)
    {
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return "0";
        double val = GetTotalNumericValue(idx);
        if (displayMode == 0) return Math.Round(val).ToString("N0");
        if (displayMode == 1 || displayMode == 3 || displayMode == 4) return val > 0 ? $"+{val:F1}" : val.ToString("F1"); // 3と4を追加
        if (displayMode == 2) return val > 0 ? $"+{val:N0}円" : $"{val:N0}円";
        return "";
    }

    private string GetTotalTdStyle(int idx)
    {
        return "background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; ";
    }

    private string GetTotalSpanStyle(int idx)
    {
        string boxWidth = displayMode == 0 ? "3.4rem" : (displayMode == 2 ? "4.2rem" : "3.2rem");
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.85rem; letter-spacing: -0.5px; ";
        
        if (ActiveHistory.Count == 0 && ActiveSessionChips[idx] == 0) return style;
        
        // 全プレイヤーの「現在の表示モードにおける合計値」を取得
        var allValues = Enumerable.Range(0, rules.PlayerCount).Select(i => GetTotalNumericValue(i)).ToList();
        double val = allValues[idx];
        
        // 太字の判定
        if (allValues.Distinct().Count() > 1 && (val == allValues.Max() || val == allValues.Min()))
        {
            style += "font-weight: bold; ";
        }
        
        // 色の判定
        bool isPositive = (displayMode == 0) ? (ActiveHistory.Sum(h => h.Points[idx]) >= 0) : (val >= 0);
        style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";
        
        return style;
    }
}