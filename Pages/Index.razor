    @* 特殊ルールOFF時のスコア表示モード切替 *@
    private void ValidateDisplayMode()
    {
        displayMode = displayMode switch
        {
            3 when !rules.IsSinkEnabled => 1,
            4 when !rules.IsYakiEnabled => 1,
            5 when !rules.IsTobiEnabled => 1,
            6 when !rules.IsColdEnabled => 1,
            _ => displayMode
        };
    }

    @* 席順入力 *@
    private async Task<Dictionary<int, int>?> OpenTieBreakerIfNeeded(List<int> scores, List<string> players)
    {
        var priority = new Dictionary<int, int>();
        // 全員の点数がバラバラならダイアログは不要
        if (scores.Distinct().Count() == scores.Count)
        {
            for (int i = 0; i < scores.Count; i++) priority[i] = i;
            return priority;
        }
        var parameters = new DialogParameters { ["Players"] = players };
        var dialog = await DialogService.ShowAsync<TieBreakerDialog>("順位の決定", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not List<int> orderedIndices) return null;
        for (int i = 0; i < scores.Count; i++) priority[i] = orderedIndices.IndexOf(i);
        return priority;
    }

    @* ポイントの端数調整 *@
    private void AdjustFractions(double[] points, List<int> orderedIndices)
    {
        double diff = Math.Round(0 - points.Sum(), 1);
        if (Math.Abs(diff) < 0.05) return;
        int steps = (int)Math.Round(Math.Abs(diff) * 10);
        double adjustment = diff > 0 ? 0.1 : -0.1;
        var targetIndices = diff > 0 ? orderedIndices : Enumerable.Reverse(orderedIndices).ToList();
        for (int i = 0; i < steps; i++)
        {
            int targetIndex = targetIndices[i % targetIndices.Count];
            points[targetIndex] = Math.Round(points[targetIndex] + adjustment, 1);
        }
    }

    @* 設定に応じた端数丸め *@
    private double ApplyRounding(double value, RoundingRule rule) => rule switch
    {
        RoundingRule.ShishaGonyu => Math.Round(value, 1, MidpointRounding.AwayFromZero),
        RoundingRule.RoundDown => Math.Floor(value * 10) / 10.0,
        RoundingRule.RoundUp => Math.Ceiling(value * 10) / 10.0,
        RoundingRule.GoshaRokunyu => Math.Floor((value * 10) + 0.4) / 10.0,
        _ => value
    };

    @* コンポーネントからのチップ変更イベントを受け取るヘルパー *@
    private async Task HandleChipChangedCallback((int Index, int Value) args)
    {
        if (args.Index >= 0 && args.Index < TablePlayers.Count)
        {
            var name = TablePlayers[args.Index];
            if (!string.IsNullOrWhiteSpace(name))
            {
                ActiveSessionChips[name] = args.Value;
                await LocalStorage.SetItemAsync("ActiveSessionChips", ActiveSessionChips);
            }
        }
    }

    @* シェア画像専用ヘルパーメソッド *@
    private string BuildShareStyle(double val, IEnumerable<double> allVals, string width)
    {
        string style = $"display: inline-block; width: {width}; text-align: right; font-variant-numeric: tabular-nums; ";
        style += val >= 0 ? "color: #ff6b6b; " : "color: #4dabf7; ";
        var dist = allVals.Distinct().ToList();
        if (dist.Count > 1 && (val == dist.Max() || val == dist.Min())) style += "font-weight: bold; ";
        return style;
    }

    private string GetSharePointValue(GameResult res, string name)
    {
        int idx = res.PlayerNames.IndexOf(name);
        if (idx == -1 || idx >= res.RawScores.Count || res.RawScores[idx] == null) return "-";
        return FormatPlus(res.Points[idx]);
    }

    private string GetSharePointStyle(GameResult res, string name)
    {
        int idx = res.PlayerNames.IndexOf(name);
        if (idx == -1 || idx >= res.RawScores.Count || res.RawScores[idx] == null)
            return "display: inline-block; width: 4.5rem; text-align: right; font-variant-numeric: tabular-nums; color: #9e9e9e;";
        double pt = (idx < res.Points.Count) ? res.Points[idx] : 0;
        return BuildShareStyle(pt, res.Points, "4.5rem");
    }

    private string GetShareTotalPointValue(string name)
    {
        if (ActiveHistory.Count == 0) return "0.0";
        double sum = 0;
        foreach (var h in ActiveHistory)
        {
            int idx = h.PlayerNames.IndexOf(name);
            if (idx != -1 && h.Points.Count > idx) sum += h.Points[idx];
        }
        return FormatPlus(sum);
    }

    private string GetShareTotalPointStyle(string name)
    {
        if (ActiveHistory.Count == 0) return "display: inline-block; width: 4.5rem; text-align: right; font-variant-numeric: tabular-nums; color: #ffffff;";
        var tablePlayers = TablePlayers;
        var allTotalPts = tablePlayers.Select(p =>
            ActiveHistory.Sum(h =>
            {
                int idx = h.PlayerNames.IndexOf(p);
                return (idx != -1 && h.Points.Count > idx) ? h.Points[idx] : 0;
            })
        ).ToList();
        int pIdx = tablePlayers.IndexOf(name);
        if (pIdx == -1) return "display: inline-block; width: 4.5rem; text-align: right; font-variant-numeric: tabular-nums; color: #ffffff;";
        return BuildShareStyle(allTotalPts[pIdx], allTotalPts, "4.5rem");
    }

    private string GetShareTotalYenValue(string name, int tableIdx)
    {
        int chips = ActiveSessionChips.TryGetValue(name, out var c) ? c : 0;
        if (ActiveHistory.Count == 0 && chips == 0) return "0円";
        double totalYen = 0;
        foreach (var h in ActiveHistory)
        {
            int idx = h.PlayerNames.IndexOf(name);
            if (idx != -1 && h.Yen.Count > idx) totalYen += h.Yen[idx];
        }
        totalYen += (chips * rules.ChipRate);
        return $"{FormatPlus(totalYen, "N0")}円";
    }

    private string GetShareTotalYenStyle(string name, int tableIdx)
    {
        int chips = ActiveSessionChips.TryGetValue(name, out var c) ? c : 0;
        if (ActiveHistory.Count == 0 && chips == 0) return "display: inline-block; width: 6.0rem; text-align: right; font-variant-numeric: tabular-nums; color: #ffffff;";
        var tablePlayers = TablePlayers;
        var allTotalYen = tablePlayers.Select((p, tIdx) => {
            double yen = ActiveHistory.Sum(h => {
                int idx = h.PlayerNames.IndexOf(p);
                return (idx != -1 && h.Yen.Count > idx) ? h.Yen[idx] : 0;
            });
            int chipCount = ActiveSessionChips.TryGetValue(p, out var v) ? v : 0;
            return yen + (chipCount * rules.ChipRate);
        }).ToList();
        int pIdx = tablePlayers.IndexOf(name);
        if (pIdx == -1) return "display: inline-block; width: 6.0rem; text-align: right; font-variant-numeric: tabular-nums; color: #ffffff;";
        return BuildShareStyle(allTotalYen[pIdx], allTotalYen, "6.0rem");
    }

    @* 結果共有用のURLを生成してクリップボードにコピー *@
    private async Task CopyShareUrlAsync()
    {
        try
        {
            var payload = new
            {
                r = rules,
                p = TablePlayers,
                c = TablePlayers.Select(p => ActiveSessionChips.TryGetValue(p, out var v) ? v : 0).ToList(),
                h = ActiveHistory.Select(g => new { t = g.Timestamp.Ticks, s = g.RawScores, pt = g.Points, yp = g.YakiPlayers, tb = g.TobiBonusRecipients, sp = g.SinkPoints, ypt = g.YakiPoints, tpt = g.TobiPoints, cp = g.ColdPoints, y = g.Yen }).ToList()
            };
            string json = System.Text.Json.JsonSerializer.Serialize(payload);
            byte[] jsonBytes = System.Text.Encoding.UTF8.GetBytes(json);
            using var ms = new System.IO.MemoryStream();
            using (var gzip = new System.IO.Compression.GZipStream(ms, System.IO.Compression.CompressionLevel.Optimal)) { gzip.Write(jsonBytes, 0, jsonBytes.Length); }
            string base64 = Convert.ToBase64String(ms.ToArray());
            string urlEncoded = base64.Replace("+", "-").Replace("/", "_").TrimEnd('=');
            string shareUrl = $"{NavigationManager.BaseUri}shared?d={urlEncoded}";
            string result = await JSRuntime.InvokeAsync<string>("shareUrlNative", "麻雀集計ツール - 対局結果", shareUrl);
            if (result == "COPIED") Snackbar.Add("閲覧用URLをクリップボードにコピーしました！", Severity.Success);
            else if (result.StartsWith("ERROR")) Snackbar.Add("共有またはコピーに失敗しました", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"URLの生成に失敗しました:\n{ex.Message}", Severity.Error); }
    }

    @* 対局人数変更時の処理 *@
    private async Task OnPlayerCountChanged(int val)
    {
        rules.PlayerCount = val;
        activeParticipantCount = val;
        (rules.StartingPoints, rules.ReturnPoints, rules.Uma1, rules.Uma2) = val switch
        {
            4 => (25000, 30000, 10, 20),
            3 => (30000, 35000, 10, 20),
            _ => (rules.StartingPoints, rules.ReturnPoints, rules.Uma1, rules.Uma2)
        };
        // 人数変更時にもカスタムウマ側にデータを同期させる
        SyncNormalToCustomUma();
        ResetInputForms();
        await LocalStorage.SetItemAsync(StorageKeys.Rules, rules);
        await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
        ValidateDisplayMode();
        StateHasChanged();
    }

    @* 参加者枠を増やす *@
    private async Task AddParticipant()
    {
        if (activeParticipantCount < MaxParticipants)
        {
            int newIndex = activeParticipantCount;
            if (autoFilledIndex.HasValue)
                currentSitOuts[newIndex] = true;
            activeParticipantCount++;
            await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
            EvaluateAutoFill();
        }
    }

    @* 参加者枠を減らす *@
    private async Task RemoveParticipant()
    {
        if (activeParticipantCount > rules.PlayerCount)
        {
            activeParticipantCount--;
            scoreInputBuffers[activeParticipantCount] = string.Empty;
            currentSitOuts[activeParticipantCount] = false;
            currentYaki[activeParticipantCount] = false;
            currentTobiBonus[activeParticipantCount] = false;
            if (activeParticipantCount == rules.PlayerCount)
            {
                for (int i = 0; i < activeParticipantCount; i++)
                {
                    if (currentSitOuts[i])
                    {
                        currentSitOuts[i] = false;
                        var prevScore = previousScores[i];
                        if (prevScore.HasValue)
                        {
                            scoreInputBuffers[i] = prevScore.Value.ToString();
                            previousScores[i] = null;
                        }
                    }
                }
            }
            await LocalStorage.SetItemAsync(StorageKeys.ActiveParticipantCount, activeParticipantCount);
            EvaluateAutoFill();
        }
    }

    @* 抜け番状態の変更処理 *@
    private void OnSitOutChanged(int index, bool isSitOut)
    {
        currentSitOuts[index] = isSitOut;
        if (isSitOut)
        {
            previousScores[index] = currentScores[index];
            scoreInputBuffers[index] = string.Empty;
            currentYaki[index] = false;
            currentTobiBonus[index] = false;
            if (index == autoFilledIndex) autoFilledIndex = null;
        }
        else
        {
            var prevScore = previousScores[index];
            if (prevScore.HasValue)
            {
                scoreInputBuffers[index] = prevScore.Value.ToString();
                previousScores[index] = null;
            }
        }
        EvaluateAutoFill();
    }

    // 自動入力された枠のインデックスを保持
    private int? autoFilledIndex = null;

    // 状態を評価し、矛盾を正すコアメソッド
    private void EvaluateAutoFill()
    {
        var activeIndices = Enumerable.Range(0, activeParticipantCount).Where(i => !currentSitOuts[i]).ToList();
        if (activeIndices.Count != rules.PlayerCount)
        {
            ClearAutoFill();
            return;
        }
        var scores = currentScores;
        var manualIndices = activeIndices.Where(i => i != autoFilledIndex).ToList();
        var nullManualIndices = manualIndices.Where(i => !scores[i].HasValue).ToList();
        if (nullManualIndices.Count == 0)
        {
            if (autoFilledIndex.HasValue)
            {
                int targetTotal = (rules.StartingPoints * rules.PlayerCount) / 100;
                int currentTotal = manualIndices.Sum(i => scores[i] ?? 0);
                scoreInputBuffers[autoFilledIndex.Value] = (targetTotal - currentTotal).ToString();
            }
        }
        else if (nullManualIndices.Count == 1)
        {
            if (autoFilledIndex.HasValue) ClearAutoFill();
            else
            {
                autoFilledIndex = nullManualIndices[0];
                int targetTotal = (rules.StartingPoints * rules.PlayerCount) / 100;
                int currentTotal = activeIndices.Where(i => i != autoFilledIndex).Sum(i => scores[i] ?? 0);
                scoreInputBuffers[autoFilledIndex.Value] = (targetTotal - currentTotal).ToString();
            }
        }
        else ClearAutoFill();
    }

    private void ClearAutoFill()
    {
        if (autoFilledIndex.HasValue)
        {
            scoreInputBuffers[autoFilledIndex.Value] = string.Empty;
            autoFilledIndex = null;
        }
    }

    @* 本日の対局セッションの終了確定確認ダイアログを表示 *@
    private async Task ConfirmFinalizeSession()
    {
        if (isFinalizing) return;
        isFinalizing = true;
        try
        {
            int chipSum = ActiveSessionChips.Values.Sum();            
            bool isChipError = chipSum != 0;
            string msg = "対局結果とチップ枚数を通算成績に記録して<br />現在の入力フォームをリセットしますか？";
            if (isChipError) msg += "<br /><span style='color: #ff6b6b; font-weight: bold;'>⚠️チップの合計枚数が" + (chipSum > 0 ? "+" : "") + chipSum + "枚です。</span>";
            bool? result = await DialogService.ShowMessageBoxAsync(
                "対局セッションの終了確定",
                (MarkupString)msg,
                yesText: "記録してリセット",
                cancelText: "戻る"
            );
            if (result == true) await FinalizeAndSaveToDbAsync();
        }
        finally
        {
            isFinalizing = false;
        }
    }

    @* データを成形して長期成績DB（IndexedDBを想定）へ一括保存し、卓を片付けるコアロジック *@
    private async Task FinalizeAndSaveToDbAsync()
    {
        try
        {
            var sessionPlayerNames = ActiveHistory.SelectMany(h => h.PlayerNames.Select((name, idx) => new { Name = name, HasScore = idx < h.RawScores.Count && h.RawScores[idx].HasValue }).Where(x => x.HasScore && !string.IsNullOrWhiteSpace(x.Name)).Select(x => x.Name)).Distinct().ToList();
            var nameToIdMap = new Dictionary<string, string>();
            var playersToUpdate = new List<PlayerProfile>();
            var gameRecordsToSave = new List<SavedGameRecord>();
            var newSessionId = Guid.NewGuid().ToString();
            var currentTimestamp = DateTime.Now;
            foreach (var name in sessionPlayerNames)
            {
                var existingPlayer = playerMaster.FirstOrDefault(p => p.Name == name);
                if (existingPlayer != null) { nameToIdMap[name] = existingPlayer.Id; playersToUpdate.Add(new PlayerProfile { Id = existingPlayer.Id, Name = existingPlayer.Name, CumulativeChips = existingPlayer.CumulativeChips, CreatedAt = existingPlayer.CreatedAt }); }
                else { var newId = Guid.NewGuid().ToString(); var newProfile = new PlayerProfile { Id = newId, Name = name, CumulativeChips = 0, CreatedAt = currentTimestamp }; playerMaster.Add(newProfile); playersToUpdate.Add(newProfile); nameToIdMap[name] = newId; }
            }
            foreach (var game in ActiveHistory) { var savedRecord = new SavedGameRecord { Id = Guid.NewGuid().ToString(), SessionId = newSessionId, RuleName = rules.Name, PlayerCount = rules.PlayerCount, Timestamp = game.Timestamp, PlayerIds = game.PlayerNames.Select(name => !string.IsNullOrWhiteSpace(name) && nameToIdMap.ContainsKey(name) ? nameToIdMap[name] : null).ToList(), RawScores = game.RawScores, Points = game.Points, Yen = game.Yen }; gameRecordsToSave.Add(savedRecord); }
            var sessionRecord = new SavedSessionRecord { SessionId = newSessionId, Date = currentTimestamp, Rate = rules.Rate, ChipRate = rules.ChipRate, ParticipantPlayerIds = new List<string>(), SettledChips = new List<int>() };
            for (int i = 0; i < TablePlayers.Count; i++)
            {
                string name = TablePlayers[i];
                if (!string.IsNullOrWhiteSpace(name) && nameToIdMap.TryGetValue(name, out var playerId))
                {
                    // 名前をキーにしてチップ数を取得
                    int chipCount = ActiveSessionChips.TryGetValue(name, out var c) ? c : 0;
                    sessionRecord.ParticipantPlayerIds.Add(playerId);
                    sessionRecord.SettledChips.Add(chipCount);
                }
            }
            await DatabaseService.SaveSessionAsync(playersToUpdate, sessionRecord, gameRecordsToSave);
            ActiveHistory.Clear();
            ActiveSessionChips.Clear();
            await LocalStorage.SetItemAsync("ActiveHistory", ActiveHistory);
            await LocalStorage.SetItemAsync("ActiveSessionChips", ActiveSessionChips);
            ResetInputForms();
            Snackbar.Add("対局結果を通算成績に保存しました！", Severity.Success);
            _ = StatsCache.InitializeAsync(forceReload: true);
            StateHasChanged();
        }
        catch (Exception ex) { Snackbar.Add("保存中にエラーが発生しました:\n" + ex.Message, Severity.Error); }
    }

    private async Task OpenKeypad(int index)
    {
        if (currentSitOuts[index]) return; // 抜け番の時は開かない
        if (activeScoreInputIndex.HasValue && activeScoreInputIndex.Value != index)
            await CommitScoreBuffer(activeScoreInputIndex.Value);
        activeScoreInputIndex = index;
        var score = currentScores[index];
        if (string.IsNullOrEmpty(scoreInputBuffers[index]) && score.HasValue)
            scoreInputBuffers[index] = score.Value.ToString();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("scrollToInput", "score-input-section");
    }

    private async Task CloseKeypad()
    {
        if (activeScoreInputIndex.HasValue)
            await CommitScoreBuffer(activeScoreInputIndex.Value);
        activeScoreInputIndex = null;
    }

    // 画面外をタップした時の統合ハンドラー
    private async Task OnContainerClick()
    {
        CancelDelete();
        await CloseKeypad();
    }

    // テンキーのボタンが押された時のコアロジック
    private async Task OnKeypadPress(string key)
    {
       if (!activeScoreInputIndex.HasValue) return;

        int idx = activeScoreInputIndex.Value;
        if (key == "閉じる")
        {
            await CloseKeypad();
            return;
        }
        if (key == "記録")
        {
            await CloseKeypad();
            await CalculateAndRecordGame();
            await LocalStorage.RemoveItemAsync("backup_score_buffers");
            return;
        }
        if (key == "C")
        {
            scoreInputBuffers[idx] = string.Empty;
            if (idx == autoFilledIndex) autoFilledIndex = null;
            EvaluateAutoFill();
            await LocalStorage.SetItemAsync("backup_score_buffers", scoreInputBuffers);
            return;
        }
        if (idx == autoFilledIndex)
        {
            scoreInputBuffers[idx] = string.Empty;
            autoFilledIndex = null;
        }
        if (key == "⌫")
        {
            if (scoreInputBuffers[idx].Length > 0)
                scoreInputBuffers[idx] = scoreInputBuffers[idx].Substring(0, scoreInputBuffers[idx].Length - 1);
        }
        else
        {
            // 演算子（＋、ー）の入力時、末尾がすでに演算子の場合は上書きする
            if (key == "+" || key == "-")
                if (scoreInputBuffers[idx].EndsWith("+") || scoreInputBuffers[idx].EndsWith("-"))
                    scoreInputBuffers[idx] = scoreInputBuffers[idx].Substring(0, scoreInputBuffers[idx].Length - 1);
            scoreInputBuffers[idx] += key;
            scoreInputBuffers[idx] = System.Text.RegularExpressions.Regex.Replace(scoreInputBuffers[idx], @"(^|[-+])0+(?=[0-9])", "$1");
        }
        EvaluateAutoFill();
        await LocalStorage.SetItemAsync("backup_score_buffers", scoreInputBuffers);
    }

    // 指定したインデックスの入力内容を計算・確定するヘルパーメソッド
    private async Task CommitScoreBuffer(int idx)
    {
        int? finalScore = EvaluateScoreExpression(scoreInputBuffers[idx]);
        if (finalScore.HasValue)
        {
            scoreInputBuffers[idx] = finalScore.Value.ToString();
        }
        else if (!string.IsNullOrWhiteSpace(scoreInputBuffers[idx]))
        {
            scoreInputBuffers[idx] = string.Empty;
        }
       EvaluateAutoFill();
        await LocalStorage.SetItemAsync("backup_score_buffers", scoreInputBuffers);
    }
}