@page "/shared"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@using System.Text.Json.Serialization
@using MahjongApp.Models

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white;">
        対局結果
    </MudText>
    @if (isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText>データを読み込み中...</MudText>
    }
    else if (errorMessage != null)
    {
        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="2" Style="overflow: hidden; width: 100%;">
             <ResultTable History="sharedData?.History ?? new()" Players="sharedData?.Players ?? new()" ActiveParticipantCount="sharedData?.Players?.Count ?? 0" @bind-DisplayMode="displayMode" Rules="sharedData?.Rules ?? new()" SessionChips="sharedData?.SessionChips ?? new()" IsReadOnly="true" />
        </MudPaper>
    }
</MudContainer>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private int displayMode = 1;
    private SharedPayload? sharedData;
    private readonly string workerUrl = "https://mahjong-share.inoino11.workers.dev";

    [SupplyParameterFromQuery(Name = "id")]
    public string? SharedIdParam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SharedIdParam))
        {
            try
            {
                var uri = new Uri(NavigationManager.Uri);
                string fragment = uri.Fragment;
                if (string.IsNullOrEmpty(fragment) || fragment.Length < 2)
                {
                    errorMessage = "復号用の鍵がURLに含まれていません。";
                    isLoading = false;
                    return;
                }
                string decryptionKey = fragment.Substring(1);

                var encData = await Http.GetFromJsonAsync<EncryptedResponse>($"{workerUrl}/{SharedIdParam}");
                
                if (encData != null && !string.IsNullOrEmpty(encData.EncryptedData))
                {
                    // --- 変更点: JS側のWeb Crypto APIを利用して復号 ---
                    string decryptedJson = await JSRuntime.InvokeAsync<string>("blazorCrypto.decrypt", encData.EncryptedData, decryptionKey);
                    
                    var options = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
                    var minData = System.Text.Json.JsonSerializer.Deserialize<MinifiedPayload>(decryptedJson, options);

                    if (minData != null)
                    {
                        var resolvedPlayers = minData.Players ?? new List<string>();
                        
                        sharedData = new SharedPayload
                        {
                            Rules = minData.Rules,
                            Players = resolvedPlayers,
                            SessionChips = minData.SessionChips,
                            History = minData.History?.Select(m => new GameResult
                            {
                                Timestamp = new DateTime(m.Ticks),
                                PlayerNames = resolvedPlayers,
                                RawScores = m.RawScores ?? new(),
                                Points = m.Points ?? new(),
                                YakiPlayers = m.YakiPlayers ?? new(),
                                TobiBonusRecipients = m.TobiBonusRecipients ?? new(),
                                SinkPoints = m.SinkPoints ?? new(),
                                YakiPoints = m.YakiPoints ?? new(),
                                TobiPoints = m.TobiPoints ?? new(),
                                ColdPoints = m.ColdPoints ?? new(),
                                Yen = m.Yen ?? new()
                            }).ToList()
                        };
                    }
                }
                else
                {
                    errorMessage = "データが存在しないか、形式が異なります。";
                }
                
                isLoading = false;
            }
            catch (Microsoft.JSInterop.JSException)
            {
                // JavaScript側での復号（crypto.subtle.decrypt）に失敗した場合
                errorMessage = "データの復号に失敗しました。URLが欠損しているか、鍵が間違っています。";
                isLoading = false;
            }
            catch (Exception)
            {
                errorMessage = "無効なURL、またはデータの有効期限（30日）が切れています。";
                isLoading = false;
            }
        }
        else
        {
            errorMessage = "データが見つかりません。";
            isLoading = false;
        }
    }

    public class EncryptedResponse
    {
        [JsonPropertyName("encryptedData")]
        public string? EncryptedData { get; set; }
    }

    public class SharedPayload
    {
        public RuleSet? Rules { get; set; }
        public List<string>? Players { get; set; }
        public List<GameResult>? History { get; set; }
        public List<int>? SessionChips { get; set; }
    }

    public class MinifiedPayload
    {
        [JsonPropertyName("r")] public RuleSet? Rules { get; set; }
        [JsonPropertyName("p")] public List<string>? Players { get; set; }
        [JsonPropertyName("c")] public List<int>? SessionChips { get; set; }
        [JsonPropertyName("h")] public List<MinifiedGame>? History { get; set; }
    }

    public class MinifiedGame
    {
        [JsonPropertyName("t")] public long Ticks { get; set; }
        [JsonPropertyName("s")] public List<int?>? RawScores { get; set; }
        [JsonPropertyName("pt")] public List<double>? Points { get; set; }
        [JsonPropertyName("yp")] public List<bool>? YakiPlayers { get; set; }
        [JsonPropertyName("tb")] public List<bool>? TobiBonusRecipients { get; set; }
        [JsonPropertyName("sp")] public List<double>? SinkPoints { get; set; }
        [JsonPropertyName("ypt")] public List<double>? YakiPoints { get; set; }
        [JsonPropertyName("tpt")] public List<double>? TobiPoints { get; set; }
        [JsonPropertyName("cp")] public List<double>? ColdPoints { get; set; }
        [JsonPropertyName("y")] public List<int>? Yen { get; set; }
    }
}