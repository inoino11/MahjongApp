@* 1. 表示モード切替ボタン ＆ リセットボタン *@
<MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 gap-2">
    <div class="d-flex flex-wrap gap-2">
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            <MudButton Variant="@(DisplayMode == 0 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(0)">素点</MudButton>
            <MudButton Variant="@(DisplayMode == 1 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(1)">+/−</MudButton>
            <MudButton Variant="@(DisplayMode == 2 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(2)">円</MudButton>
            <MudButton Variant="@(DisplayMode == 7 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.ShowChart" OnClick="() => SetDisplayMode(7)">グラフ</MudButton>
        </MudStack>
        @if (Rules?.IsSinkEnabled == true || Rules?.IsYakiEnabled == true || Rules?.IsTobiEnabled == true || Rules?.IsColdEnabled == true)
        {
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                @if (Rules?.IsSinkEnabled == true)
                {
                    <MudButton Variant="@(DisplayMode == 3 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Warning" Size="Size.Small" OnClick="() => SetDisplayMode(3)">沈み</MudButton>
                }
                @if (Rules?.IsYakiEnabled == true)
                {
                    <MudButton Variant="@(DisplayMode == 4 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Warning" Size="Size.Small" OnClick="() => SetDisplayMode(4)">焼き鳥</MudButton>
                }
                @if (Rules?.IsTobiEnabled == true)
                {
                    <MudButton Variant="@(DisplayMode == 5 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Info" Size="Size.Small" OnClick="() => SetDisplayMode(5)">トビ</MudButton>
                }
                @if (Rules?.IsColdEnabled == true)
                {
                    <MudButton Variant="@(DisplayMode == 6 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Info" Size="Size.Small" OnClick="() => SetDisplayMode(6)">コールド</MudButton>
                }
            </MudStack>
        }
    </div>
    @if (!IsReadOnly)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="() => OnResetRequested.InvokeAsync()">記録リセット</MudButton>
    }
</MudStack>

@if (DisplayMode == 7)
{
    <style>
        .mud-chart-legend {
            display: none !important;
        }
        @@media (max-width: 959.98px) {
            .custom-legend-item {
                flex: 0 0 calc(50% - 4px);
                min-width: 0;
            }
        }
        @@media (min-width: 960px) {
            .custom-legend-item {
                width: 100%;
            }
        }
    </style>
    @* --- モード7: グラフ表示 --- *@
    <div class="pa-2 pa-md-4 mud-background-gray rounded-lg" style="background-color: rgba(255,255,255,0.02);">
        <div class="d-flex flex-column flex-md-row gap-3">            
            <div style="flex-grow: 1; min-width: 0; width: 100%; overflow-x: auto; overflow-y: hidden; touch-action: pan-x;">
                @{
                    int minWidthPx = Math.Max(400, History.Count * 80 + 80);
                }
                <div style="min-width: max(100%, @(minWidthPx)px); margin-top: -5px;">
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_chartSeries" XAxisLabels="@_xAxisLabels" Width="100%" Height="280px" ChartOptions="@_chartOptions" />
                </div>
            </div>
            <div class="d-flex flex-row flex-wrap flex-md-column gap-2" style="min-width: 140px; align-content: flex-start;">
                <div style="width: 100%;">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">最終pt順</MudText>
                </div>
                @foreach (var stat in _finalStats.OrderByDescending(x => x.TotalPt))
                {
                    <div class="custom-legend-item d-flex align-center px-2 py-1 rounded" style="background: rgba(255,255,255,0.05); border-left: 4px solid @stat.Color;">
                        <div style="flex-grow: 1; overflow: hidden;">
                            <MudText Typo="Typo.body2" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: bold;">
                                @stat.Name
                            </MudText>
                            <MudText Typo="Typo.caption" Style="@(stat.TotalPt >= 0 ? "color: #ff6b6b;" : "color: #4dabf7;")">
                                @(stat.TotalPt > 0 ? "+" : "")@stat.TotalPt.ToString("F1")
                            </MudText>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    @* 2. チップ集計 *@
    @if (!IsReadOnly || Rules?.ChipRate > 0)
    {
        <MudCard Class="mb-4" Elevation="0" Outlined="true">
            <MudCardContent Class="pa-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">チップ集計</MudText>
                <div style="display: flex; width: 100%; flex-wrap: nowrap; align-items: center; gap: 8px; overflow-x: auto; padding-bottom: 4px;">
                    @{
                        bool isChipError = !IsReadOnly && SessionChips.Take(ActiveParticipantCount).Sum() != 0;
                    }
                    <div style="width: 25px; flex-shrink: 0;"></div>
                    @for (int i = 0; i < ActiveParticipantCount; i++)
                    {
                        var idx = i;
                        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
                        string pName = string.IsNullOrWhiteSpace(Players.ElementAtOrDefault(idx)) ? "　" : Players[idx];

                        <div style="flex: 1; min-width: 4.5rem; @(IsReadOnly ? "text-align: center;" : "")">
                            @if (!IsReadOnly)
                            {
                                <MudNumericField T="int" Label="@pName" Value="chip" ValueChanged="@(v => OnChipChanged.InvokeAsync((idx, v)))" Step="1" HideSpinButtons="true" Margin="Margin.Dense" Style="@(isChipError ? "max-width: 4.0rem; color:#ff0000; font-weight:bold;" : "max-width: 4.5rem;")" onfocus="this.select();" />
                            }
                            else
                            {
                                <MudText Align="Align.Center" Typo="Typo.caption" Class="d-block mud-text-secondary" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px;">
                                    @pName
                                </MudText>
                                <MudText Align="Align.Center" Typo="Typo.body1" Style="@(chip > 0 ? "color:#ff0000; font-weight:bold;" : (chip < 0 ? "color:#1976d2; font-weight:bold;" : "color:#9e9e9e;"))">
                                    @(chip > 0 ? $"+{chip}" : chip.ToString())枚
                                </MudText>
                            }
                        </div>
                    }
                    <div style="width: 25px; flex-shrink: 0;"></div>
                </div>
            </MudCardContent>
        </MudCard>
    }

    @* 3. 成績テーブル *@
    <div style="width: 100%; overflow-x: auto;">
        <MudTable Items="@History" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None" Style="width: 100%; table-layout: fixed;">
            @* ... ColGroup, HeaderContent, RowTemplate, FooterContent は以前と同じ (変更なし) ... *@
            <ColGroup>
                <col style="width: 35px;" />
                @for (int i = 0; i < ActiveParticipantCount; i++)
                {
                    <col style="width: 60px;" />
                }
                @if (!IsReadOnly)
                {
                    <col style="width: 30px;" />
                }
            </ColGroup>
            <HeaderContent>
                <MudTh Style="position: sticky; left: 0; background-color: var(--mud-palette-surface); z-index: 2; text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.65rem; letter-spacing: -0.5px;">時刻</MudTh>
                @for (int i = 0; i < ActiveParticipantCount; i++)
                {
                    var idx = i;
                    <MudTh Style="text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.75rem; letter-spacing: -0.5px;">
                        @(string.IsNullOrWhiteSpace(Players.ElementAtOrDefault(idx)) ? "　" : Players[idx])
                    </MudTh>
                }
                @if (!IsReadOnly)
                {
                    <MudTh Style="padding: 4px 0px;"></MudTh>
                }
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="position: sticky; left: 0; background-color: var(--mud-palette-surface); z-index: 1; text-align: center; white-space: nowrap; padding: 4px 0px; font-size: 0.6rem; color: #666; letter-spacing: -0.5px;">
                    @context.Timestamp.ToString("HH:mm")
                </MudTd>
                @for (int i = 0; i < ActiveParticipantCount; i++)
                {
                    var idx = i;
                    <MudTd Style="text-align: center; padding: 4px 0px; white-space: nowrap;">
                        <span style="@GetTdStyle(context, idx)">
                            @GetDisplayValue(context, idx)
                        </span>
                    </MudTd>
                }
                @if (!IsReadOnly)
                {
                    <MudTd Style="text-align: center; white-space: nowrap; padding: 4px 0px;">
                        <span @onclick="() => { }" @onclick:stopPropagation="true">
                            <MudIconButton Icon="@(ArmedDeleteTarget == context ? DeleteEmpty : Icons.Material.Filled.Delete)" Color="@(ArmedDeleteTarget == context ? Color.Error : Color.Default)" Size="Size.Small" Style="@(ArmedDeleteTarget == context ? "padding: 0px;" : "padding: 0px; color: #9e9e9e;")" OnClick="() => OnDeleteRequested.InvokeAsync(context)" />
                        </span>
                    </MudTd>
                }
            </RowTemplate>
            <FooterContent>
                <MudTd Style="position: sticky; left: 0; background-color: var(--mud-palette-surface); z-index: 2; text-align: center; border-top: 2px solid #4caf50; font-weight: bold; white-space: nowrap; padding: 6px 0px; font-size: 0.75rem;">
                    <MudIcon Icon="@(DisplayMode == 0 ? Icons.Material.Filled.Calculate : Icons.Material.Filled.Functions)" Style="font-size: 1rem; vertical-align: text-bottom; margin-right: 2px; color: #2e7d32;" />
                    @(DisplayMode == 0 ? "平均" : "合計")
                </MudTd>
                @for (int i = 0; i < ActiveParticipantCount; i++)
                {
                    var idx = i;
                    <MudTd Style="@($"{GetTotalTdStyle(idx)} text-align: center; padding: 6px 0px; white-space: nowrap;")">
                        <span style="@GetTotalSpanStyle(idx)">
                            @GetTotalDisplayValue(idx)
                        </span>
                    </MudTd>
                }
                @if (!IsReadOnly)
                {
                    <MudTd Style="background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; padding: 6px 0px;"></MudTd>
                }
            </FooterContent>
        </MudTable>
    </div>
}

@code {
    // ... 前回の Parameter 群はそのまま ...
    [Parameter] public List<GameResult> History { get; set; } = new();
    [Parameter] public List<string> Players { get; set; } = new();
    [Parameter] public int ActiveParticipantCount { get; set; }
    [Parameter] public int DisplayMode { get; set; }
    [Parameter] public EventCallback<int> DisplayModeChanged { get; set; }
    [Parameter] public RuleSet Rules { get; set; } = new();
    [Parameter] public List<int> SessionChips { get; set; } = new();
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public GameResult? ArmedDeleteTarget { get; set; }
    [Parameter] public EventCallback<GameResult> OnDeleteRequested { get; set; }
    [Parameter] public EventCallback OnResetRequested { get; set; }
    [Parameter] public EventCallback<(int Index, int Value)> OnChipChanged { get; set; }

    // --- グラフ用データ定義 ---
    private List<ChartSeries<double>> _chartSeries = new();
    private string[] _xAxisLabels = Array.Empty<string>();
    private ChartOptions _chartOptions = new();
    private List<PlayerFinalStat> _finalStats = new();

    private readonly string[] _chartColors = {
        "#FF6B6B", // 赤
        "#4DABF7", // 青
        "#51CF66", // 緑
        "#FCC419", // 黄
        "#FF922B", // 橙
        "#845EF7", // 紫
        "#F06595"  // ピンク
    };

    private class PlayerFinalStat
    {
        public string Name { get; set; } = "";
        public double TotalPt { get; set; }
        public string Color { get; set; } = "";
    }

    protected override void OnParametersSet()
    {
        // 既存の列幅計算ロジック
        CalculateColumnWidths();

        // モード7のとき、グラフデータを更新
        if (DisplayMode == 7)
        {
            PrepareChartData();
        }
    }

    private void PrepareChartData()
    {
        _chartSeries.Clear();
        _finalStats.Clear();
        _chartOptions.ChartPalette = _chartColors;
        int gameCount = History.Count;
        _xAxisLabels = Enumerable.Range(0, gameCount + 1).Select(i => i == 0 ? "Start" : $"{i}局").ToArray();
        for (int i = 0; i < ActiveParticipantCount; i++)
        {
            string pName = string.IsNullOrWhiteSpace(Players.ElementAtOrDefault(i)) ? $"P{i + 1}" : Players[i];
            double cumulative = 0;
            double[] data = new double[gameCount + 1];
            
            data[0] = 0; // 0局目（開始時）は全員0pt
            for (int j = 0; j < gameCount; j++)
            {
                // 抜け番なら加算Ptは0となり、線は水平に維持される
                cumulative += (History[j].Points.Count > i ? History[j].Points[i] : 0);
                data[j + 1] = Math.Round(cumulative, 1);
            }
            string color = _chartColors[i % _chartColors.Length];
            _chartSeries.Add(new ChartSeries<double> { Name = pName, Data = data });
            _finalStats.Add(new PlayerFinalStat { Name = pName, TotalPt = cumulative, Color = color });
        }
    }

    // ... CalculateColumnWidths(), CalculateWidthInCh(), SetDisplayMode() 等の既存メソッド ...
    private string[] _columnWidths = Array.Empty<string>();

    private void CalculateColumnWidths()
    {
        if (_columnWidths.Length != ActiveParticipantCount)
        {
            _columnWidths = new string[ActiveParticipantCount];
        }

        for (int i = 0; i < ActiveParticipantCount; i++)
        {
            string playerName = Players.ElementAtOrDefault(i) ?? "";
            double maxCh = CalculateWidthInCh(playerName);
            if (maxCh < 2.0) maxCh = 2.0;

            foreach (var res in History)
            {
                string s = GetDisplayValue(res, i);
                double ch = CalculateWidthInCh(s);
                if (ch > maxCh) maxCh = ch;
            }

            string totalS = GetTotalDisplayValue(i);
            double totalCh = CalculateWidthInCh(totalS);
            if (totalCh > maxCh) maxCh = totalCh;

            _columnWidths[i] = $"{maxCh + 0.5}ch";
        }
    }

    private double CalculateWidthInCh(string s)
    {
        if (string.IsNullOrEmpty(s)) return 0;
        double width = 0;
        foreach (char c in s)
        {
            if (c == '\uFE0F' || c == '\uFE0E' || c == '\u200D') continue;
            if (c >= 0x00 && c <= 0x7F) width += 1.0;
            else if (char.IsSurrogate(c)) width += 1.0;
            else width += 2.0;
        }
        return width;
    }

    private async Task SetDisplayMode(int mode)
    {
        if (DisplayMode != mode)
        {
            DisplayMode = mode;
            await DisplayModeChanged.InvokeAsync(mode);
        }
    }

    private string FormatPlus(double val, string fmt = "F1") => val > 0 ? $"+{val.ToString(fmt)}" : val.ToString(fmt);

    private string GetDisplayValue(GameResult res, int idx)
    {
        if (idx >= res.RawScores.Count || res.RawScores[idx] == null) return "-";
        return DisplayMode switch
        {
            0 => (res.RawScores[idx] * 100)?.ToString("N0") ?? "-",
            1 => FormatPlus(res.Points[idx]),
            2 => $"{FormatPlus(res.Yen[idx], "N0")}円",
            3 => FormatExtra(res.SinkPoints, idx, "📈", "📉"),
            4 => FormatExtra(res.YakiPoints, idx, "🍴", "🍗"),
            5 => FormatExtra(res.TobiPoints, idx, "🚀", "💥"),
            6 => FormatExtra(res.ColdPoints, idx, "👑", "🏳️"),
            _ => ""
        };

        string FormatExtra(List<double>? list, int i, string posIcon, string negIcon)
        {
            if (list == null || i >= list.Count || list[i] == 0) return "-";
            double pt = list[i];
            return pt > 0 ? $"{posIcon} +{pt:F1}" : $"{negIcon} {pt:F1}";
        }
    }

    private string GetTdStyle(GameResult res, int idx)
    {
        var valList = DisplayMode switch
        {
            0 => res.RawScores.Select(x => (double)(x ?? 0)).ToList(),
            1 => res.Points,
            2 => res.Yen.Select(x => (double)x).ToList(),
            3 => res.SinkPoints?.Count > idx ? res.SinkPoints : new(),
            4 => res.YakiPoints?.Count > idx ? res.YakiPoints : new(),
            5 => res.TobiPoints?.Count > idx ? res.TobiPoints : new(),
            6 => res.ColdPoints?.Count > idx ? res.ColdPoints : new(),
            _ => new()
        };

        if (idx >= valList.Count || idx >= _columnWidths.Length) return "";
        double val = valList[idx];
        string boxWidth = _columnWidths[idx];
        string style = $"display:inline-block; width:{boxWidth}; text-align:right; font-variant-numeric:tabular-nums; font-size:0.8rem; letter-spacing:-0.5px; ";
        if (res.RawScores[idx] == null) return style + "color: #9e9e9e; font-weight: normal; text-align: center;";
        if (DisplayMode >= 3 && val == 0) return style + "color: #9e9e9e; font-weight: normal;";
        bool isPositive = (DisplayMode == 0) ? res.Points[idx] >= 0 : val >= 0;
        style += $"color:{(isPositive ? "#ff0000" : "#1976d2")}; ";
        if (valList.Distinct().Count() > 1 && (val == valList.Max() || val == valList.Min())) style += "font-weight:bold;";
        return style;
    }

    private double GetTotalNumericValue(int idx)
    {
        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
        if (History.Count == 0 && chip == 0) return 0;
        return DisplayMode switch
        {
            0 => History.Any(h => h.RawScores.Count > idx && h.RawScores[idx].HasValue)
                ? History.Where(h => h.RawScores.Count > idx && h.RawScores[idx].HasValue).Average(h => h.RawScores[idx]!.Value) * 100
                : 0,
            1 => History.Sum(h => h.Points.Count > idx ? h.Points[idx] : 0),
            2 => History.Sum(h => h.Yen.Count > idx ? h.Yen[idx] : 0) + (chip * Rules.ChipRate),
            3 => History.Sum(h => h.SinkPoints?.Count > idx ? h.SinkPoints[idx] : 0),
            4 => History.Sum(h => h.YakiPoints?.Count > idx ? h.YakiPoints[idx] : 0),
            5 => History.Sum(h => h.TobiPoints?.Count > idx ? h.TobiPoints[idx] : 0),
            6 => History.Sum(h => h.ColdPoints?.Count > idx ? h.ColdPoints[idx] : 0),
            _ => 0
        };
    }

    private string GetTotalDisplayValue(int idx)
    {
        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
        if (History.Count == 0 && chip == 0) return "0";
        double val = GetTotalNumericValue(idx);
        if (DisplayMode == 0) return Math.Round(val).ToString("N0");
        if (DisplayMode == 2) return FormatPlus(val, "N0") + "円";
        return FormatPlus(val, "F1");
    }

    private string GetTotalTdStyle(int idx) => "background-color: rgba(46, 125, 50, 0.08); border-top: 2px solid #4caf50; ";

    private string GetTotalSpanStyle(int idx)
    {
        if (idx >= _columnWidths.Length) return "";
        string boxWidth = _columnWidths[idx];
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.85rem; letter-spacing: -0.5px; ";
        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
        if (History.Count == 0 && chip == 0) return style;
        var allValues = Enumerable.Range(0, ActiveParticipantCount).Select(GetTotalNumericValue).ToList();
        double val = allValues[idx];
        if (DisplayMode >= 3 && val == 0) return style + "color: #9e9e9e; font-weight: normal; ";
        if (allValues.Distinct().Count() > 1 && (val == allValues.Max() || val == allValues.Min())) style += "font-weight: bold; ";
        bool isPositive = DisplayMode == 0 ? History.Sum(h => h.Points.Count > idx ? h.Points[idx] : 0) >= 0 : val >= 0;
        style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";
        return style;
    }

    private const string DeleteEmpty = "<path d=\"M20.37,8.91L19.37,10.64L7.24,3.64L8.24,1.91L11.28,3.66L12.64,3.29L16.97,5.79L17.34,7.16L20.37,8.91M6,19V7H11.07L18,11V19A2,2 0 0,1 16,21H8A2,2 0 0,1 6,19Z\"/>";
}