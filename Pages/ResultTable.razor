<style>
    /* チップ入力欄の文字を中央揃えにする */
    .chip-input input {
        text-align: center !important;
    }

    /* 最優先でスクロールバーを非表示にするため !important を追加 */
    .sync-chip-scroll {
        -ms-overflow-style: none !important;
        /* IE, Edge用 */
        scrollbar-width: none !important;
        /* Firefox用 */
    }

    /* 最優先でスクロールバーを非表示にするため !important を追加 */
    .sync-chip-scroll::-webkit-scrollbar {
        display: none !important;
        /* Chrome, Safari用 */
    }

    /* テーブル部分のスクロールラッパー（縦スクロールとバー非表示を設定） */
    .sync-table-scroll {
        max-height: 55vh;
        /* 画面高の55%で一旦止める */
        overflow-y: auto !important;
        /* 縦スクロールを有効化 */
        -ms-overflow-style: none !important;
        /* IE, Edge用スクロールバー非表示 */
        scrollbar-width: none !important;
        /* Firefox用スクロールバー非表示 */
    }

    .sync-table-scroll::-webkit-scrollbar {
        display: none !important;
        /* Chrome, Safari用スクロールバー非表示 */
    }

    /* 内部コンテナのスクロールを殺し、外側のJavaScript監視用divにスクロールを一任する */
    .sync-table-scroll .mud-table-container {
        overflow-x: visible !important;
        overflow-y: visible !important;
    }

    /* テーブルの最小幅を設定 */
    .sync-table-scroll .mud-table-container table {
        min-width: var(--table-min-width) !important;
    }

    /* 実測・同期用の新設CSS */
    #result-container {
        width: 100%;
        display: grid;
        grid-template-areas: "content";
        align-items: start;
        min-width: 0;
    }

    /* グラフと表の共通設定。フェードアニメーションを追加 */
    #chart-wrapper,
    #table-wrapper {
        grid-area: content;
        width: 100%;
        transition: opacity 0.5s ease-in-out;
        opacity: 1;
        min-width: 0;
    }

    .hide-element {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        opacity: 0 !important;
        visibility: hidden;
        pointer-events: none;
        z-index: -1;
    }

    /* グラフ描画範囲 */
    .mud-chart-legend {
        display: none !important;
    }

    @@media (max-width: 959.98px) {
        .custom-legend-item {
            flex: 0 0 calc(50% - 4px);
            min-width: 0;
        }
    }

    @@media (min-width: 960px) {
        .custom-legend-item {
            width: 100%;
        }
    }

    /* グラフと凡例の親要素をFlexコンテナにして高さを揃える */
    .chart-flex-container {
        display: flex;
        flex-direction: column;
    }

    @@media (min-width: 960px) {
        .chart-flex-container {
            flex-direction: row;
            align-items: stretch;
        }
    }

    /* 共通: 上下の見切れ防止とSVGのオーバーフロー許可 */
    .responsive-chart-wrapper {
        padding-top: 12px;
        padding-bottom: 12px;
        width: 100%;
        /* 横幅の60%のサイズを高さとする */
        height: 40vw;
        min-height: 150px;
        max-height: 300px;
    }

    @@media (min-width: 960px) {
        .responsive-chart-wrapper {
            height: 100%;
            min-height: 300px;
        }
    }

    .responsive-chart-wrapper svg {
        overflow: visible !important;
    }

    /* チップ入力中（テンキーが開いている対象）をハイライトするスタイル */
    .chip-input-active {
        background-color: rgba(76, 175, 80, 0.15) !important;
        border-radius: 4px;
        box-shadow: 0 0 6px rgba(129, 199, 132, 0.8);
        border-bottom: 1px solid transparent !important;
    }
</style>

@* 1. 表示モード切替ボタン ＆ リセットボタン *@
<MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 gap-2">
    <div class="d-flex flex-wrap gap-2">
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            <MudButton Variant="@(DisplayMode == 0 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(0)">素点</MudButton>
            <MudButton Variant="@(DisplayMode == 1 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(1)">+/−</MudButton>
            <MudButton Variant="@(DisplayMode == 2 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(2)">円</MudButton>
            <MudButton Variant="@(DisplayMode == 7 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Primary" Size="Size.Small" OnClick="() => SetDisplayMode(7)">グラフ</MudButton>
        </MudStack>
        @if (Rules?.IsSinkEnabled == true || Rules?.IsYakiEnabled == true || Rules?.IsTobiEnabled == true || Rules?.IsColdEnabled == true ||
             HasAnySinkPoints || HasAnyYakiPoints || HasAnyTobiPoints || HasAnyColdPoints)
        {
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                @if (Rules?.IsSinkEnabled == true || HasAnySinkPoints)
                {
                    <MudButton Variant="@(DisplayMode == 3 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Warning" Size="Size.Small" OnClick="() => SetDisplayMode(3)">沈み</MudButton>
                }
                @if (Rules?.IsYakiEnabled == true || HasAnyYakiPoints)
                {
                    <MudButton Variant="@(DisplayMode == 4 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Warning" Size="Size.Small" OnClick="() => SetDisplayMode(4)">焼き鳥</MudButton>
                }
                @if (Rules?.IsTobiEnabled == true || HasAnyTobiPoints)
                {
                    <MudButton Variant="@(DisplayMode == 5 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Info" Size="Size.Small" OnClick="() => SetDisplayMode(5)">トビ</MudButton>
                }
                @if (Rules?.IsColdEnabled == true || HasAnyColdPoints)
                {
                    <MudButton Variant="@(DisplayMode == 6 ? Variant.Filled : Variant.Outlined)" DisableElevation="true" Color="Color.Info" Size="Size.Small" OnClick="() => SetDisplayMode(6)">コールド</MudButton>
                }
            </MudStack>
        }
    </div>
    @if (!IsReadOnly)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="() => OnResetRequested.InvokeAsync()">記録リセット</MudButton>
    }
</MudStack>
<div id="result-container">
    @* --- グラフ表示 --- *@
    <div id="chart-wrapper" class="@(DisplayMode == 7 ? "" : "hide-element")">
        <div class="pa-2 pa-md-4 mud-background-gray rounded-lg">
            <div class="chart-flex-container gap-3">
                <div style="flex-grow: 1; min-width: 0; width: 100%;">
                    <div class="responsive-chart-wrapper">
                        <MudChart ChartType="ChartType.Line" ChartSeries="@_chartSeries" XAxisLabels="@_xAxisLabels" Width="100%" Height="100%" ChartOptions="@_chartOptions" />
                    </div>
                </div>
                <div class="d-flex flex-row flex-wrap flex-md-column gap-2" style="min-width: 140px; align-content: flex-start; flex-shrink: 0;">
                    <div style="width: 100%;">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">最終Pt</MudText>
                    </div>
                    @foreach (var stat in _finalStats.OrderByDescending(x => x.TotalPt))
                    {
                        <div class="custom-legend-item d-flex align-center px-2 py-1 rounded" style="background: var(--mud-palette-surface); border-left: 4px solid @stat.Color;">
                            <div style="flex-grow: 1; overflow: hidden;">
                                <MudText Typo="Typo.body2" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: bold;">
                                    @stat.Name
                                </MudText>
                                <MudText Typo="Typo.caption" Style="@(stat.TotalPt >= 0 ? "color: #ff6b6b;" : "color: #4dabf7;")">
                                    @(stat.TotalPt > 0 ? "+" : "")@stat.TotalPt.ToString("F1")
                                </MudText>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    @* --- テーブル表示エリア --- *@
    <div id="table-wrapper" class="@(DisplayMode != 7 ? "" : "hide-element")">
        @* チップ集計 *@
        @if (Rules?.ChipRate > 0)
        {
            <MudCard Class="mb-4" Elevation="0" Outlined="true">
                <MudCardContent Class="py-3 px-0">
                    <div class="d-flex align-center mb-2 px-3">
                        <MudText Typo="Typo.subtitle2" Class="mr-2">チップ集計</MudText>
                        <span style="color: #9e9e9e; font-size: 0.8rem; font-weight: normal; margin-right: auto;">
                            @(Rules?.ChipRate ?? 0)円/枚
                        </span>
                        @if (!IsReadOnly)
                        {
                            int currentChipTotal = SessionChips.Take(ActiveParticipantCount).Sum();
                            if (currentChipTotal != 0)
                            {
                                int neededChip = -currentChipTotal;
                                string neededSign = neededChip > 0 ? "+" : "";
                                <span style="color: var(--mud-palette-error); font-weight: bold; font-size: 0.75rem;">残り@(neededSign)@(neededChip)枚</span>
                            }
                        }
                    </div>
                    <div id="@ChipScrollId" class="sync-chip-scroll" style="width: 100%; overflow-x: auto; padding-bottom: 4px;">
                        @{
                            bool isChipError = !IsReadOnly && SessionChips.Take(ActiveParticipantCount).Sum() != 0;
                        }
                        <div style="display: table; width: 100%; min-width: @GetTableMinWidth(); table-layout: fixed; border-collapse: collapse;">
                            <div style="display: table-row;">
                                <div style="display: table-cell; width: 45px; min-width: 45px; max-width: 45px; box-sizing: border-box; position: sticky; left: -1px; background-color: var(--mud-palette-surface); z-index: 1; padding: 0;"></div>
                                @for (int i = 0; i < ActiveParticipantCount; i++)
                                {
                                    var idx = i;
                                    int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
                                    string pName = string.IsNullOrWhiteSpace(Players.ElementAtOrDefault(idx)) ? " " : Players[idx];
                                    string boxWidth = _columnWidths.Length > idx ? _columnWidths[idx] : "4.5rem";
                                    <div style="display: table-cell; width: @boxWidth; vertical-align: bottom; padding: 0;">
                                        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
                                            <div style="width: @boxWidth; min-width: @boxWidth; height: 0px;"></div>
                                            <MudText Align="Align.Center" Typo="Typo.caption" Class="d-block mud-text-secondary" Style="@($"max-width: {boxWidth}; white-space: nowrap; margin: 0 auto 2px auto; letter-spacing: -0.5px;")">
                                                @GetShortName(Players.ElementAtOrDefault(idx))
                                            </MudText>
                                            @if (!IsReadOnly)
                                            {
                                                string displayValue = ActiveChipInputIndex == idx
                                                    ? ChipInputBuffer
                                                    : (chip == 0 ? "0" : (chip > 0 ? $"+{chip}" : chip.ToString()));
                                                <div @onclick="@(async () => await OnChipInputClicked.InvokeAsync(idx))" @onclick:stopPropagation="true">
                                                    <MudTextField T="string" Value="@displayValue" ReadOnly="true" Margin="Margin.Dense" Class="@($"chip-input {(ActiveChipInputIndex == idx ? "chip-input-active" : "")}")" Style="@(isChipError && ActiveChipInputIndex != idx ? "max-width: 2.5rem; color:#ff0000; font-weight:bold; margin: 0 auto; cursor: pointer;" : "max-width: 2.5rem; margin: 0 auto; cursor: pointer;")" />
                                                </div>
                                            }
                                            else
                                            {
                                                <MudText Align="Align.Center" Typo="Typo.body1" Style="@(chip > 0 ? "color:#ff0000; font-weight:bold;" : (chip < 0 ? "color:#1976d2; font-weight:bold;" : "color:#9e9e9e;"))">
                                                    @(chip > 0 ? $"+{chip}" : chip.ToString())枚
                                                </MudText>
                                            }
                                            <span style="color: #9e9e9e; font-size: 0.6rem; font-variant-numeric: tabular-nums; line-height: 1.2; margin-top: 2px;">
                                                @(FormatPlus(chip * (Rules?.ChipRate ?? 0), "N0")) 円
                                            </span>
                                        </div>
                                    </div>
                                }
                                @if (!IsReadOnly)
                                {
                                    <div style="display: table-cell; width: 30px; padding: 0;"></div>
                                }
                            </div>
                        </div>
                    </div>
                </MudCardContent>
            </MudCard>
        }
        @* テーブル *@
        <div id="@TableScrollId" class="sync-table-scroll" style="width: 100%; overflow-x: auto; --table-min-width: @GetTableMinWidth();">
            <MudTable Items="@History" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None" Style="width: 100%; table-layout: fixed;">
                <ColGroup>
                    <col style="width: 45px;" />
                    @for (int i = 0; i < ActiveParticipantCount; i++)
                    {
                        var idx = i;
                        string colWidth = _columnWidths.Length > idx ? _columnWidths[idx] : "4.5rem";
                        <col style="width: @colWidth;" />
                    }
                    @if (!IsReadOnly)
                    {
                        <col style="width: 30px;" />
                    }
                </ColGroup>
                <HeaderContent>
                    <MudTh Style="position: sticky; top: 0; left: -1px; background-color: var(--mud-palette-surface); z-index: 4; text-align: center; white-space: nowrap; padding: 4px 0px !important; font-size: 0.65rem; letter-spacing: -0.5px; width: 45px; min-width: 45px; max-width: 45px; box-sizing: border-box;">時刻</MudTh>
                    @for (int i = 0; i < ActiveParticipantCount; i++)
                    {
                        var idx = i;
                        string boxWidth = _columnWidths.Length > idx ? _columnWidths[idx] : "4.5rem";
                        <MudTh Style="position: sticky; top: 0; background-color: var(--mud-palette-surface); z-index: 3; text-align: center; padding: 4px 0px !important; font-size: 0.75rem; letter-spacing: -0.5px;">
                            <div style="width: @boxWidth; min-width: @boxWidth; height: 0px; margin: 0 auto;"></div>
                            <div style="max-width: @boxWidth; white-space: nowrap; margin: 0 auto;">
                                @GetShortName(Players.ElementAtOrDefault(idx))
                            </div>
                        </MudTh>
                    }
                    @if (!IsReadOnly)
                    {
                        <MudTh Style="position: sticky; top: 0; background-color: var(--mud-palette-surface); z-index: 3; padding: 4px 0px !important;"></MudTh>
                    }
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="position: sticky; left: -1px; background-color: var(--mud-palette-surface); z-index: 1; text-align: center; white-space: nowrap; padding: 4px 0px !important; font-size: 0.6rem; color: #666; letter-spacing: -0.5px; width: 45px; min-width: 45px; max-width: 45px; box-sizing: border-box;">
                        @context.Timestamp.ToString("HH:mm")
                    </MudTd>
                    @for (int i = 0; i < ActiveParticipantCount; i++)
                    {
                        var idx = i;
                        string cellWidth = _columnWidths.Length > idx ? _columnWidths[idx] : "4.5rem";
                        <MudTd Style="@($"text-align: center; padding: 4px 0px !important; white-space: nowrap; width: {cellWidth}; min-width: {cellWidth}; max-width: {cellWidth};")">
                            <span style="@GetTdStyle(context, idx)">
                                @GetDisplayValue(context, idx)
                            </span>
                        </MudTd>
                    }
                    @if (!IsReadOnly)
                    {
                        <MudTd Style="text-align: center; white-space: nowrap; padding: 4px 0px !important;">
                            <span @onclick="() => { }" @onclick:stopPropagation="true">
                                <MudIconButton Icon="@(ArmedDeleteTarget == context ? DeleteEmpty : Icons.Material.Filled.Delete)" Color="@(ArmedDeleteTarget == context ? Color.Error : Color.Default)" Size="Size.Small" Style="@(ArmedDeleteTarget == context ? "padding: 0px;" : "padding: 0px; color: #9e9e9e;")" OnClick="() => OnDeleteRequested.InvokeAsync(context)" />
                            </span>
                        </MudTd>
                    }
                </RowTemplate>
                <FooterContent>
                    <MudTd Style="position: sticky; bottom: -1px; left: -1px; background: linear-gradient(rgba(46, 125, 50, 0.08), rgba(46, 125, 50, 0.08)), var(--mud-palette-surface); z-index: 4; text-align: center; font-weight: bold; white-space: nowrap; padding: 8px 0px 12px 0px !important; font-size: 0.75rem; width: 45px; min-width: 45px; max-width: 45px; box-sizing: border-box; box-shadow: inset 0 2px 0 0 #4caf50, 0 10px 0 0 var(--mud-palette-surface);">
                        <MudIcon Icon="@(DisplayMode == 0 ? Icons.Material.Filled.Calculate : Icons.Material.Filled.Functions)" Style="font-size: 1rem; vertical-align: text-bottom; margin-right: 2px; color: #2e7d32;" />
                        @(DisplayMode == 0 ? "平均" : "合計")
                    </MudTd>
                    @for (int i = 0; i < ActiveParticipantCount; i++)
                    {
                        var idx = i;
                        string cellWidth = _columnWidths.Length > idx ? _columnWidths[idx] : "4.5rem";
                        <MudTd Style="@($"{GetTotalTdStyle(idx)} position: sticky; bottom: -1px; z-index: 3; text-align: center; padding: 8px 0px 12px 0px !important; white-space: nowrap; width: {cellWidth}; min-width: {cellWidth}; max-width: {cellWidth};")">
                            <span style="@GetTotalSpanStyle(idx)">
                                @GetTotalDisplayValue(idx)
                            </span>
                        </MudTd>
                    }
                    @if (!IsReadOnly)
                    {
                        <MudTd Style="position: sticky; bottom: -1px; z-index: 3; background: linear-gradient(rgba(46, 125, 50, 0.08), rgba(46, 125, 50, 0.08)), var(--mud-palette-surface); padding: 8px 0px 12px 0px !important; box-shadow: inset 0 2px 0 0 #4caf50, 0 10px 0 0 var(--mud-palette-surface);"></MudTd>
                    }
                </FooterContent>
            </MudTable>
        </div>
    </div>
</div>

@code {
    @inject IJSRuntime JSRuntime
    [Parameter] public List<GameResult> History { get; set; } = new();
    [Parameter] public List<string> Players { get; set; } = new();
    [Parameter] public int ActiveParticipantCount { get; set; }
    [Parameter] public int DisplayMode { get; set; }
    [Parameter] public EventCallback<int> DisplayModeChanged { get; set; }
    [Parameter] public RuleSet Rules { get; set; } = new();
    [Parameter] public List<int> SessionChips { get; set; } = new();
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public GameResult? ArmedDeleteTarget { get; set; }
    [Parameter] public EventCallback<GameResult> OnDeleteRequested { get; set; }
    [Parameter] public EventCallback OnResetRequested { get; set; }
    [Parameter] public EventCallback<(int Index, int Value)> OnChipChanged { get; set; }
    [Parameter] public int? ActiveChipInputIndex { get; set; }
    [Parameter] public string ChipInputBuffer { get; set; } = "";
    [Parameter] public EventCallback<int> OnChipInputClicked { get; set; }

    // スクロール要素に個別IDを設定
    private readonly string _uid = Guid.NewGuid().ToString("N");
    private string ChipScrollId => $"chip-{_uid}";
    private string TableScrollId => $"table-{_uid}";

    // --- グラフ用データ定義 ---
    private List<ChartSeries<double>> _chartSeries = new();
    private string[] _xAxisLabels = Array.Empty<string>();
    private LineChartOptions _chartOptions = new();
    private List<PlayerFinalStat> _finalStats = new();

    private class PlayerFinalStat
    {
        public string Name { get; set; } = "";
        public double TotalPt { get; set; }
        public string Color { get; set; } = "";
    }

    // 黄金角を用いて色が被りにくいように自動生成
    private string GenerateColor(int index)
    {
        // 137.508度は黄金角。これを使うと色が被りにくい
        double hue = (index * 137.508) % 360.0;
        // 彩度75%, 明度60%程度に固定し、見やすく目に優しいパステル調ベースにする
        return HslToHex(hue, 0.75, 0.60);
    }

    private string HslToHex(double h, double s, double l)
    {
        double c = (1.0 - Math.Abs(2.0 * l - 1.0)) * s;
        double x = c * (1.0 - Math.Abs((h / 60.0) % 2.0 - 1.0));
        double m = l - c / 2.0;
        double r = 0, g = 0, b = 0;
        if (h >= 0 && h < 60) { r = c; g = x; b = 0; }
        else if (h >= 60 && h < 120) { r = x; g = c; b = 0; }
        else if (h >= 120 && h < 180) { r = 0; g = c; b = x; }
        else if (h >= 180 && h < 240) { r = 0; g = x; b = c; }
        else if (h >= 240 && h < 300) { r = x; g = 0; b = c; }
        else if (h >= 300 && h < 360) { r = c; g = 0; b = x; }
        int rInt = (int)Math.Round((r + m) * 255);
        int gInt = (int)Math.Round((g + m) * 255);
        int bInt = (int)Math.Round((b + m) * 255);
        return $"#{rInt:X2}{gInt:X2}{bInt:X2}";
    }

    protected override void OnParametersSet()
    {
        // 既存の列幅計算ロジック
        CalculateColumnWidths();
        // モード7のとき、グラフデータを更新
        if (DisplayMode == 7) PrepareChartData();
    }

    // スクロール同期
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DisplayMode != 7)
            await JSRuntime.InvokeVoidAsync("syncScroll", ChipScrollId, TableScrollId);
    }

    private void PrepareChartData()
    {
        _chartSeries = new List<ChartSeries<double>>();
        _finalStats = new List<PlayerFinalStat>();
        var chartPalette = Enumerable.Range(0, ActiveParticipantCount).Select(i => GenerateColor(i)).ToArray();
        var newOptions = new LineChartOptions
        {
            ChartPalette = chartPalette,
            MaxNumYAxisTicks = 20
        };
        int gameCount = History.Count;
        _xAxisLabels = Enumerable.Range(0, gameCount + 1).Select(i => i == 0 ? "Start" : $"{i}局").ToArray();
        // グラフの最大値・最小値を求めるための変数
        double maxPt = 0;
        double minPt = 0;
        for (int i = 0; i < ActiveParticipantCount; i++)
        {
            string pName = string.IsNullOrWhiteSpace(Players.ElementAtOrDefault(i)) ? "　" : Players[i];
            double cumulative = 0;
            double[] data = new double[gameCount + 1];
            data[0] = 0;
            for (int j = 0; j < gameCount; j++)
            {
                cumulative += (History[j].Points.Count > i ? History[j].Points[i] : 0);
                data[j + 1] = Math.Round(cumulative, 1);
            }
            double localMax = data.Max();
            double localMin = data.Min();
            if (localMax > maxPt) maxPt = localMax;
            if (localMin < minPt) minPt = localMin;
            string color = chartPalette[i];
            _chartSeries.Add(new ChartSeries<double> { Name = pName, Data = data });
            _finalStats.Add(new PlayerFinalStat { Name = pName, TotalPt = cumulative, Color = color });
        }
        // --- Y軸の刻み幅（よしなに計算） ---
        double range = maxPt - minPt;
        if (range == 0)
        {
            newOptions.YAxisTicks = 10; // 全員0ptの時などのデフォルト
        }
        else
        {
            double roughStep = range / 5.0;
            double magnitude = Math.Pow(10, Math.Floor(Math.Log10(roughStep)));
            double normalizedStep = roughStep / magnitude;
            double niceStep;
            if (normalizedStep < 1.5) niceStep = 1;
            else if (normalizedStep < 3.5) niceStep = 2;
            else if (normalizedStep < 7.5) niceStep = 5;
            else niceStep = 10;
            newOptions.YAxisTicks = Math.Max(1, (int)Math.Round(niceStep * magnitude));
        }
        _chartOptions = newOptions;
    }

    private double[,] _modeWidths = new double[7, 0];

    private string[] _columnWidths = Array.Empty<string>();
    private void CalculateColumnWidths()
    {
        if (_columnWidths.Length != ActiveParticipantCount)
            _columnWidths = new string[ActiveParticipantCount];
        if (_modeWidths.GetLength(1) != ActiveParticipantCount)
            _modeWidths = new double[7, ActiveParticipantCount];
        double absoluteMaxCh = 0;
        for (int i = 0; i < ActiveParticipantCount; i++)
        {
            string shortName = GetShortName(Players.ElementAtOrDefault(i));
            double nameWidthCh = CalculateWidthInCh(shortName);
            double playerMaxCh = nameWidthCh;
            for (int m = 0; m <= 6; m++)
            {
                double modeDataMaxCh = 1.0;
                foreach (var res in History)
                {
                    string s = GetDisplayValue(res, i, m);
                    double ch = CalculateWidthInCh(s);
                    if (ch > modeDataMaxCh) modeDataMaxCh = ch;
                }
                string totalS = GetTotalDisplayValue(i, m);
                double totalCh = CalculateWidthInCh(totalS);
                if (totalCh > modeDataMaxCh) modeDataMaxCh = totalCh;
                _modeWidths[m, i] = modeDataMaxCh;
                if (modeDataMaxCh > playerMaxCh) playerMaxCh = modeDataMaxCh;
            }
            if (playerMaxCh > absoluteMaxCh) absoluteMaxCh = playerMaxCh;
        }
        // 幅が広すぎる場合はここで調整
        double uniformColumnWidth = absoluteMaxCh * 0.65;
        for (int i = 0; i < ActiveParticipantCount; i++)
            _columnWidths[i] = $"{uniformColumnWidth}ch";
    }

    private double CalculateWidthInCh(string s)
    {
        if (string.IsNullOrEmpty(s)) return 0;
        double width = 0;
        foreach (char c in s)
        {
            if (c == '\uFE0F' || c == '\uFE0E' || c == '\u200D') continue;
            if (c == '.') width += 0.4;
            else if (c == '+' || c == '-') width += 1.0;
            else if (c >= 0x00 && c <= 0x7F) width += 1.0;
            else if (char.IsSurrogate(c)) width += 1.0;
            else width += 2.0;
        }
        return width - 0.5;
    }

    private async Task SetDisplayMode(int mode)
    {
        if (DisplayMode != mode)
        {
            DisplayMode = mode;
            if (mode == 7) PrepareChartData();
            await DisplayModeChanged.InvokeAsync(mode);
        }
    }

    private string FormatPlus(double val, string fmt = "F1")
    {
        return val > 0 ? $"+{val.ToString(fmt)}" : val.ToString(fmt);
    }

    private string GetDisplayValue(GameResult res, int idx, int? overrideMode = null)
    {
        int mode = overrideMode ?? DisplayMode;
        string playerName = Players.ElementAtOrDefault(idx) ?? "";
        int originalIdx = res.PlayerNames?.IndexOf(playerName) ?? -1;
        if (originalIdx == -1 || originalIdx >= res.RawScores.Count || res.RawScores[originalIdx] == null) return "-";
        return mode switch
        {
            0 => (res.RawScores[originalIdx] * 100)?.ToString("N0") ?? "-",
            1 => FormatPlus(res.Points[originalIdx]),
            2 => $"{FormatPlus(res.Yen[originalIdx], "N0")}円",
            3 => FormatExtra(res.SinkPoints, originalIdx, "📈", "📉"),
            4 => FormatExtra(res.YakiPoints, originalIdx, "🍴", "🍗"),
            5 => FormatExtra(res.TobiPoints, originalIdx, "🚀", "💥"),
            6 => FormatExtra(res.ColdPoints, originalIdx, "👑", "🏳️"),
            _ => ""
        };
        string FormatExtra(List<double>? list, int i, string posIcon, string negIcon)
        {
            if (list == null || i >= list.Count || list[i] == 0) return "-";
            double pt = list[i];
            return pt > 0 ? $"{posIcon} +{pt:F1}" : $"{negIcon} {pt:F1}";
        }
    }

    private string GetTdStyle(GameResult res, int idx)
    {
        // 列幅が計算できていない場合は空を返す
        if (idx >= _columnWidths.Length) return "";
        double modeWidth = (DisplayMode >= 0 && DisplayMode <= 6 && idx < _modeWidths.GetLength(1)) ? _modeWidths[DisplayMode, idx] : 2.0;
        string boxWidth = $"{modeWidth}ch";
        string baseStyle = $"display:inline-block; width:{boxWidth}; text-align:right; font-variant-numeric:tabular-nums; font-size:0.8rem; letter-spacing:-0.5px; ";
        // ヘッダーからプレイヤー名を取得し、その局(res)でのインデックスを探す
        string playerName = Players.ElementAtOrDefault(idx) ?? "";
        int originalIdx = res.PlayerNames?.IndexOf(playerName) ?? -1;
        // 1. 該当プレイヤーがいない場合、または明示的な抜け番(null)の場合
        if (originalIdx == -1 || originalIdx >= res.RawScores.Count || res.RawScores[originalIdx] == null)
            return baseStyle + "color: #9e9e9e; font-weight: normal; text-align: center;";
        var valList = DisplayMode switch
        {
            0 => res.RawScores.Select(x => (double)(x ?? 0)).ToList(),
            1 => res.Points,
            2 => res.Yen.Select(x => (double)x).ToList(),
            3 => res.SinkPoints,
            4 => res.YakiPoints,
            5 => res.TobiPoints,
            6 => res.ColdPoints,
            _ => new List<double>()
        };
        // 万が一データリストが短かった場合（フォールバック）
        if (valList == null || originalIdx >= valList.Count)
            return baseStyle + "color: #9e9e9e; font-weight: normal; text-align: center;";
        double val = valList[originalIdx];
        string style = baseStyle;
        // 2. 特殊ルール(沈み・焼き鳥など)で変動が0の場合（ハイフン表示になるためCenterに揃える）
        if (DisplayMode >= 3 && val == 0)
            return baseStyle + "color: #9e9e9e; font-weight: normal; text-align: center;";
        // 文字色の設定
        if (DisplayMode == 0)
        {
            // 素点: 既存ルールのまま (持ち点に対してプラスなら赤、マイナスなら青)
            bool isPositive = res.Points[originalIdx] >= 0;
            style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";
        }
        else
        {
            // 素点以外: 正は赤色、負は青色、0は標準テキスト色（黒）
            if (val > 0) style += "color: #ff0000; ";
            else if (val < 0) style += "color: #1976d2; ";
            else style += "color: var(--mud-palette-text-primary); ";
        }
        // トップとラスの太字判定
        if (valList.Distinct().Count() > 1 && (val == valList.Max() || val == valList.Min()))
            style += "font-weight: bold; ";
        return style;
    }

    private double GetTotalNumericValue(int idx, int? overrideMode = null)
    {
        int mode = overrideMode ?? DisplayMode;
        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
        if (History.Count == 0 && chip == 0) return 0;
        string playerName = Players.ElementAtOrDefault(idx) ?? "";
        double? GetVal<T>(System.Collections.Generic.IList<T>? list, System.Collections.Generic.List<string>? names) =>
            (names?.IndexOf(playerName) is int oIdx && oIdx != -1 && list != null && oIdx < list.Count && list[oIdx] is not null)
            ? Convert.ToDouble(list[oIdx]) : null;
        return mode switch
        {
            0 => History.Select(h => GetVal(h.RawScores, h.PlayerNames))
                        .Where(v => v.HasValue)
                        .Select(v => v!.Value)
                        .ToList() is var raws && raws.Count > 0
                        ? raws.Average() * 100 : 0,
            1 => History.Sum(h => GetVal(h.Points, h.PlayerNames) ?? 0),
            2 => History.Sum(h => GetVal(h.Yen, h.PlayerNames) ?? 0) + (chip * Rules.ChipRate),
            3 => History.Sum(h => GetVal(h.SinkPoints, h.PlayerNames) ?? 0),
            4 => History.Sum(h => GetVal(h.YakiPoints, h.PlayerNames) ?? 0),
            5 => History.Sum(h => GetVal(h.TobiPoints, h.PlayerNames) ?? 0),
            6 => History.Sum(h => GetVal(h.ColdPoints, h.PlayerNames) ?? 0),
            _ => 0
        };
    }

    private string GetTotalDisplayValue(int idx, int? overrideMode = null)
    {
        int mode = overrideMode ?? DisplayMode;
        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
        double val = GetTotalNumericValue(idx, mode);
        if (mode == 0) return Math.Round(val).ToString("N0");
        if (mode == 2) return FormatPlus(val, "N0") + "円";
        return FormatPlus(val, "F1");
    }

    private string GetTotalTdStyle(int idx) => "background: linear-gradient(rgba(46, 125, 50, 0.08), rgba(46, 125, 50, 0.08)), var(--mud-palette-surface); box-shadow: inset 0 2px 0 0 #4caf50, 0 10px 0 0 var(--mud-palette-surface); ";

    private string GetTotalSpanStyle(int idx)
    {
        if (idx >= _columnWidths.Length) return "";
        double modeWidth = (DisplayMode >= 0 && DisplayMode <= 6 && idx < _modeWidths.GetLength(1)) ? _modeWidths[DisplayMode, idx] : 2.0;
        string boxWidth = $"{modeWidth}ch";
        string style = $"display: inline-block; width: {boxWidth}; text-align: right; font-variant-numeric: tabular-nums; font-size: 0.85rem; letter-spacing: -0.5px; ";
        int chip = SessionChips.Count > idx ? SessionChips[idx] : 0;
        if (History.Count == 0 && chip == 0) return style;
        var allValues = Enumerable.Range(0, ActiveParticipantCount).Select(i => GetTotalNumericValue(i)).ToList();
        double val = allValues[idx];
        // 文字色の設定
        if (DisplayMode == 0)
        {
            if (History.Count == 0)
            {
                // 対局数0の場合は標準テキスト色
                style += "color: var(--mud-palette-text-primary); ";
            }
            else
            {
                // 素点: 既存ルールのまま
                bool isPositive = GetTotalNumericValue(idx, 1) >= 0;
                style += isPositive ? "color: #ff0000; " : "color: #1976d2; ";
            }
        }
        else
        {
            // 素点以外: 正は赤色、負は青色、0は標準テキスト色（黒）
            if (val > 0) style += "color: #ff0000; ";
            else if (val < 0) style += "color: #1976d2; ";
            else style += "color: var(--mud-palette-text-primary); ";
        }
        // トップとラスの太字判定
        if (allValues.Distinct().Count() > 1 && (val == allValues.Max() || val == allValues.Min()))
            style += "font-weight: bold; ";
        return style;
    }

    private string GetTableMinWidth()
    {
        double totalPx = 45;
        foreach (var w in _columnWidths)
            if (w != null && w.EndsWith("ch"))
                if (double.TryParse(w.Replace("ch", ""), out double ch))
                {
                    totalPx += ch * 8.0;
                    totalPx += 16.0;
                }
        if (!IsReadOnly) totalPx += 30;
        return $"{totalPx + 20}px";
    }

    // データやルールが更新されるたびに自動で呼ばれるメソッド
    protected override async Task OnParametersSetAsync()
    {
        bool isModeInvalid = DisplayMode switch
        {
            3 => !Rules.IsSinkEnabled && !HasAnySinkPoints,
            4 => !Rules.IsYakiEnabled && !HasAnyYakiPoints,
            5 => !Rules.IsTobiEnabled && !HasAnyTobiPoints,
            6 => !Rules.IsColdEnabled && !HasAnyColdPoints,
            _ => false // 素点(0), pt(1), 円(2), グラフ(7)などは常に表示可能とする
        };
        if (isModeInvalid) await SetDisplayMode(1);
        CalculateColumnWidths();
    }

    // 指定文字数を超えたら「...」を付ける
    private string GetShortName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "　";
        return name.Length > 4 ? name.Substring(0, 4) + "..." : name;
    }

    private bool HasAnySinkPoints => History.Any(h => h.SinkPoints != null && h.SinkPoints.Any(pt => pt != 0));
    private bool HasAnyYakiPoints => History.Any(h => h.YakiPoints != null && h.YakiPoints.Any(pt => pt != 0));
    private bool HasAnyTobiPoints => History.Any(h => h.TobiPoints != null && h.TobiPoints.Any(pt => pt != 0));
    private bool HasAnyColdPoints => History.Any(h => h.ColdPoints != null && h.ColdPoints.Any(pt => pt != 0));
