@using MahjongApp.Models
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar

<style>
    @@keyframes flash-highlight {
        0% {
            background-color: rgba(var(--mud-palette-primary-rgb), 0.3);
        }

        100% {
            background-color: transparent;
        }
    }

    .moved-highlight {
        animation: flash-highlight 0.7s ease-out;
    }

    /* バッジの余白と文字サイズを削ってコンパクト化 */
    .rule-badge {
        display: inline-flex;
        align-items: center;
        padding: 1px 6px;
        background-color: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        font-size: 0.7rem;
        color: #ddd;
        white-space: nowrap;
    }
</style>

<MudDialog>
    <DialogContent>
        <div @onclick="ClearArmedState" 
             style="max-height: 55vh; overflow-y: auto; overflow-x: hidden; padding: 4px 8px 12px 4px;">
            @if (Presets == null || Presets.Count == 0)
            {
                <MudText Typo="Typo.body2" Align="Align.Center" Class="py-4">保存済みの設定はありません。</MudText>
            }
            else
            {
                <MudStack Spacing="2">
                    @foreach (var preset in Presets.ToList())
                    {
                        <MudPaper Elevation="0" Outlined="true" 
                                  Class="@($"pa-2 flex-grow-1 {(flashingPresets.Any(p => ReferenceEquals(p, preset)) ? "moved-highlight" : "")}")" 
                                  Style="cursor:pointer; transition: border-color 0.2s;" 
                                  @onclick="() => SelectPreset(preset)">
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:bold; line-height: 1.2;" Color="Color.Primary">@preset.Name</MudText>
                                        @if (IsCustomApplied(preset))
                                        {
                                            <MudTooltip Text="カスタムルール適用中">
                                                <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Secondary" Size="Size.Small" />
                                            </MudTooltip>
                                        }
                                    </MudStack>
                                    <MudStack Row="true" Spacing="0" @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" Color="Color.Default" Disabled="@(Presets.IndexOf(preset) == 0)" OnClick="() => MovePreset(preset, -1)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Color="Color.Default" Disabled="@(Presets.IndexOf(preset) == Presets.Count - 1)" OnClick="() => MovePreset(preset, 1)" />
                                        <MudIconButton Icon="@(armedDeletePreset == preset ? DeleteEmpty : Icons.Material.Filled.Delete)"
                                                       Color="@(armedDeletePreset == preset ? Color.Error : Color.Default)"
                                                       Size="Size.Small"
                                                       Style="@(armedDeletePreset == preset ? "" : "color: #9e9e9e;")"
                                                       OnClick="() => HandleDeleteClick(preset)" />
                                    </MudStack>
                                </MudStack>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    <span class="rule-badge">@(preset.PlayerCount == 3 ? "三麻" : "四麻")</span>
                                    <span class="rule-badge">@($"{preset.StartingPoints} / {preset.ReturnPoints}")</span>
                                    <span class="rule-badge">ウマ: @preset.GetUmaDisplayText()</span>
                                    <span class="rule-badge">レート: @(preset.Rate)</span>
                                    @if (preset.ChipRate > 0)
                                    {
                                        <span class="rule-badge">チップ: @(preset.ChipRate)</span>
                                    }
                                </div>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<RuleSet> Presets { get; set; } = new();

    // 削除待機状態のプリセットを保持
    private RuleSet? armedDeletePreset = null;

    private bool CheckAndDisarm()
    {
        if (armedDeletePreset != null)
        {
            armedDeletePreset = null;
            return true;
        }
        return false;
    }

    private void ClearArmedState()
    {
        CheckAndDisarm();
    }

    private void SelectPreset(RuleSet preset)
    {
        if (CheckAndDisarm()) return;
        MudDialog.Close(DialogResult.Ok(preset));
    }

    private async Task HandleDeleteClick(RuleSet preset)
    {
        if (armedDeletePreset != null && armedDeletePreset != preset)
        {
            CheckAndDisarm();
            return;
        }
        if (armedDeletePreset == preset)
        {
            await DeletePreset(preset);
            armedDeletePreset = null;
        }
        else
        {
            armedDeletePreset = preset;
        }
    }

    private async Task DeletePreset(RuleSet preset)
    {
        Presets.Remove(preset);
        await LocalStorage.SetItemAsync("rulePresets", Presets);
        Snackbar.Add($"設定「{preset.Name}」を削除しました", Severity.Info);
        StateHasChanged(); // UIを更新
    }

    private bool IsCustomApplied(RuleSet p)
    {
        return p.IsCustomUma ||
               p.IsSinkEnabled ||
               p.IsYakiEnabled ||
               p.IsTobiEnabled ||
               p.IsColdEnabled ||
               p.TieBreaker != TieBreakerRule.Kamicha ||
               p.Rounding != RoundingRule.GoshaRokunyu;
    }

    // 複数の発光状態を独立して管理するリスト
    private List<RuleSet> flashingPresets = new();

    // 新しい位置に挿入
    private async Task MovePreset(RuleSet preset, int direction)
    {
        if (CheckAndDisarm()) return;
        int index = Presets.IndexOf(preset);
        int newIndex = index + direction;
        if (newIndex >= 0 && newIndex < Presets.Count)
        {
            Presets.RemoveAt(index);
            Presets.Insert(newIndex, preset);
            await LocalStorage.SetItemAsync("rulePresets", Presets);
            flashingPresets.Add(preset);
            StateHasChanged();
            _ = Task.Run(async () =>
            {
                await Task.Delay(700);
                flashingPresets.RemoveAll(p => ReferenceEquals(p, preset));
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    // 開いたごみ箱のSVG
    private const string DeleteEmpty = "<path d=\"M20.37,8.91L19.37,10.64L7.24,3.64L8.24,1.91L11.28,3.66L12.64,3.29L16.97,5.79L17.34,7.16L20.37,8.91M6,19V7H11.07L18,11V19A2,2 0 0,1 16,21H8A2,2 0 0,1 6,19Z\"/>";
}