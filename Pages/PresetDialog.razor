@using MahjongApp.Models
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (Presets == null || Presets.Count == 0)
        {
            <MudText>保存済みの設定はありません。</MudText>
        }
        else
        {
            <MudDropContainer T="RuleSet" Items="@Presets" ItemsSelector="@((item, dropzone) => true)" ItemDropped="PresetUpdated" Class="d-flex flex-column gap-2">
                <ChildContent>
                    <MudDropZone T="RuleSet" Identifier="presets" AllowReorder="true" Class="mud-h-full" />
                </ChildContent>
                <ItemRenderer>
                    @* foreachの変数が context に変わります *@
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="cursor:grab;" @onclick="() => SelectPreset(context)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:bold;" Color="Color.Primary">@context.Name</MudText>
                            @if (IsCustomApplied(context))
                            {
                                <MudTooltip Text="カスタムルール適用中">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Secondary" Size="Size.Small" />
                                </MudTooltip>
                            }
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.End" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2" Class="mt-1">
                                @(context.PlayerCount == 3 ? "三麻" : "四麻") / @(context.StartingPoints)点持ち / @(context.ReturnPoints)点返し<br />
                                ウマ: @context.GetUmaDisplayText() / レート:@(context.Rate)円
                            </MudText>
                            @* stopPropagationを追加して誤爆を防止 *@
                            <span @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Medium" OnClick="() => DeletePreset(context)" />
                            </span>
                        </MudStack>
                    </MudPaper>
                </ItemRenderer>
            </MudDropContainer>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">閉じる</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<RuleSet> Presets { get; set; } = new();

    private void SelectPreset(RuleSet preset)
    {
        MudDialog.Close(DialogResult.Ok(preset));
    }

    private async Task DeletePreset(RuleSet preset)
    {
        Presets.Remove(preset);
        await LocalStorage.SetItemAsync("rulePresets", Presets);
        Snackbar.Add($"設定「{preset.Name}」を削除しました", Severity.Info);
        StateHasChanged(); // UIを更新
    }

    private bool IsCustomApplied(RuleSet p)
    {
        return p.IsCustomUma ||
               p.IsSinkEnabled ||
               p.IsYakiEnabled ||
               p.IsTobiEnabled ||
               p.IsColdEnabled ||
               p.TieBreaker != TieBreakerRule.Kamicha ||
               p.Rounding != RoundingRule.GoshaRokunyu;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // ドロップされた要素を元の位置から消し、新しい位置に挿入
    private async Task PresetUpdated(MudItemDropInfo<RuleSet> dropItem)
    {
        if (dropItem.Item == null) return;
        Presets.Remove(dropItem.Item);
        Presets.Insert(dropItem.IndexInZone, dropItem.Item);
        await LocalStorage.SetItemAsync(StorageKeys.RulePresets, Presets);
        StateHasChanged();
    }
}