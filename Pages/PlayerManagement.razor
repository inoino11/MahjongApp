@page "/players"
@using MahjongApp.Models
@inject MahjongApp.Services.DatabaseService DatabaseService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white;">
        <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        名簿管理
    </MudText>

    <MudPaper Class="pa-4" Style="background-color: rgba(255,255,255,0.02);">
        @if (isLoading)
        {
            <div class="d-flex justify-center py-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudTable Items="@players" Hover="true" Dense="true" Elevation="0" Style="background: transparent;">
                <HeaderContent>
                    <MudTh>名前</MudTh>
                    <MudTh>通算収支</MudTh>
                    <MudTh>対局数</MudTh>
                    <MudTh>登録日</MudTh>
                    <MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate Context="player">
                    @if (editTargetId == player.Id)
                    {
                        @* 編集モード *@
                        <MudTd>
                            <MudTextField @bind-Value="editName" Margin="Margin.Dense" AutoFocus="true" Label="新しい名前" />
                        </MudTd>
                        <MudTd Style="color: #888; font-style: italic;">
                            @GetTotalYenDisplayText(player.Id) @GetChipYenDetailText(player.Id)
                        </MudTd>
                        <MudTd>@GetGameCount(player.Id)</MudTd>
                        <MudTd>@player.CreatedAt.ToString("yyyy/MM/dd")</MudTd>
                        <MudTd>
                            <MudButton Size="Size.Small" Color="Color.Primary" OnClick="SaveEdit" Class="mr-2">保存</MudButton>
                            <MudButton Size="Size.Small" Color="Color.Default" OnClick="CancelEdit">取消</MudButton>
                        </MudTd>
                    }
                    else if (mergeSourceId == player.Id)
                    {
                        @* ... (統合モードの部分は変更なし) ... *@
                        <MudTd Colspan="4">
                            <div class="d-flex align-center gap-4">
                                <MudText Color="Color.Warning" Typo="Typo.body2" Style="font-weight:bold;">統合先を選択 ➡</MudText>
                                <MudSelect T="string" @bind-Value="mergeTargetId" Margin="Margin.Dense" Style="width: 200px;">
                                    @foreach (var target in players.Where(p => p.Id != player.Id))
                                    {
                                        <MudSelectItem Value="@target.Id">@target.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                        </MudTd>
                        <MudTd>
                            <MudButton Size="Size.Small" Color="Color.Error" Disabled="@string.IsNullOrEmpty(mergeTargetId)" OnClick="ExecuteMerge" Class="mr-2">統合確定</MudButton>
                            <MudButton Size="Size.Small" Color="Color.Default" OnClick="CancelMerge">取消</MudButton>
                        </MudTd>
                    }
                    else
                    {
                        @* 通常表示モード *@
                        <MudTd><strong style="font-size: 1.1rem;">@player.Name</strong></MudTd>
                        <MudTd>
                            @* 総合収支（色付き）と、チップ内訳（小さめのグレー）を並べて表示 *@
                            <span style="@GetTotalYenStyle(player.Id)">
                                @GetTotalYenDisplayText(player.Id)
                            </span>
                            <span style="font-size: 0.85rem; color: #aaa; margin-left: 6px;">
                                @GetChipYenDetailText(player.Id)
                            </span>
                        </MudTd>
                        <MudTd>@GetGameCount(player.Id)</MudTd>
                        <MudTd>@player.CreatedAt.ToString("yyyy/MM/dd")</MudTd>
                        <MudTd>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => StartEdit(player))">名前を変更</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.MergeType" OnClick="@(() => StartMerge(player.Id))">他の名前と統合</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => ConfirmDelete(player))">完全に削除</MudMenuItem>
                            </MudMenu>
                        </MudTd>
                    }
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-8" Style="background-color: rgba(255, 0, 0, 0.05); border: 1px solid #ff4444;">
        <MudText Typo="Typo.h6" Color="Color.Error" Class="mb-2">⚠️ 危険な操作 (Danger Zone)</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">すべてのプレイヤー名簿と対局履歴を完全に消去します。</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="ConfirmWipeAllData">
            全データを初期化する
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private bool isLoading = true;
    private List<PlayerProfile> players = new();
    private List<SavedGameRecord> allGames = new();
    private List<SavedSessionRecord> allSessions = new(); // ★追加：チップ集計用のセッション履歴
    private List<PlayerProfile> rawMasterPlayers = new();

    private string? editTargetId = null;
    private string editName = "";

    private string? mergeSourceId = null;
    private string? mergeTargetId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        
        var dbData = await DatabaseService.GetAllDataAsync();
        if (dbData != null)
        {
            rawMasterPlayers = dbData.Players;
            allGames = dbData.Games;
            allSessions = dbData.Sessions; // ★セッション履歴をロード
            
            players = dbData.Players
                .Where(p => p.Id != "deleted")
                .OrderByDescending(p => GetGameCountSafe(dbData.Games, p.Id))
                .ToList();
        }
        
        isLoading = false;
        StateHasChanged();
    }

    private int GetGameCount(string playerId) => GetGameCountSafe(allGames, playerId);

    private int GetGameCountSafe(List<SavedGameRecord> games, string playerId)
    {
        return games.Count(g => 
        {
            int idx = g.PlayerIds.IndexOf(playerId);
            return idx >= 0 && idx < g.RawScores.Count && g.RawScores[idx].HasValue;
        });
    }

    // 1. ゲーム履歴から「ポイント換算円」のトータルを計算する
    private int GetPlayerTotalGameYen(string playerId)
    {
        int totalGameYen = 0;
        foreach (var game in allGames)
        {
            int idx = game.PlayerIds.IndexOf(playerId);
            if (idx >= 0 && idx < game.Yen.Count)
            {
                totalGameYen += game.Yen[idx];
            }
        }
        return totalGameYen;
    }

    // 2. セッション履歴から「チップ換算円」のトータルを計算する
    private int GetPlayerTotalChipYen(string playerId)
    {
        int totalChipYen = 0;
        foreach (var session in allSessions)
        {
            int idx = session.ParticipantPlayerIds.IndexOf(playerId);
            if (idx >= 0 && idx < session.SettledChips.Count)
            {
                totalChipYen += session.SettledChips[idx] * session.ChipRate;
            }
        }
        return totalChipYen;
    }

    // 3. 総合収支（ゲーム円 ＋ チップ円）を計算する
    private int GetPlayerTotalYen(string playerId) => GetPlayerTotalGameYen(playerId) + GetPlayerTotalChipYen(playerId);

    // 4. UI表示用のテキストとスタイル（総合収支）
    private string GetTotalYenDisplayText(string playerId)
    {
        int yen = GetPlayerTotalYen(playerId);
        if (yen == 0) return "0円";
        return yen > 0 ? $"+{yen:N0}円" : $"{yen:N0}円";
    }

    private string GetTotalYenStyle(string playerId)
    {
        int yen = GetPlayerTotalYen(playerId);
        if (yen == 0) return "";
        return yen > 0 ? "color:#ff6b6b;font-weight:bold;" : "color:#4dabf7;font-weight:bold;";
    }

    // 5. UI表示用のテキスト（内チップ）
    private string GetChipYenDetailText(string playerId)
    {
        int yen = GetPlayerTotalChipYen(playerId);
        string sign = yen > 0 ? "+" : "";
        return $"(内チップ {sign}{yen:N0}円)";
    }

    private void StartEdit(PlayerProfile player)
    {
        editTargetId = player.Id;
        editName = player.Name;
        mergeSourceId = null;
    }

    private void CancelEdit() => editTargetId = null;

    private async Task SaveEdit()
    {
        var player = players.First(p => p.Id == editTargetId);
        
        if (players.Any(p => p.Id != player.Id && p.Name == editName))
        {
            Snackbar.Add("その名前は既に存在します。別名にするか、統合機能を使用してください。", Severity.Warning);
            return;
        }

        player.Name = editName;
        // チップ直接編集は撤廃されたため、名前のみ更新
        
        await DatabaseService.UpdatePlayerAsync(player);
        Snackbar.Add("プレイヤー名を変更しました", Severity.Success);
        
        editTargetId = null;
        await LoadData();
    }

    private void StartMerge(string playerId)
    {
        mergeSourceId = playerId;
        mergeTargetId = null;
        editTargetId = null;
    }

    private void CancelMerge() => mergeSourceId = null;

    private async Task ExecuteMerge()
    {
        if (string.IsNullOrEmpty(mergeSourceId) || string.IsNullOrEmpty(mergeTargetId)) return;

        var sourceName = players.First(p => p.Id == mergeSourceId).Name;
        var targetName = players.First(p => p.Id == mergeTargetId).Name;

        bool? result = await DialogService.ShowMessageBoxAsync(
            "🚨 プレイヤーの統合（名寄せ）",
            $"【{sourceName}】のすべての履歴とチップを、\n【{targetName}】に吸収させます。\n※この操作は取り消せません。実行しますか？",
            yesText: "統合を実行", cancelText: "キャンセル");

        if (result == true)
        {
            await DatabaseService.MergePlayersAsync(mergeSourceId, mergeTargetId);
            Snackbar.Add("統合が完了しました！", Severity.Success);
            mergeSourceId = null;
            await LoadData();
        }
    }

    private async Task ConfirmWipeAllData()
    {
        bool? result1 = await DialogService.ShowMessageBoxAsync(
            "全データの初期化", "すべてのプレイヤー名簿と対局履歴を完全に消去します。よろしいですか？",
            yesText: "はい、消去します", cancelText: "キャンセル");

        if (result1 == true)
        {
            bool? result2 = await DialogService.ShowMessageBoxAsync(
                "最終確認", "本当にすべてのデータを消去しますか？（※絶対に取り消せません）",
                yesText: "完全に消去する", cancelText: "キャンセル");

            if (result2 == true)
            {
                await DatabaseService.ClearAllDataAsync();
                Snackbar.Add("すべてのデータを初期化しました。", Severity.Success);
                await LoadData();
            }
        }
    }

    private async Task ConfirmDelete(PlayerProfile player)
    {
        int gameCount = GetGameCount(player.Id);

        string message = gameCount == 0 
            ? $"【{player.Name}】を削除しますか？\n(対局履歴がないため、完全に消去されます)"
            : $"【{player.Name}】を削除しますか？\n\n⚠️注意: このプレイヤーには {gameCount} 件の対局履歴があります。\n履歴の整合性を保つため、データは「削除済みのプレイヤー(deleted)」へ一括統合されます。";

        bool? result = await DialogService.ShowMessageBoxAsync(
            "プレイヤーの削除確認", message,
            yesText: "削除（統合）する", cancelText: "キャンセル");

        if (result != true) return;

        if (gameCount == 0)
        {
            await DatabaseService.DeletePlayerAsync(player.Id);
            Snackbar.Add($"{player.Name} を削除しました。", Severity.Info);
            await LoadData();
            return;
        }

        var hasDeletedContainer = rawMasterPlayers.Any(p => p.Id == "deleted");
        if (!hasDeletedContainer)
        {
            var deletedProfile = new PlayerProfile
            {
                Id = "deleted",
                Name = "削除済みのプレイヤー",
                CumulativeChips = 0,
                CreatedAt = DateTime.Now
            };
            await DatabaseService.UpdatePlayerAsync(deletedProfile);
        }

        await DatabaseService.MergePlayersAsync(player.Id, "deleted");
        Snackbar.Add($"{player.Name} を削除し、履歴を「削除済みのプレイヤー」に統合しました。", Severity.Success);
        await LoadData();
    }

    
}