@page "/dashboard"
@using MahjongApp.Models
@inject MahjongApp.Services.DatabaseService DatabaseService


<style>
    .align-center-select .mud-input-slot {
        padding-top: 13px !important;
        padding-bottom: 5px !important;
    }

    .sticky-table-col {
        width: 100% !important;
        max-width: 100% !important;
    }

    .sticky-table-col .mud-table-container {
        overflow-x: auto !important;
        overflow-y: auto !important;
        max-height: 270px !important;
        width: 100% !important;
        padding-left: 0 !important;
        clip-path: inset(0) !important;
    }

    .sticky-table-col table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
        width: 100% !important;
    }

    .ranking-table table {
        min-width: 800px !important;
    }

    .matchup-table table {
        min-width: 600px !important;
    }

    .sticky-table-col th {
        position: -webkit-sticky !important;
        position: sticky !important;
        top: -1px !important;
        background-color: #1e1e1e !important;
        z-index: 1 !important;
        box-shadow: 0 -2px 0 0 #1e1e1e !important;
    }

    .sticky-table-col th:first-child,
    .sticky-table-col td:first-child {
        position: -webkit-sticky !important;
        position: sticky !important;
        left: 0 !important;
        background-color: #1e1e1e !important;
        border-right: 1px solid rgba(255, 255, 255, 0.1) !important;
    }

    .sticky-table-col th:first-child {
        top: -1px !important;
        z-index: 4 !important;
        box-shadow: -2px -2px 0 0 #1e1e1e !important;
    }

    .sticky-table-col td:first-child {
        z-index: 2 !important;
        box-shadow: -2px 0 0 0 #1e1e1e !important;
    }

    .sticky-table-col th,
    .sticky-table-col td {
        white-space: nowrap !important;
    }
</style>
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white;">
        <MudIcon Icon="@Icons.Material.Filled.QueryStats" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        通算成績
    </MudText>
    @if (isLoading)
    {
        <div class="d-flex flex-column align-center justify-center py-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">データを集計中...</MudText>
        </div>
    }
    else
    {
        @* 四麻・三麻の切り替えタブ（相性データと、それぞれのレイアウトマネージャーを渡す） *@
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Dark">
            <MudTabPanel Text="四人麻雀">
                @RenderTabContent("四麻", stats4, matchupStats4, 4, _rank4Layout, _matchupLayout4)
            </MudTabPanel>
            <MudTabPanel Text="三人麻雀">
                @RenderTabContent("三麻", stats3, matchupStats3, 3, _rank3Layout, _matchupLayout3)
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    // --- ランキングテーブルを共通化するRenderFragment ---
    private RenderFragment RenderTabContent(string title, List<PlayerStats> stats, List<MatchupStat> matchupList, int playerCount, TableLayoutManager layout, TableLayoutManager matchupLayout) => __builder =>
    {
        <text>
            @if (stats == null || stats.Count == 0)
            {
                <MudText Typo="Typo.body1" Align="Align.Center" Class="py-10">@(playerCount == 4 ? "四麻" : "三麻")のデータはまだありません。</MudText>
            }
            else
            {
                var top = stats.First();
                @* --- トッププレイヤーメトリクス --- *@
                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-3 d-flex flex-column align-center justify-center" Style="height: 100%; width: 100%; background-color: rgba(255,255,255,0.05);">
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">@(playerCount == 4 ? "四麻" : "三麻")トップ (@top.Name)</MudText>
                            <MudText Typo="Typo.h4" Style="@(top.TotalYen >= 0 ? "color: #ff6b6b; font-weight: bold;" : "color: #4dabf7; font-weight: bold;")">
                                @(top.TotalYen > 0 ? "+" : "")@top.TotalYen.ToString("N0")<span style="font-size: 1rem;">円</span>
                            </MudText>
                            <div class="d-flex gap-3 mt-1" style="font-size: 0.75rem; color: #aaaaaa;">
                                <span>Pt: @(top.TotalGameYen > 0 ? "+" : "")@top.TotalGameYen.ToString("N0")円</span>
                                <span>チップ: @(top.TotalChipYen > 0 ? "+" : "")@top.TotalChipYen.ToString("N0")円</span>
                            </div>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-3 d-flex flex-column align-center justify-center" Style="height: 100%; width: 100%; background-color: rgba(255,255,255,0.05);">
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">平均順位</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: bold;">@top.AverageRank.ToString("F2")<span style="font-size: 1rem; color: #9e9e9e;"> 位</span></MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                @* --- ランキングテーブル --- *@
                <MudPaper Class="pa-4 mt-2" Style="background-color: rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2 mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Leaderboard" />
                        @(title) ランキング
                    </MudText>
                    <MudTable T="PlayerStats" Items="@stats" Class="sticky-table-col ranking-table" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None" Style="background: transparent;">
                        <HeaderContent>
                            @for (int i = 0; i < RankHeaders.Length; i++)
                            {
                                var colIndex = i;
                                var headerText = RankHeaders[colIndex];
                                // 総合Pt(2) と 総合収支(3) だけ緑色にするルール
                                var colorStyle = (colIndex == 2 || colIndex == 3) ? "color:#4caf50;" : "";
                                <MudTh Style="@(layout.GetTdStyle(colIndex))">
                                    <MudText Typo="Typo.caption" Align="Align.Center" Style="@($"font-weight: bold; white-space: nowrap; {colorStyle}")">
                                        @headerText
                                    </MudText>
                                </MudTh>
                            }
                        </HeaderContent>
                        <RowTemplate Context="stat">
                            <MudTd Style="@(layout.GetTdStyle(0))"><span style="font-weight: bold;">@GetShortName(stat.Name)</span></MudTd>
                            <MudTd Style="@(layout.GetTdStyle(1))">
                                <div style="@(layout.GetDataStyle(1))">@stat.TotalGames 局</div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(2, "background-color: rgba(76, 175, 80, 0.05);"))">
                                <div style="@(layout.GetDataStyle(2, stat.TotalPoint >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;"))">
                                    @(stat.TotalPoint > 0 ? "+" : "")@stat.TotalPoint.ToString("F1")
                                </div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(3, "background-color: rgba(76, 175, 80, 0.05);"))">
                                <div style="@(layout.GetDataStyle(3, stat.TotalYen >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;"))">
                                    @(stat.TotalYen > 0 ? "+" : "")@stat.TotalYen.ToString("N0")円
                                </div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(4))">
                                <div style="@(layout.GetDataStyle(4, "color:#aaa; font-size:0.85rem;"))">@(stat.TotalGameYen > 0 ? "+" : "")@stat.TotalGameYen.ToString("N0")円</div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(5))">
                                <div style="@(layout.GetDataStyle(5, "color:#aaa; font-size:0.85rem;"))">@(stat.TotalChipYen > 0 ? "+" : "")@stat.TotalChipYen.ToString("N0")円</div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(6))">
                                <div style="@(layout.GetDataStyle(6))">@stat.AverageRank.ToString("F2")</div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(7))">
                                <div style="@(layout.GetDataStyle(7))">@stat.FirstPlaceRate.ToString("F1")%</div>
                            </MudTd>
                            <MudTd Style="@(layout.GetTdStyle(8))">
                                <div style="@(layout.GetDataStyle(8))">@stat.AvoidLastPlaceRate(playerCount).ToString("F1")%</div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
                @* --- 相性分析エリア (タブ内に移動 & ルール別に分離) --- *@
                <MudPaper Class="pa-4 mt-6" Style="background-color: rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2 mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Handshake" />
                        @(title) 相性分析
                    </MudText>
                    @* 分析対象プレイヤーの選択（タブの上にグローバルに配置） *@
                    <div class="mb-4" style="max-width: 150px;">
                        <MudSelect T="string" Label="分析対象プレイヤー" Value="@selectedHeroId" ValueChanged="OnHeroSelected" Class="align-center-select">
                            @foreach (var player in availablePlayers)
                            {
                                <MudSelectItem Value="@player.Id">@player.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    @if (!stats.Any(s => s.Id == selectedHeroId))
                    {
                        <MudText Color="Color.Secondary" Class="mt-2 pa-4" Style="background-color: rgba(255,255,255,0.01); border-radius: 4px; text-align: center;">
                            対象者の対局履歴がありません。
                        </MudText>
                    }
                    else if (matchupList.Count > 0)
                    {
                        <MudTable T="MatchupStat" Items="@matchupList" Class="sticky-table-col matchup-table" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.None" Style="background: transparent;">
                            <HeaderContent>
                                @for (int i = 0; i < MatchupHeaders.Length; i++)
                                {
                                    var colIndex = i;
                                    var headerText = MatchupHeaders[colIndex];
                                    var colorStyle = (colIndex == 2 || colIndex == 3) ? "color:#4caf50;" : "";
                                    <MudTh Style="@(matchupLayout.GetTdStyle(colIndex))">
                                        <MudText Typo="Typo.caption" Align="Align.Center" Style="@($"font-weight: bold; white-space: nowrap; {colorStyle}")">
                                            @headerText
                                        </MudText>
                                    </MudTh>
                                }
                            </HeaderContent>
                            <RowTemplate Context="mStat">
                                <MudTd Style="@(matchupLayout.GetTdStyle(0))"><span style="font-weight: bold;">@GetShortName(mStat.OpponentName)</span></MudTd>
                                <MudTd Style="@(matchupLayout.GetTdStyle(1))">
                                    <div style="@(matchupLayout.GetDataStyle(1))">@mStat.GamesTogether 局</div>
                                </MudTd>
                                <MudTd Style="@(matchupLayout.GetTdStyle(2, mStat.HeroNetPoint >= 0 ? "background-color: rgba(76, 175, 80, 0.05);" : "background-color: rgba(244, 67, 54, 0.05);"))">
                                    <div style="@(matchupLayout.GetDataStyle(2, mStat.HeroNetPoint >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;"))">
                                        @(mStat.HeroNetPoint > 0 ? "+" : "")@mStat.HeroNetPoint.ToString("F1")
                                    </div>
                                </MudTd>
                                <MudTd Style="@(matchupLayout.GetTdStyle(3, mStat.HeroNetYen >= 0 ? "background-color: rgba(76, 175, 80, 0.05);" : "background-color: rgba(244, 67, 54, 0.05);"))">
                                    <div style="@(matchupLayout.GetDataStyle(3, mStat.HeroNetYen >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;"))">
                                        @(mStat.HeroNetYen > 0 ? "+" : "")@mStat.HeroNetYen.ToString("N0")円
                                    </div>
                                </MudTd>
                                <MudTd Style="@(matchupLayout.GetTdStyle(4))">
                                    <div style="@(matchupLayout.GetDataStyle(4))">@mStat.HeroWins 勝 - @mStat.HeroLosses 負</div>
                                </MudTd>
                                <MudTd Style="@(matchupLayout.GetTdStyle(5))">
                                    <div style="@(matchupLayout.GetDataStyle(5))">@mStat.DirectWinRate.ToString("F1")%</div>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary" Class="mt-2">同卓データがありません。</MudText>
                    }
                </MudPaper>
            }
        </text>
    };

    // --- ヘッダー定義の一元管理---
    private static readonly string[] RankHeaders = { "名前", "対局数", "総合Pt", "総合収支", "(Pt収支)", "(チップ収支)", "平均順位", "トップ率", "ラス回避率" };
    private static readonly string[] MatchupHeaders = { "相手", "同卓数", "Pt差", "収支差", "直接対決", "先着率" };

    // --- 集計結果を画面にバインドするためのViewModel ---
    private class PlayerStats
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int TotalGames { get; set; }
        public double TotalPoint { get; set; }
        // --- 収支関連（新設） ---
        public int TotalGameYen { get; set; } // ポイントによる収支
        public int TotalChipYen { get; set; } // チップによる収支
        public int TotalYen => TotalGameYen + TotalChipYen; // 総合収支
        public int[] RankCounts { get; set; } = new int[4];
        public double AverageRank => TotalGames == 0 ? 0 : RankCounts.Select((count, index) => count * (index + 1)).Sum() / (double)TotalGames;
        public double FirstPlaceRate => TotalGames == 0 ? 0 : (double)RankCounts[0] / TotalGames * 100;
        public double AvoidLastPlaceRate(int playerCount) => 
            TotalGames == 0 ? 0 : (1.0 - (double)RankCounts[playerCount - 1] / TotalGames) * 100;
    }

    private bool isLoading = true;

    // 三麻・四麻ごとの集計リスト
    private List<PlayerStats> stats4 = new();
    private List<PlayerStats> stats3 = new();

    // 総合収支（全ルール＋チップ合算）の算出用
    private string topPlayerName = "データなし";
    private int totalYenAllRules = 0;
    private int totalGameYenAllRules = 0;
    private int totalChipYenAllRules = 0;
    private double topPlayerAverageRank = 0;

    // --- 相性分析用の変数 (四麻・三麻で分離) ---
    private List<PlayerProfile> availablePlayers = new();
    private List<SavedGameRecord> allGames = new();
    private string? selectedHeroId;
    private List<MatchupStat> matchupStats4 = new();
    private List<MatchupStat> matchupStats3 = new();

    // --- レイアウト管理クラスのインスタンス ---
    private TableLayoutManager _rank4Layout = new(9);
    private TableLayoutManager _rank3Layout = new(9);
    private TableLayoutManager _matchupLayout4 = new(6);
    private TableLayoutManager _matchupLayout3 = new(6);

    private class MatchupStat
    {
        public string OpponentName { get; set; } = "";
        public int GamesTogether { get; set; }
        public double HeroNetPoint { get; set; }
        public int HeroNetYen { get; set; }
        public int HeroWins { get; set; }
        public int HeroLosses { get; set; }
        public double DirectWinRate => (HeroWins + HeroLosses) == 0 ? 0 : (double)HeroWins / (HeroWins + HeroLosses) * 100;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAndCalculateStatsAsync();
        isLoading = false;
    }

    private async Task LoadAndCalculateStatsAsync()
    {
        try
        {
            var dbData = await DatabaseService.GetAllDataAsync();
            if (dbData == null || dbData.Players.Count == 0 || dbData.Games.Count == 0) return;
            allGames = dbData.Games;
            availablePlayers = dbData.Players.Where(p => p.Id != "deleted").OrderBy(p => p.Name).ToList();
            var statsMap4 = dbData.Players.ToDictionary(p => p.Id, p => new PlayerStats { Id = p.Id, Name = p.Name });
            var statsMap3 = dbData.Players.ToDictionary(p => p.Id, p => new PlayerStats { Id = p.Id, Name = p.Name });

            // 1. 局データ（ゲーム収支とポイント）を集計
            foreach (var game in dbData.Games)
            {
                bool isSanma = game.PlayerCount == 3;
                var currentMap = isSanma ? statsMap3 : statsMap4;
                var validPlayers = game.PlayerIds
                    .Select((id, idx) => new { Id = id, Score = game.RawScores.Count > idx ? game.RawScores[idx] : null, Index = idx })
                    .Where(x => !string.IsNullOrEmpty(x.Id) && x.Score.HasValue)
                    .OrderByDescending(x => x.Score)
                    .ToList();
                for (int rank = 0; rank < validPlayers.Count; rank++)
                {
                    var p = validPlayers[rank];
                    if (currentMap.ContainsKey(p.Id!))
                    {
                        var stat = currentMap[p.Id!];
                        var idx = p.Index;
                        stat.TotalGames++;
                        stat.RankCounts[rank]++;
                        stat.TotalPoint += game.Points.Count > idx ? game.Points[idx] : 0;
                        stat.TotalGameYen += game.Yen.Count > idx ? game.Yen[idx] : 0;
                    }
                }
            }

            // 2. セッション記録からチップ収支を集計
            foreach (var session in dbData.Sessions)
            {
                // そのセッションが三麻か四麻かを、紐づく最初のゲームから判定する
                var firstGame = dbData.Games.FirstOrDefault(g => g.SessionId == session.SessionId);
                bool isSanmaSession = firstGame != null && firstGame.PlayerCount == 3;
                var currentMap = isSanmaSession ? statsMap3 : statsMap4;
                for (int i = 0; i < session.ParticipantPlayerIds.Count; i++)
                {
                    string pId = session.ParticipantPlayerIds[i];
                    if (!string.IsNullOrEmpty(pId) && currentMap.ContainsKey(pId) && session.SettledChips.Count > i)
                    {
                        // チップ枚数 × 当時のチップレートを円として加算
                        currentMap[pId].TotalChipYen += session.SettledChips[i] * session.ChipRate;
                    }
                }
            }

            // 3. システム用の "deleted" を除外し、総合収支（TotalYen）順にソート
            stats4 = statsMap4.Values.Where(s => s.Id != "deleted" && s.TotalGames > 0).OrderByDescending(s => s.TotalYen).ToList();
            stats3 = statsMap3.Values.Where(s => s.Id != "deleted" && s.TotalGames > 0).OrderByDescending(s => s.TotalYen).ToList();

            // 4. 相性分析の初期化（デフォルトで四麻のトッププレイヤーを選択、いなければ三麻から）
            if (string.IsNullOrEmpty(selectedHeroId))
            {
                var defaultHero = stats4.FirstOrDefault() ?? stats3.FirstOrDefault();
                selectedHeroId = defaultHero?.Id;
            }

            CalculateMatchups();
            CalculateDashboardWidths();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ダッシュボードの集計エラー: {ex.Message}");
        }
    }

    private void OnHeroSelected(string id)
    {
        selectedHeroId = id;
        CalculateMatchups();
        CalculateDashboardWidths();
    }

    private void CalculateMatchups()
    {
        // 四麻(4)と三麻(3)をそれぞれ別ロジックで抽出
        matchupStats4 = CalculateMatchupsForPlayerCount(4);
        matchupStats3 = CalculateMatchupsForPlayerCount(3);
    }

    private List<MatchupStat> CalculateMatchupsForPlayerCount(int playerCount)
    {
        var result = new List<MatchupStat>();
        if (string.IsNullOrEmpty(selectedHeroId)) return result;
        var map = new Dictionary<string, MatchupStat>();

        // 指定されたプレイヤーカーウント（4または3）の局のみに絞り込む
        foreach (var game in allGames.Where(g => g.PlayerCount == playerCount))
        {
            int heroIdx = game.PlayerIds.IndexOf(selectedHeroId);
            if (heroIdx < 0 || heroIdx >= game.RawScores.Count || !game.RawScores[heroIdx].HasValue) continue;

            double heroPt = game.Points.Count > heroIdx ? game.Points[heroIdx] : 0;
            int heroYen = game.Yen.Count > heroIdx ? game.Yen[heroIdx] : 0;
            double heroRaw = game.RawScores[heroIdx]!.Value;

            for (int i = 0; i < game.PlayerIds.Count; i++)
            {
                string? oppId = game.PlayerIds[i];
                if (string.IsNullOrEmpty(oppId) || oppId == "deleted" || oppId == selectedHeroId) continue;
                if (!game.RawScores[i].HasValue) continue;
                if (!map.ContainsKey(oppId))
                    map[oppId] = new MatchupStat { OpponentName = availablePlayers.FirstOrDefault(p => p.Id == oppId)?.Name ?? "不明" };
                var stat = map[oppId];
                stat.GamesTogether++;
                double oppPt = game.Points.Count > i ? game.Points[i] : 0;
                int oppYen = game.Yen.Count > i ? game.Yen[i] : 0;
                stat.HeroNetPoint += (heroPt - oppPt);
                stat.HeroNetYen += (heroYen - oppYen);

                double oppRaw = game.RawScores[i]!.Value;
                if (heroRaw > oppRaw) stat.HeroWins++;
                else if (heroRaw < oppRaw) stat.HeroLosses++;
            }
        }
        return map.Values.OrderByDescending(s => s.HeroNetYen).ToList();
    }

    // --- 各列の幅計算ロジック（TableLayoutManagerへ委譲） ---
    private void CalculateDashboardWidths()
    {
        // 毎回新規インスタンスでリセットし、古いキャッシュを破棄する
        _rank4Layout = new TableLayoutManager(9);
        _rank3Layout = new TableLayoutManager(9);
        _matchupLayout4 = new TableLayoutManager(6);
        _matchupLayout3 = new TableLayoutManager(6);

        // 1. 四麻ランキングのデータ幅を計算
        foreach (var stat in stats4)
        {
            _rank4Layout.UpdateDataWidth(0, GetShortName(stat.Name));
            _rank4Layout.UpdateDataWidth(1, stat.TotalGames.ToString() + " 局");
            _rank4Layout.UpdateDataWidth(2, (stat.TotalPoint > 0 ? "+" : "") + stat.TotalPoint.ToString("F1"));
            _rank4Layout.UpdateDataWidth(3, (stat.TotalYen > 0 ? "+" : "") + stat.TotalYen.ToString("N0") + "円");
            _rank4Layout.UpdateDataWidth(4, (stat.TotalGameYen > 0 ? "+" : "") + stat.TotalGameYen.ToString("N0") + "円");
            _rank4Layout.UpdateDataWidth(5, (stat.TotalChipYen > 0 ? "+" : "") + stat.TotalChipYen.ToString("N0") + "円");
            _rank4Layout.UpdateDataWidth(6, stat.AverageRank.ToString("F2"));
            _rank4Layout.UpdateDataWidth(7, stat.FirstPlaceRate.ToString("F1") + "%");
            _rank4Layout.UpdateDataWidth(8, stat.AvoidLastPlaceRate(4).ToString("F1") + "%");
        }

        // 2. 三麻ランキングのデータ幅を計算
        foreach (var stat in stats3)
        {
            _rank3Layout.UpdateDataWidth(0, GetShortName(stat.Name));
            _rank3Layout.UpdateDataWidth(1, stat.TotalGames.ToString() + " 局");
            _rank3Layout.UpdateDataWidth(2, (stat.TotalPoint > 0 ? "+" : "") + stat.TotalPoint.ToString("F1"));
            _rank3Layout.UpdateDataWidth(3, (stat.TotalYen > 0 ? "+" : "") + stat.TotalYen.ToString("N0") + "円");
            _rank3Layout.UpdateDataWidth(4, (stat.TotalGameYen > 0 ? "+" : "") + stat.TotalGameYen.ToString("N0") + "円");
            _rank3Layout.UpdateDataWidth(5, (stat.TotalChipYen > 0 ? "+" : "") + stat.TotalChipYen.ToString("N0") + "円");
            _rank3Layout.UpdateDataWidth(6, stat.AverageRank.ToString("F2"));
            _rank3Layout.UpdateDataWidth(7, stat.FirstPlaceRate.ToString("F1") + "%");
            _rank3Layout.UpdateDataWidth(8, stat.AvoidLastPlaceRate(3).ToString("F1") + "%");
        }

        // 3. 四麻相性のデータ幅を計算
        foreach (var stat in matchupStats4)
        {
            _matchupLayout4.UpdateDataWidth(0, GetShortName(stat.OpponentName));
            _matchupLayout4.UpdateDataWidth(1, stat.GamesTogether + " 局");
            _matchupLayout4.UpdateDataWidth(2, (stat.HeroNetYen > 0 ? "+" : "") + stat.HeroNetYen.ToString("N0") + "円");
            _matchupLayout4.UpdateDataWidth(3, (stat.HeroNetPoint > 0 ? "+" : "") + stat.HeroNetPoint.ToString("F1"));
            _matchupLayout4.UpdateDataWidth(4, stat.HeroWins + " 勝 - " + stat.HeroLosses + " 負");
            _matchupLayout4.UpdateDataWidth(5, stat.DirectWinRate.ToString("F1") + "%");
        }

        // 4. 三麻相性のデータ幅を計算
        foreach (var stat in matchupStats3)
        {
            _matchupLayout3.UpdateDataWidth(0, GetShortName(stat.OpponentName));
            _matchupLayout3.UpdateDataWidth(1, stat.GamesTogether + " 局");
            _matchupLayout3.UpdateDataWidth(2, (stat.HeroNetYen > 0 ? "+" : "") + stat.HeroNetYen.ToString("N0") + "円");
            _matchupLayout3.UpdateDataWidth(3, (stat.HeroNetPoint > 0 ? "+" : "") + stat.HeroNetPoint.ToString("F1"));
            _matchupLayout3.UpdateDataWidth(4, stat.HeroWins + " 勝 - " + stat.HeroLosses + " 負");
            _matchupLayout3.UpdateDataWidth(5, stat.DirectWinRate.ToString("F1") + "%");
        }

        // 5. ランキングテーブルのヘッダー幅を列幅に反映（一元管理された配列を使用）
        for (int i = 0; i < RankHeaders.Length; i++)
        {
            _rank4Layout.UpdateHeaderWidth(i, RankHeaders[i]);
            _rank3Layout.UpdateHeaderWidth(i, RankHeaders[i]);
        }

        // 6. 相性テーブルのヘッダー幅を列幅に反映（一元管理された配列を使用）
        for (int i = 0; i < MatchupHeaders.Length; i++)
        {
            _matchupLayout4.UpdateHeaderWidth(i, MatchupHeaders[i]);
            _matchupLayout3.UpdateHeaderWidth(i, MatchupHeaders[i]);
        }
    }

    private string GetShortName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "　";
        return name.Length > 4 ? name.Substring(0, 4) + "..." : name;
    }
}