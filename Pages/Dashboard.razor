@page "/dashboard"
@using MahjongApp.Models

<style>
    /* セレクトボックスの文字が上に寄る現象の補正 */
    .align-center-select .mud-input-slot {
        padding-top: 13px !important; /* 上の余白を増やして文字を押し下げる */
        padding-bottom: 5px !important; /* 下の余白を減らす */
    }
</style>
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white;">
        <MudIcon Icon="@Icons.Material.Filled.QueryStats" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        成績ダッシュボード
    </MudText>

    @if (isLoading)
    {
        <div class="d-flex flex-column align-center justify-center py-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">データを集計中...</MudText>
        </div>
    }
    else
    {
        @* --- Hero Metrics (全ルール合算の最重要指標) --- *@
        <MudGrid Spacing="3" Class="mb-6">
            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4 d-flex flex-column align-center justify-center" Style="min-height: 120px; background-color: rgba(255,255,255,0.05);">
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">トッププレイヤー総合収支 (@topPlayerName)</MudText>
                    <MudText Typo="Typo.h3" Style="@(totalYenAllRules >= 0 ? "color: #ff6b6b; font-weight: bold;" : "color: #4dabf7; font-weight: bold;")">
                        @(totalYenAllRules > 0 ? "+" : "")@totalYenAllRules.ToString("N0")<span style="font-size: 1.2rem;">円</span>
                    </MudText>
                    @* ポイントとチップの内訳表示 *@
                    <div class="d-flex gap-4 mt-1" style="font-size: 0.85rem; color: #aaaaaa;">
                        <span>ポイント: @(totalGameYenAllRules > 0 ? "+" : "")@totalGameYenAllRules.ToString("N0")円</span>
                        <span>チップ: @(totalChipYenAllRules > 0 ? "+" : "")@totalChipYenAllRules.ToString("N0")円</span>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4 d-flex flex-column align-center justify-center" Style="min-height: 120px; background-color: rgba(255,255,255,0.05);">
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">平均順位 (合算)</MudText>
                    <MudText Typo="Typo.h3" Style="font-weight: bold;">@(topPlayerAverageRank > 0 ? topPlayerAverageRank.ToString("F2") : "-")<span style="font-size: 1rem; color: #9e9e9e;"> 位</span></MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
        @* 四麻・三麻の切り替えタブ *@
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Dark">
            <MudTabPanel Text="四人麻雀" Icon="@Icons.Material.Filled.People">
                <MudPaper Class="pa-4" Style="background-color: rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.h6" Class="mb-4">基本成績ランキング (四麻)</MudText>
                    <div style="overflow-x: auto;">
                        <MudTable Items="@stats4" Hover="true" Dense="true" Elevation="0" Style="min-width: 800px; background: transparent;">
                            <HeaderContent>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">名前</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">対局数</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap; color:#4caf50;">総合Pt</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap; color:#4caf50;">総合収支</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">(Pt収支)</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">(チップ収支)</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">平均順位</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">トップ率</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">ラス率</MudText></MudTh>
                            </HeaderContent>
                            <RowTemplate Context="stat">
                                <MudTd DataLabel="名前"><strong style="font-size: 1.1rem;">@stat.Name</strong></MudTd>
                                <MudTd DataLabel="対局数">@stat.TotalGames</MudTd>
                                <MudTd DataLabel="総合Pt">
                                    <span style="@(stat.TotalPoint >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;")">
                                        @(stat.TotalPoint > 0 ? "+" : "")@stat.TotalPoint.ToString("F1")
                                    </span>
                                </MudTd>
                                <MudTd DataLabel="総合収支" Style="background-color: rgba(76, 175, 80, 0.05);">
                                    <span style="@(stat.TotalYen >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;")">
                                        @(stat.TotalYen > 0 ? "+" : "")@stat.TotalYen.ToString("N0")円
                                    </span>
                                </MudTd>
                                <MudTd DataLabel="(Pt収支)" Style="color:#aaa; font-size:0.85rem;">@(stat.TotalGameYen > 0 ? "+" : "")@stat.TotalGameYen.ToString("N0")円</MudTd>
                                <MudTd DataLabel="(チップ収支)" Style="color:#aaa; font-size:0.85rem;">@(stat.TotalChipYen > 0 ? "+" : "")@stat.TotalChipYen.ToString("N0")円</MudTd>
                                <MudTd DataLabel="平均順位">@stat.AverageRank.ToString("F2")</MudTd>
                                <MudTd DataLabel="トップ率">@stat.FirstPlaceRate.ToString("F1")%</MudTd>
                                <MudTd DataLabel="ラス率">@stat.LastPlaceRate(4).ToString("F1")%</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="三人麻雀" Icon="@Icons.Material.Filled.PersonOutline">
                @if (stats3.Count == 0)
                {
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="py-10">三麻のデータはまだありません。</MudText>
                }
                else
                {
                    <MudPaper Class="pa-4 mt-2" Style="background-color: rgba(255,255,255,0.02);">
                        <MudText Typo="Typo.h6" Class="mb-4">基本成績ランキング (三麻)</MudText>
                        <div style="overflow-x: auto;">
                            <MudTable Items="@stats3" Hover="true" Dense="true" Elevation="0" Style="min-width: 800px; background: transparent;">
                                <HeaderContent>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">名前</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">対局数</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap; color:#4caf50;">総合Pt</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap; color:#4caf50;">総合収支</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">(Pt収支)</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">(チップ収支)</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">平均順位</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">トップ率</MudText></MudTh>
                                    <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">ラス率</MudText></MudTh>
                                </HeaderContent>
                                <RowTemplate Context="stat">
                                    <MudTd DataLabel="名前"><strong style="font-size: 1.1rem;">@stat.Name</strong></MudTd>
                                    <MudTd DataLabel="対局数">@stat.TotalGames</MudTd>
                                    <MudTd DataLabel="総合Pt">
                                        <span style="@(stat.TotalPoint >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;")">
                                            @(stat.TotalPoint > 0 ? "+" : "")@stat.TotalPoint.ToString("F1")
                                        </span>
                                    </MudTd>
                                    <MudTd DataLabel="総合収支" Style="background-color: rgba(76, 175, 80, 0.05);">
                                        <span style="@(stat.TotalYen >= 0 ? "color:#ff6b6b; font-weight:bold;" : "color:#4dabf7; font-weight:bold;")">
                                            @(stat.TotalYen > 0 ? "+" : "")@stat.TotalYen.ToString("N0")円
                                        </span>
                                    </MudTd>
                                    <MudTd DataLabel="(Pt収支)" Style="color:#aaa; font-size:0.85rem;">@(stat.TotalGameYen > 0 ? "+" : "")@stat.TotalGameYen.ToString("N0")円</MudTd>
                                    <MudTd DataLabel="(チップ収支)" Style="color:#aaa; font-size:0.85rem;">@(stat.TotalChipYen > 0 ? "+" : "")@stat.TotalChipYen.ToString("N0")円</MudTd>
                                    <MudTd DataLabel="平均順位">@stat.AverageRank.ToString("F2")</MudTd>
                                    <MudTd DataLabel="トップ率">@stat.FirstPlaceRate.ToString("F1")%</MudTd>
                                    <MudTd DataLabel="ラス率">@stat.LastPlaceRate(3).ToString("F1")%</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </div>
                    </MudPaper>
                }
            </MudTabPanel>
        </MudTabs>

        @* --- 相性分析エリア --- *@
        <MudPaper Class="pa-4 mt-6" Style="background-color: rgba(255,255,255,0.02);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Handshake" Size="Size.Medium" />
                <MudText Typo="Typo.h6">相性分析</MudText>
            </MudStack>
            <MudSelect T="string" Label="分析対象を選択" Value="@selectedHeroId" ValueChanged="OnHeroSelected" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4 align-center-select" Style="max-width: 200px; background-color: rgba(255,255,255,0.05);">
                @foreach (var p in availablePlayers)
                {
                    <MudSelectItem Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>

            @if (matchupStats.Count > 0)
            {
                <div style="overflow-x: auto;">
                    <MudTable Items="@matchupStats" Hover="true" Dense="true" Elevation="0" Style="min-width: 600px; background: transparent;">
                        <HeaderContent>
                            <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">相手</MudText></MudTh>
                            <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">同卓回数</MudText></MudTh>
                            <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">同卓時の収支</MudText></MudTh>
                            <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">同卓時のPt</MudText></MudTh>
                            <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">直接対決 (勝-負)</MudText></MudTh>
                            <MudTh><MudText Typo="Typo.caption" Style="font-weight: bold; white-space: nowrap;">先着率</MudText></MudTh>
                        </HeaderContent>
                        <RowTemplate Context="stat">
                            <MudTd DataLabel="相手"><strong style="font-size: 1.05rem;">@stat.OpponentName</strong></MudTd>
                            <MudTd DataLabel="同卓回数">@stat.GamesTogether 局</MudTd>
                            <MudTd DataLabel="同卓時の収支" Style="@(stat.HeroNetYen >= 0 ? "color:#ff6b6b; font-weight:bold; background-color: rgba(76, 175, 80, 0.05);" : "color:#4dabf7; font-weight:bold; background-color: rgba(244, 67, 54, 0.05);")">
                                @(stat.HeroNetYen > 0 ? "+" : "")@stat.HeroNetYen.ToString("N0")円
                            </MudTd>
                            <MudTd DataLabel="同卓時のPt" Style="@(stat.HeroNetPoint >= 0 ? "color:#ff6b6b;" : "color:#4dabf7;")">
                                @(stat.HeroNetPoint > 0 ? "+" : "")@stat.HeroNetPoint.ToString("F1")
                            </MudTd>
                            <MudTd DataLabel="直接対決">@stat.HeroWins 勝 - @stat.HeroLosses 負</MudTd>
                            <MudTd DataLabel="先着率">@stat.DirectWinRate.ToString("F1")%</MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            }
            else if (!string.IsNullOrEmpty(selectedHeroId))
            {
                <MudText Color="Color.Secondary" Class="mt-2">同卓データがありません。</MudText>
            }
        </MudPaper>
    }

    <div class="d-flex justify-center mt-6">
        <MudButton Href="" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home">
            入力画面に戻る
        </MudButton>
    </div>
</MudContainer>

@code {
    @inject MahjongApp.Services.DatabaseService DatabaseService

    // --- 集計結果を画面にバインドするためのViewModel ---
    private class PlayerStats
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int TotalGames { get; set; }
        public double TotalPoint { get; set; }
        // --- 収支関連（新設） ---
        public int TotalGameYen { get; set; } // ポイントによる収支
        public int TotalChipYen { get; set; } // チップによる収支
        public int TotalYen => TotalGameYen + TotalChipYen; // 総合収支
        public int[] RankCounts { get; set; } = new int[4];
        public double AverageRank => TotalGames == 0 ? 0 : RankCounts.Select((count, index) => count * (index + 1)).Sum() / (double)TotalGames;
        public double FirstPlaceRate => TotalGames == 0 ? 0 : (double)RankCounts[0] / TotalGames * 100;
        public double LastPlaceRate(int playerCount) => TotalGames == 0 ? 0 : (double)RankCounts[playerCount - 1] / TotalGames * 100;
    }

    private bool isLoading = true;

    // 三麻・四麻ごとの集計リスト
    private List<PlayerStats> stats4 = new();
    private List<PlayerStats> stats3 = new();

    // 総合収支（全ルール＋チップ合算）の算出用
    private string topPlayerName = "データなし";
    private int totalYenAllRules = 0;
    private int totalGameYenAllRules = 0;
    private int totalChipYenAllRules = 0;
    private double topPlayerAverageRank = 0;

    // --- 相性分析用の変数 ---
    private List<PlayerProfile> availablePlayers = new();
    private List<SavedGameRecord> allGames = new();
    private string? selectedHeroId;
    private List<MatchupStat> matchupStats = new();

    private class MatchupStat
    {
        public string OpponentName { get; set; } = "";
        public int GamesTogether { get; set; }
        public double HeroNetPoint { get; set; }
        public int HeroNetYen { get; set; }
        public int HeroWins { get; set; }
        public int HeroLosses { get; set; }
        public double DirectWinRate => (HeroWins + HeroLosses) == 0 ? 0 : (double)HeroWins / (HeroWins + HeroLosses) * 100;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAndCalculateStatsAsync();
        isLoading = false;
    }

    private async Task LoadAndCalculateStatsAsync()
    {
        try
        {
            var dbData = await DatabaseService.GetAllDataAsync();
            if (dbData == null || dbData.Players.Count == 0 || dbData.Games.Count == 0) return;
            allGames = dbData.Games;
            availablePlayers = dbData.Players.Where(p => p.Id != "deleted").OrderBy(p => p.Name).ToList();
            var statsMap4 = dbData.Players.ToDictionary(p => p.Id, p => new PlayerStats { Id = p.Id, Name = p.Name });
            var statsMap3 = dbData.Players.ToDictionary(p => p.Id, p => new PlayerStats { Id = p.Id, Name = p.Name });

            // 1. 局データ（ゲーム収支とポイント）を集計
            foreach (var game in dbData.Games)
            {
                bool isSanma = game.PlayerCount == 3;
                var currentMap = isSanma ? statsMap3 : statsMap4;

                var validPlayers = game.PlayerIds
                    .Select((id, idx) => new { Id = id, Score = game.RawScores.Count > idx ? game.RawScores[idx] : null, Index = idx })
                    .Where(x => !string.IsNullOrEmpty(x.Id) && x.Score.HasValue)
                    .OrderByDescending(x => x.Score)
                    .ToList();

                for (int rank = 0; rank < validPlayers.Count; rank++)
                {
                    var p = validPlayers[rank];
                    if (currentMap.ContainsKey(p.Id!))
                    {
                        var stat = currentMap[p.Id!];
                        var idx = p.Index;

                        stat.TotalGames++;
                        stat.RankCounts[rank]++;
                        stat.TotalPoint += game.Points.Count > idx ? game.Points[idx] : 0;
                        stat.TotalGameYen += game.Yen.Count > idx ? game.Yen[idx] : 0;
                    }
                }
            }

            // 2. セッション記録からチップ収支を集計
            foreach (var session in dbData.Sessions)
            {
                // そのセッションが三麻か四麻かを、紐づく最初のゲームから判定する
                var firstGame = dbData.Games.FirstOrDefault(g => g.SessionId == session.SessionId);
                bool isSanmaSession = firstGame != null && firstGame.PlayerCount == 3;
                var currentMap = isSanmaSession ? statsMap3 : statsMap4;

                for (int i = 0; i < session.ParticipantPlayerIds.Count; i++)
                {
                    string pId = session.ParticipantPlayerIds[i];
                    if (!string.IsNullOrEmpty(pId) && currentMap.ContainsKey(pId) && session.SettledChips.Count > i)
                    {
                        // チップ枚数 × 当時のチップレートを円として加算
                        currentMap[pId].TotalChipYen += session.SettledChips[i] * session.ChipRate;
                    }
                }
            }

            // 3. システム用の "deleted" を除外し、総合収支（TotalYen）順にソート
            stats4 = statsMap4.Values.Where(s => s.Id != "deleted" && s.TotalGames > 0).OrderByDescending(s => s.TotalYen).ToList();
            stats3 = statsMap3.Values.Where(s => s.Id != "deleted" && s.TotalGames > 0).OrderByDescending(s => s.TotalYen).ToList();

            // 4. ヒーローメトリクス用（全ルール合算でのトッププレイヤーを抽出）
            var combinedStats = dbData.Players.Where(p => p.Id != "deleted").Select(p => 
            {
                var s4 = statsMap4.ContainsKey(p.Id) ? statsMap4[p.Id] : null;
                var s3 = statsMap3.ContainsKey(p.Id) ? statsMap3[p.Id] : null;
                int games = (s4?.TotalGames ?? 0) + (s3?.TotalGames ?? 0);
                
                // 平均順位は対局数による重み付け平均
                double avgRank = games == 0 ? 0 : 
                    (((s4?.AverageRank ?? 0) * (s4?.TotalGames ?? 0)) + ((s3?.AverageRank ?? 0) * (s3?.TotalGames ?? 0))) / games;

                return new {
                    Name = p.Name,
                    TotalGames = games,
                    TotalYen = (s4?.TotalYen ?? 0) + (s3?.TotalYen ?? 0),
                    TotalGameYen = (s4?.TotalGameYen ?? 0) + (s3?.TotalGameYen ?? 0),
                    TotalChipYen = (s4?.TotalChipYen ?? 0) + (s3?.TotalChipYen ?? 0),
                    AverageRank = avgRank
                };
            })
            .Where(x => x.TotalGames > 0)
            .OrderByDescending(x => x.TotalYen)
            .ToList();

            // 5. 合算トップのデータをメトリクスにセット
            var topPlayer = combinedStats.FirstOrDefault();
            if (topPlayer != null)
            {
                topPlayerName = topPlayer.Name;
                totalYenAllRules = topPlayer.TotalYen;
                totalGameYenAllRules = topPlayer.TotalGameYen;
                totalChipYenAllRules = topPlayer.TotalChipYen;
                topPlayerAverageRank = topPlayer.AverageRank;
            }

            // 6. 相性分析の初期化（デフォルトでトッププレイヤーを選択）
            if (string.IsNullOrEmpty(selectedHeroId) && topPlayer != null)
            {
                selectedHeroId = availablePlayers.FirstOrDefault(p => p.Name == topPlayerName)?.Id;
            }
            CalculateMatchups();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ダッシュボードの集計エラー: {ex.Message}");
        }
    }

    private void OnHeroSelected(string id)
    {
        selectedHeroId = id;
        CalculateMatchups();
    }

    private void CalculateMatchups()
    {
        matchupStats.Clear();
        if (string.IsNullOrEmpty(selectedHeroId)) return;

        var map = new Dictionary<string, MatchupStat>();

        foreach (var game in allGames)
        {
            // 自分（Hero）がその局に参加しているかチェック
            int heroIdx = game.PlayerIds.IndexOf(selectedHeroId);
            if (heroIdx < 0 || heroIdx >= game.RawScores.Count || !game.RawScores[heroIdx].HasValue) continue;

            double heroPt = game.Points.Count > heroIdx ? game.Points[heroIdx] : 0;
            int heroYen = game.Yen.Count > heroIdx ? game.Yen[heroIdx] : 0;
            double heroRaw = game.RawScores[heroIdx]!.Value; 

            // 同じ局にいた他のプレイヤーを走査
            for (int i = 0; i < game.PlayerIds.Count; i++)
            {
                string? oppId = game.PlayerIds[i];
                // 空席、削除済みアカウント、または自分自身ならスキップ
                if (string.IsNullOrEmpty(oppId) || oppId == "deleted" || oppId == selectedHeroId) continue;
                if (!game.RawScores[i].HasValue) continue; // 相手が抜け番ならスキップ

                if (!map.ContainsKey(oppId))
                {
                    map[oppId] = new MatchupStat { OpponentName = availablePlayers.FirstOrDefault(p => p.Id == oppId)?.Name ?? "不明" };
                }

                var stat = map[oppId];
                stat.GamesTogether++;
                
                // 「同卓したときの自分の成績」を相手ごとに蓄積
                stat.HeroNetPoint += heroPt;
                stat.HeroNetYen += heroYen;

                // 直接対決（素点の比較による先着判定）
                double oppRaw = game.RawScores[i]!.Value;
                if (heroRaw > oppRaw) stat.HeroWins++;
                else if (heroRaw < oppRaw) stat.HeroLosses++;
            }
        }

        // 収支（同卓時の自分のプラスが大きい＝カモ）順にソート
        matchupStats = map.Values.OrderByDescending(s => s.HeroNetYen).ToList();
    }
}