@page "/settings"
@using Microsoft.AspNetCore.Components.Forms
@inject MahjongApp.Services.DatabaseService DatabaseService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject MahjongApp.Services.StatsCacheService StatsCache
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4 pb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6" Style="font-family: 'Kaisei Decol', serif; font-weight: bold; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" Class="mr-2" Style="vertical-align: bottom;" />
        データ管理
    </MudText>
    @* バックアップ *@
    <MudPaper Class="pa-6 mb-6" Outlined="true" Style="border-color: var(--mud-palette-info);">
        <MudText Typo="Typo.h6" Class="mb-2" Color="Color.Info">データのバックアップ</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">
            現在のすべての成績データと対局者名簿を<br />
            JSONファイルとしてダウンロードします。
        </MudText>
        @* データ消失に関する注意喚起 *@
        <MudAlert Severity="Severity.Normal" Icon="@Icons.Material.Filled.Lightbulb" Class="mb-4 pa-3" Style="font-size: 0.8rem; line-height: 1.5; background-color: rgba(41, 182, 246, 0.05);">
            <div style="font-weight: bold; margin-bottom: 4px;">データ保存に関するTips</div>
            @if (!envInfo.IsPwa)
            {
                @* Web *@
                <div>
                    データは現在のブラウザに保存されています。<br />
                    以下の操作でデータが消去されるため、<br />
                    事前のバックアップを推奨します。<br />
                    <ul style="margin-top: 4px; margin-bottom: 0; padding-left: 20px;">
                        <li>ブラウザの履歴・キャッシュの消去</li>
                        <li>プライベートモードでの利用終了</li>
                        <li>機種変更や別ブラウザへの移行</li>
                    </ul>
                </div>
                <div style="margin-top: 8px; color: var(--mud-palette-warning); font-weight: bold;">
                    @if (envInfo.IsIOS)
                    {
                        @* iOS *@
                        <span>
                            「ホーム画面に追加」してアプリ化する場合、<br /><span style="color: var(--mud-palette-error);">
                            ブラウザのデータはアプリに引き継がれません。</span><br />
                            事前にバックアップを保存し、アプリ側で復元してください。
                        </span>
                    }
                    else
                    {
                        @* Android *@
                        <span>
                            「アプリとして追加」でアプリ化できます。<br />
                            ブラウザのデータはアプリに引き継がれます。
                        </span>
                    }
                </div>
            }
            else
            {
                @* PWA *@
                <div style="margin-top: 8px; color: var(--mud-palette-normal); font-weight: bold;">
                    @if (envInfo.IsIOS)
                    {
                        @* iOS *@
                        <span>
                            長期間アプリを使用しないとOSの判断で<br />
                            データが削除される場合があります。<br />
                            こまめなバックアップを推奨します。
                        </span>
                    }
                    else if (envInfo.IsAndroid)
                    {
                        @* Android *@
                        <span>
                            アプリのデータはインストール元のブラウザと<br />
                            共有されています。<br />
                            ブラウザの履歴やCookie消去でデータが<br />
                            消失するためご注意ください。
                        </span>
                    }
                    else
                    {
                        @* Windowsなど *@
                        <span>
                            ブラウザのキャッシュやサイトデータをクリアすると<br />
                            アプリのデータも消える可能性があります。
                        </span>
                    }
                </div>
            }
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportData">
            バックアップファイルを保存
        </MudButton>
    </MudPaper>
    @* ダウンロード *@
    <MudPaper Class="pa-6 mb-6" Outlined="true" Style="border-color: var(--mud-palette-warning);">
        <MudText Typo="Typo.h6" Class="mb-2" Color="Color.Warning">データの復元・統合</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">
            バックアップされたJSONファイルを<br />
            読み込みます。
        </MudText>
        @* モード選択のラジオボタン *@
        <MudRadioGroup @bind-Value="importMode" Class="mb-4 d-flex flex-column">
            <MudRadio Value='"overwrite"' Color="Color.Error">
                <strong>完全上書き</strong><br />(データを消去して入れ替えます)
            </MudRadio>
            <MudRadio Value='"merge"' Color="Color.Success">
                <strong>データ統合</strong><br />(データに差分を追加します)
            </MudRadio>
        </MudRadioGroup>
        <MudButton HtmlTag="label" for="backup-upload" Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Upload">
            ファイルを選択して実行
        </MudButton>
        <InputFile id="backup-upload" OnChange="ImportData" accept=".json" style="display: none;" />
    </MudPaper>
    @* 全データ初期化 *@
    <MudPaper Class="pa-6" Outlined="true" Style="border-color: var(--mud-palette-error);">
        <MudText Typo="Typo.h6" Color="Color.Error" Class="mb-2">⚠️データの初期化</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">
            すべての対局者名簿と対局履歴を<br />
            完全に消去します。<br />
            事前のバックアップをお勧めします。
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="ConfirmWipeAllData">
            全データを初期化する
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private string importMode = "merge"; // 初期値は統合

    // 初期化時にJSを呼び出して判定
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            envInfo = await JSRuntime.InvokeAsync<EnvironmentInfo>("pwaHelper.getEnvironmentInfo");
            StateHasChanged();
        }
    }

    private EnvironmentInfo envInfo = new();

    private async Task ExportData()
    {
        try
        {
            string result = await DatabaseService.ExportDataAsync();
            if (result == "SHARED")
            {
                Snackbar.Add("バックアップファイルをシェアしました", Severity.Success);
            }
            else if (result == "DOWNLOADED")
            {
                Snackbar.Add("バックアップファイルをダウンロードしました", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"エクスポートに失敗しました:\n{ex.Message}", Severity.Error);
        }
    }

    private async Task ImportData(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        bool isMerge = importMode == "merge";
        string title = isMerge ? "データの統合" : "データの完全上書き";
        string message = isMerge
            ? "現在のデータにバックアップファイルのデータを追加・統合します。\n（※同じIDの履歴はバックアップ側の内容で更新されます）\n本当によろしいですか？"
            : "現在のアプリ内のデータはすべて消去され、選択したファイルの内容で上書きされます。\n本当によろしいですか？";
        bool? result = await DialogService.ShowMessageBoxAsync(
            title, message, yesText: "はい、実行します", cancelText: "キャンセル");

        if (result != true) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            // DBへ流し込む前に、C#側でJSONスキーマの妥当性を事前検証する
            try
            {
                var options = new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                };
                // AllDbData型にパースできるかテスト
                var testParse = System.Text.Json.JsonSerializer.Deserialize<MahjongApp.Services.AllDbData>(json, options);

                if (testParse == null || (testParse.Players == null && testParse.Games == null))
                {
                    Snackbar.Add("ファイル形式が正しくありません。麻雀集計ツールのバックアップデータを選択してください。", Severity.Error);
                    return;
                }
            }
            catch (System.Text.Json.JsonException)
            {
                // JSONとしてそもそも解析不能なファイル（テキストファイルや画像など）が来た場合
                Snackbar.Add("ファイルの解析に失敗しました。無効なファイルです。", Severity.Error);
                return;
            }
            // 検証を通過した場合のみインポートを実行
            await DatabaseService.ImportDataAsync(json, isMerge);
            _ = StatsCache.InitializeAsync(forceReload: true); // キャッシュの再構築
            string successMsg = isMerge ? "データを統合しました！" : "データを復元しました！";
            Snackbar.Add(successMsg, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"ファイルの読み込み処理中にエラーが発生しました:\n{ex.Message}", Severity.Error);
        }
    }

    // 全データ初期化
    private async Task ConfirmWipeAllData()
    {
        bool? result1 = await DialogService.ShowMessageBoxAsync(
            "全データの初期化",
            (MarkupString)"すべての対局者名簿と対局履歴を完全に消去します。<br />よろしいですか？",
            yesText: "はい、消去します", cancelText: "キャンセル");
        if (result1 == true)
        {
            bool? result2 = await DialogService.ShowMessageBoxAsync(
                "最終確認",
                (MarkupString)"本当にすべてのデータを消去しますか？",
                yesText: "はい、消去します", cancelText: "キャンセル");
            if (result2 == true)
            {
                await DatabaseService.ClearAllDataAsync();
                Snackbar.Add("すべてのデータを初期化しました", Severity.Success);
            }
        }
    }
}